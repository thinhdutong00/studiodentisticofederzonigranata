---
import BaseLayout from '../components/BaseLayout.astro';
import { site } from '../data/site';

const heroImages = [
  {
    src: '/assets/chi-siamo/hero-bambina-visita-color.png',
    alt: 'Bambina durante una visita odontoiatrica',
  },
  {
    src: '/assets/chi-siamo/hero-controllo-sorriso.png',
    alt: 'Controllo del sorriso con specchio in studio dentistico',
  },
  {
    src: '/assets/chi-siamo/hero-procedura-clinica.jpg',
    alt: 'Equipe odontoiatrica durante una procedura clinica',
  },
  {
    src: '/assets/original/2021/02/HOME.jpg',
    alt: 'Dottor Stefano Granata e Dottoressa Chiara Federzoni nello studio dentistico',
  },
];

const values = [
  'Vicini a te',
  'Verso una odontoiatria di precisione',
  'La prevenzione è la prima cura',
];

const teamCards = [
  {
    name: 'Dottoressa Chiara Federzoni',
    role: 'Odontoiatria conservativa, endodonzia e ortodonzia',
    image: '/assets/original/2020/10/Livello-12.jpg',
    alt: 'Dottoressa Chiara Federzoni',
  },
  {
    name: 'Dottor Stefano Granata',
    role: 'Protesi, implantologia e chirurgia computer guidata',
    image: '/assets/original/2020/10/Livello-13.jpg',
    alt: 'Dottor Stefano Granata',
  },
  {
    name: 'Dottor Giovanni Strozzi',
    role: 'Odontoiatria e percorsi specialistici',
    image: '/assets/original/2020/11/Dottor-Giovanni-Strozza-scaled.jpg',
    alt: 'Dottor Giovanni Strozzi',
  },
  {
    name: 'ASO Alejandra Bellini',
    role: 'Assistente di studio odontoiatrico',
    image: '/assets/original/2020/11/ASO-Alejandra-Bellini-scaled.jpg',
    alt: 'ASO Alejandra Bellini',
  },
  {
    name: 'ASO Agnese Leoni',
    role: 'Assistente di studio odontoiatrico',
    image: '/assets/original/2022/05/agnese.jpg',
    alt: 'ASO Agnese Leoni',
  },
];

const networkImages = [
  {
    src: '/assets/chi-siamo/network-stefano-granata-relatore.jpg',
    alt: 'Dottor Stefano Granata durante un intervento formativo',
  },
  {
    src: '/assets/chi-siamo/network-raggi-x-impianto.png',
    alt: 'Radiografia dentale con impianto',
  },
  {
    src: '/assets/original/2022/03/dentista-modena-reggio-emilia.jpg',
    alt: 'Dottor Stefano Granata e Dottoressa Chiara Federzoni davanti al monitor',
  },
];

const officeImages: Record<string, { src: string; alt: string; position: string }> = {
  Modena: {
    src: '/assets/chi-siamo/sede-modena-ambulatorio.png',
    alt: 'Ambulatorio dello Studio Dentistico Federzoni Granata di Modena',
    position: 'center',
  },
  'Reggio Emilia': {
    src: '/assets/original/2022/05/dentista-reggio-emilia-modena-3.jpg',
    alt: 'Studio dentistico Federzoni Granata di Reggio Emilia',
    position: 'center',
  },
};

const officeDetails: Record<string, { label: string; title: string; description: string; cta: string }> = {
  Modena: {
    label: 'Studio Dentistico Federzoni Granata',
    title: 'Studio dentistico a Modena',
    description:
      'Nel cuore di Modena, lo studio accoglie adulti e bambini per visite, prevenzione, odontoiatria digitale e percorsi specialistici coordinati.',
    cta: 'Vai alla sede di Modena',
  },
  'Reggio Emilia': {
    label: 'Studio Dentistico Federzoni Granata',
    title: 'Studio dentistico a Reggio Emilia',
    description:
      'La sede di Reggio Emilia offre lo stesso metodo clinico: diagnosi accurata, tecnologie digitali e continuità nei controlli periodici.',
    cta: 'Vai alla sede di Reggio Emilia',
  },
};

const serviceCards = [
  {
    title: 'Trattamenti odontoiatrici',
    text: 'Prevenzione, estetica, chirurgia, implantologia, ortodonzia e riabilitazioni pensate su misura.',
    href: '/trattamenti/',
    image: '/assets/original/2021/01/06-E-foto-chir-guidata-1.jpeg',
    alt: 'Pianificazione digitale di un trattamento odontoiatrico',
  },
  {
    title: 'Qualità e tecnologia',
    text: 'Strumenti digitali per diagnosi, pianificazione e controllo dei percorsi clinici.',
    href: '/strumentazioni-attrezzature-tecniche/',
    image: '/assets/feature-stack/tecnologia-studio.jpg',
    alt: 'Tecnologia diagnostica digitale nello studio dentistico',
  },
];
---

<BaseLayout
  title="Chi siamo - Studio dentistico Federzoni Granata"
  description="Conosci lo Studio Dentistico Federzoni Granata, il metodo di lavoro, i valori e le sedi di Modena e Reggio Emilia."
  ogImage="/assets/original/2021/02/HOME.jpg"
  canonicalPath="/chi-siamo/"
>
  <div class="about-page">
    <section class="about-hero" aria-labelledby="about-title">
      <div class="about-wrap about-hero-copy">
        <p class="about-kicker">Studio Dentistico Federzoni Granata</p>
        <h1 id="about-title"><span>Il tuo sorriso,</span><span>la nostra priorità</span></h1>
        <div class="about-lead">
          <p>
            A Modena e Reggio Emilia accompagniamo adulti e bambini in percorsi odontoiatrici fondati su ascolto,
            diagnosi accurata e tecnologie digitali, con un approccio coordinato che segue ogni fase della salute orale.
          </p>
          <p>
            Ogni piano di cura nasce da una valutazione completa: prevenzione, estetica, chirurgia, implantologia,
            ortodonzia e riabilitazioni vengono integrate per proteggere salute, funzione e naturalezza del sorriso,
            con attenzione costante alla relazione e alla continuità nel tempo.
          </p>
        </div>
      </div>

      <div class="hero-image-strip" aria-label="Immagini dello studio">
        {heroImages.map((image) => (
          <figure>
            <img src={image.src} alt={image.alt} loading="eager" />
          </figure>
        ))}
      </div>
    </section>

    <section class="vision-section" aria-labelledby="vision-title">
      <div class="about-wrap text-stack">
        <article>
          <h2 id="vision-title">La nostra visione.</h2>
          <p>
            All’orizzonte vediamo uno studio odontoiatrico che mette al centro le persone, attraverso una cura sempre
            più specialistica, capace di rispondere alle esigenze cliniche di ogni paziente prendendolo in carico
            completamente dalla prima visita, alla diagnosi digitale, sino al trattamento e ai controlli nel tempo.
          </p>
        </article>

        <article>
          <h2>La nostra missione.</h2>
          <p>
            Tutti i servizi dello Studio Dentistico Federzoni Granata sono finalizzati a costruire un percorso
            ragionato, organizzato ed efficiente per gestire salute orale, benessere e prevenzione dei pazienti, grazie
            alla possibilità di coordinare tecnologie, competenze specialistiche e controlli nel tempo.
          </p>
        </article>
        <a class="vision-more" href="#values-title">Leggi di più <span aria-hidden="true">+</span></a>
      </div>
    </section>

    <section class="values-section" aria-labelledby="values-title">
      <div class="about-wrap values-title-wrap">
        <h2 id="values-title">I nostri valori</h2>
      </div>
      <div class="about-wrap values-grid">
        <div class="values-copy">
          <div class="values-intro">
            <p class="values-eyebrow">L’attenzione dei migliori specialisti</p>
            <p>
              Tutta la disponibilità di un team di professionisti altamente specializzati, per una presa in carico
              completa: dalla visita, all’esame diagnostico, fino al percorso di cura e controllo.
            </p>
          </div>
          <ul class="value-list">
            {values.map((value) => <li>{value}</li>)}
          </ul>
        </div>
        <div class="team-carousel" data-team-carousel aria-label="Team dello Studio Dentistico Federzoni Granata">
          <div class="team-carousel-controls" aria-label="Controlli carosello team">
            <button class="team-carousel-button" type="button" data-carousel-prev aria-label="Team precedente">←</button>
            <button class="team-carousel-button team-carousel-button-next" type="button" data-carousel-next aria-label="Team successivo">→</button>
          </div>
          <div class="team-carousel-viewport" data-carousel-viewport>
            <div class="team-carousel-track">
              {teamCards.map((member) => (
                <article class="team-card">
                  <img src={member.image} alt={member.alt} loading="eager" />
                  <span class="team-card-shade" aria-hidden="true"></span>
                  <span class="team-card-copy">
                    <strong>{member.name}</strong>
                    <small>{member.role}</small>
                  </span>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="network-section" aria-labelledby="network-title">
      <div class="about-wrap network-copy">
        <h2 id="network-title"><span>La rete</span><span>odontoiatrica</span></h2>
        <div class="network-paragraphs">
          <p>
            Concepite come studi dentistici integrati, con servizi di diagnostica digitale, prevenzione, chirurgia,
            implantologia, ortodonzia ed estetica dentale che ruotano attorno alla persona, le nostre sedi sono un
            punto di riferimento per la salute del sorriso.
          </p>
          <p>
            Punto di forza è la continuità nella presa in carico, grazie a una organizzazione condivisa, a
            professionisti coordinati e a strumenti digitali che rendono visite, controlli e trattamenti più chiari e
            precisi nel tempo.
          </p>
        </div>
      </div>

      <div class="network-gallery" aria-label="Ambienti, tecnologia e persone dello studio">
        {networkImages.map((image) => (
          <figure>
            <img src={image.src} alt={image.alt} loading="eager" />
          </figure>
        ))}
      </div>

      <div class="about-wrap network-foot">
        <h3>I nostri studi dentistici a Modena e Reggio Emilia</h3>
        <div class="network-foot-copy">
          <p>
            Un unico metodo clinico, due sedi collegate da diagnosi, tecnologia e continuità organizzativa, per dare
            risposte affidabili e accompagnare ogni paziente nel percorso più adatto.
          </p>
          <a href="#sedi">Scopri le nostre sedi <span aria-hidden="true">↗</span></a>
        </div>
      </div>
    </section>

    <section id="sedi" class="offices-section" aria-labelledby="offices-title">
      <div class="about-wrap offices-head">
        <h2 id="offices-title">Le nostre sedi</h2>
        <p>
          Lo studio riceve in centro a Modena e a Reggio Emilia. In entrambe le sedi trovi gli stessi principi di lavoro:
          visita approfondita, strumenti digitali e comunicazione chiara.
        </p>
      </div>

      <div class="about-wrap office-list">
        {site.offices.map((office, index) => {
          const image = officeImages[office.city] || officeImages.Modena;
          const detail = officeDetails[office.city];

          return (
            <article class:list={['office-feature', index % 2 === 1 && 'office-feature-reverse']}>
              <div class="office-copy">
                <p class="office-city">{detail.label}</p>
                <h3>{detail.title}</h3>
                <p>{detail.description}</p>
                <p>{office.address}</p>
                <div class="office-actions">
                  <a href={office.href}>{detail.cta} <span aria-hidden="true">↗</span></a>
                </div>
              </div>
              <figure class="office-image" style={`--office-position: ${image.position};`}>
                <img src={image.src} alt={image.alt} loading="eager" />
              </figure>
            </article>
          );
        })}
      </div>
    </section>

    <section class="discover-section" aria-labelledby="discover-title">
      <div class="about-wrap discover-head">
        <h2 id="discover-title">Continua a scoprire i nostri servizi</h2>
      </div>
      <div class="about-wrap discover-grid">
        {serviceCards.map((card) => (
          <a class="discover-card" href={card.href}>
            <img src={card.image} alt={card.alt} loading="eager" />
            <span class="discover-shade" aria-hidden="true"></span>
            <span class="discover-copy">
              <strong>{card.title}</strong>
              <small>{card.text}</small>
            </span>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<script is:inline>
  document.querySelectorAll('[data-team-carousel]').forEach((carousel) => {
    const viewport = carousel.querySelector('[data-carousel-viewport]');
    const previous = carousel.querySelector('[data-carousel-prev]');
    const next = carousel.querySelector('[data-carousel-next]');
    const track = carousel.querySelector('.team-carousel-track');
    const originalCards = Array.from(carousel.querySelectorAll('.team-card')).filter(
      (card) => card instanceof HTMLElement,
    );

    if (
      !(viewport instanceof HTMLElement) ||
      !(previous instanceof HTMLButtonElement) ||
      !(next instanceof HTMLButtonElement) ||
      !(track instanceof HTMLElement) ||
      originalCards.length < 2
    ) {
      return;
    }

    const cloneCard = (card) => {
      const clone = card.cloneNode(true);
      if (clone instanceof HTMLElement) {
        clone.dataset.carouselClone = 'true';
        clone.setAttribute('aria-hidden', 'true');
      }
      return clone;
    };

    const beforeClones = originalCards.map(cloneCard);
    const afterClones = originalCards.map(cloneCard);

    beforeClones
      .slice()
      .reverse()
      .forEach((clone) => track.insertBefore(clone, track.firstChild));
    afterClones.forEach((clone) => track.appendChild(clone));

    const originalCount = originalCards.length;
    let currentIndex = originalCount;
    let autoplay = 0;
    let isAnimating = false;
    let isPaused = false;
    let resizeFrame = 0;
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    const getStep = () => {
      const cardWidth = originalCards[0].getBoundingClientRect().width;
      const styles = window.getComputedStyle(track);
      const gap = Number.parseFloat(styles.columnGap || styles.gap || '0');
      return cardWidth + (Number.isNaN(gap) ? 0 : gap);
    };

    const setPosition = (animate = true) => {
      track.style.transition = animate ? 'transform 520ms ease' : 'none';
      track.style.transform = `translate3d(${-currentIndex * getStep()}px, 0, 0)`;
    };

    const stopAutoplay = () => {
      if (!autoplay) return;
      window.clearInterval(autoplay);
      autoplay = 0;
    };

    const pauseAutoplay = () => {
      isPaused = true;
      stopAutoplay();
    };

    const resumeAutoplay = () => {
      isPaused = false;
      startAutoplay();
    };

    const startAutoplay = () => {
      if (autoplay || isPaused || document.hidden || prefersReducedMotion.matches) return;
      autoplay = window.setInterval(() => moveCarousel(1), 3600);
    };

    const restartAutoplay = () => {
      stopAutoplay();
      startAutoplay();
    };

    const moveCarousel = (direction) => {
      if (isAnimating) return;
      isAnimating = true;
      currentIndex += direction;
      setPosition(true);
    };

    track.addEventListener('transitionend', (event) => {
      if (event.target !== track) return;

      if (currentIndex >= originalCount * 2) {
        currentIndex -= originalCount;
        setPosition(false);
      }

      if (currentIndex < originalCount) {
        currentIndex += originalCount;
        setPosition(false);
      }

      isAnimating = false;
    });

    previous.addEventListener('click', () => {
      moveCarousel(-1);
      restartAutoplay();
    });

    next.addEventListener('click', () => {
      moveCarousel(1);
      restartAutoplay();
    });

    carousel.addEventListener('pointerenter', pauseAutoplay);
    carousel.addEventListener('pointerleave', resumeAutoplay);
    carousel.addEventListener('mouseenter', pauseAutoplay);
    carousel.addEventListener('mouseleave', resumeAutoplay);

    carousel.addEventListener('focusin', () => {
      pauseAutoplay();
    });

    carousel.addEventListener('focusout', () => {
      resumeAutoplay();
    });

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        stopAutoplay();
      } else {
        startAutoplay();
      }
    });

    window.addEventListener('resize', () => {
      window.cancelAnimationFrame(resizeFrame);
      resizeFrame = window.requestAnimationFrame(() => setPosition(false));
    });

    setPosition(false);
    requestAnimationFrame(() => setPosition(false));
    startAutoplay();
    window.addEventListener('load', () => {
      setPosition(false);
      startAutoplay();
    }, { once: true });
  });
</script>

<style>
  .about-page {
    --about-green: var(--brand-primary-dark);
    --about-green-dark: var(--brand-primary-dark);
    --about-blue: var(--brand-blue);
    --about-ink: var(--text-dark);
    --about-muted: var(--muted-text);
    --about-soft: var(--soft-blue-bg);
    --about-soft-blue: var(--soft-blue-bg);
    --about-line: var(--border);
    background: var(--surface-white);
    color: var(--about-ink);
    font-family: "Inter", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    letter-spacing: 0;
  }

  .about-page :global(a) {
    color: inherit;
  }

  .about-wrap {
    width: min(1120px, calc(100% - 42px));
    margin: 0 auto;
  }

  .about-kicker {
    margin: 0 0 52px;
    color: var(--about-green);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.3;
    text-align: center;
    text-transform: uppercase;
  }

  .about-hero {
    --hero-strip-cut: 325px;
    padding: 126px 0 0;
    background: linear-gradient(
      to bottom,
      var(--about-soft) 0 calc(100% - var(--hero-strip-cut)),
      var(--surface-white) calc(100% - var(--hero-strip-cut)) 100%
    );
    color: var(--about-green);
    text-align: center;
  }

  .about-hero-copy {
    width: min(1500px, calc(100% - 220px));
    display: grid;
    justify-items: center;
  }

  .about-hero h1,
  .values-section h2,
  .network-section h2,
  .offices-section h2,
  .discover-section h2 {
    margin: 0;
    color: inherit;
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.02;
    text-transform: uppercase;
  }

  .about-hero h1 {
    max-width: none;
    font-size: 5.45rem;
    font-weight: 400;
    line-height: 0.98;
  }

  .about-hero h1 span {
    display: block;
    white-space: nowrap;
  }

  .about-lead {
    max-width: 1420px;
    margin: 68px auto 0;
    color: var(--about-green);
    font-size: 2.02rem;
    font-weight: 400;
    line-height: 1.43;
  }

  .about-lead p {
    margin: 0;
  }

  .about-lead p + p {
    margin-top: 54px;
  }

  .hero-image-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    align-items: center;
    gap: 22px;
    margin-top: 300px;
  }

  .hero-image-strip figure,
  .network-gallery figure,
  .values-image,
  .office-image {
    margin: 0;
    overflow: hidden;
  }

  .hero-image-strip figure {
    height: clamp(540px, 34vw, 680px);
    background: var(--border);
  }

  .hero-image-strip figure:nth-child(2),
  .hero-image-strip figure:nth-child(4) {
    height: clamp(620px, 38vw, 760px);
  }

  .hero-image-strip img,
  .network-gallery img,
  .values-image img,
  .office-image img,
  .discover-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-image-strip figure:nth-child(1) img {
    object-position: 62% center;
  }

  .hero-image-strip figure:nth-child(2) img {
    object-position: 49% center;
  }

  .hero-image-strip figure:nth-child(3) img {
    object-position: 46% center;
  }

  .hero-image-strip figure:nth-child(4) img {
    object-position: 70% center;
  }

  .vision-section {
    padding: 100px 0 106px;
    background: var(--surface-white);
  }

  .text-stack {
    width: min(1400px, calc(100% - 220px));
    max-width: none;
    display: grid;
    gap: 142px;
  }

  .text-stack h2 {
    margin: 0 0 60px;
    color: var(--about-green);
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: 3.65rem;
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.08;
  }

  .text-stack p {
    max-width: 1360px;
    margin: 0;
    color: var(--text-dark);
    font-size: 2.15rem;
    font-weight: 400;
    line-height: 1.34;
  }

  .vision-more {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    width: fit-content;
    margin-top: -22px;
    color: var(--about-green);
    font-size: 1rem;
    font-weight: 800;
    line-height: 1;
    text-decoration: none;
  }

  .vision-more span {
    width: 25px;
    height: 25px;
    display: inline-grid;
    place-items: center;
    border: 2px solid currentColor;
    border-radius: 50%;
    font-size: 1.4rem;
    font-weight: 500;
    line-height: 1;
  }

  .values-section {
    padding: 86px 0 118px;
    background: var(--about-green);
    color: var(--surface-white);
  }

  .values-title-wrap,
  .values-grid {
    width: min(1576px, calc(100% - 160px));
  }

  .values-title-wrap {
    margin-bottom: 88px;
    text-align: center;
  }

  .values-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(420px, 1.05fr);
    align-items: center;
    gap: 120px;
  }

  .values-section h2 {
    color: var(--surface-white);
    font-size: 3.9rem;
    text-align: center;
  }

  .values-copy {
    min-width: 0;
  }

  .values-intro {
    max-width: 610px;
    margin-bottom: 58px;
    border-left: 3px solid var(--brand-blue);
    padding-left: 52px;
  }

  .values-eyebrow {
    max-width: 18ch;
    margin: 0 0 24px;
    color: var(--brand-blue);
    font-size: 1.55rem;
    font-weight: 800;
    line-height: 1.08;
    text-transform: uppercase;
  }

  .values-intro p:not(.values-eyebrow) {
    max-width: 560px;
    margin: 0;
    color: var(--surface-white);
    font-size: 1.18rem;
    font-weight: 400;
    line-height: 1.55;
  }

  .value-list {
    display: grid;
    gap: 48px;
    margin: 0 0 0 55px;
    padding: 0;
    list-style: none;
  }

  .value-list li {
    color: var(--surface-white);
    max-width: 15ch;
    font-size: 2.25rem;
    font-weight: 500;
    line-height: 1.05;
    text-transform: uppercase;
  }

  .team-carousel {
    width: min(100%, 760px);
    min-width: 0;
    justify-self: end;
  }

  .team-carousel-controls {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    margin-bottom: 24px;
  }

