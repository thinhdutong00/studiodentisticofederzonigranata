---
import BaseLayout from '../components/BaseLayout.astro';
import ContentPage from '../components/ContentPage.astro';
import { site } from '../data/site';

export function getStaticPaths() {
  return [...site.pages, ...site.navigationPages, ...site.treatmentPages]
    .filter((page) => page.path !== '/' && page.path !== '/prima-visita/' && page.path !== '/chi-siamo/' && page.path !== '/orari-e-sedi/' && page.path !== '/trattamenti/' && page.path !== '/igiene-orale-prevenzione/')
    .map((page) => ({
      params: { slug: page.slug },
      props: { page },
    }));
}

const { page } = Astro.props;
---

<BaseLayout title={page.title} description={page.description} ogImage={page.ogImage || site.heroImage} canonicalPath={page.path}>
  <ContentPage page={page} />
</BaseLayout>
