---
import BaseLayout from '../components/BaseLayout.astro';
import { site } from '../data/site';
import { formatParentheticalDetail } from '../utils/formatParentheticalDetail';

const treatmentOrder = [
  'Igiene orale e Prevenzione',
  'Sbiancamento',
  'Conservativa (otturazioni)',
  'Endodonzia (devitalizzazioni)',
  'Pedodonzia (odontoiatria infantile)',
  'Ortodonzia e Allineatori invisibili (adulti e bimbi)',
  'Estetica diretta (faccette in composito)',
  'Parodontologia (cure gengivali)',
  'Protesi fissa e mobile',
  'Estetica Indiretta (faccette in porcellana)',
  'Chirurgia Stomatologica',
  'Implantologia tradizionale e computer guidata',
  'Gnatologia (disturbi articolazione temporo-mandibolare)',
  'Dispositivi contro il russamento e le apnee notturne',
];

const treatmentMenuLabels: Record<string, string> = {
  'Igiene orale e Prevenzione': 'Igiene e prevenzione',
  'Estetica diretta (faccette in composito)': 'Faccette in composito',
  'Estetica Indiretta (faccette in porcellana)': 'Faccette in ceramica',
  'Ortodonzia e Allineatori invisibili (adulti e bimbi)': 'Ortodonzia e allineatori',
  'Gnatologia (disturbi articolazione temporo-mandibolare)': 'Gnatologia',
  'Dispositivi contro il russamento e le apnee notturne': 'Russamento e apnee',
};

const treatmentDescriptions: Record<string, string> = {
  'Igiene orale e Prevenzione': 'Controlli periodici, igiene professionale e indicazioni personalizzate per proteggere denti e gengive nel tempo.',
  Sbiancamento: 'Trattamenti professionali per migliorare il colore del sorriso in modo controllato e rispettoso dei tessuti dentali.',
  'Conservativa (otturazioni)': 'Otturazioni, restauri e ricostruzioni per recuperare denti danneggiati preservando la struttura naturale.',
  'Endodonzia (devitalizzazioni)': 'Cure canalari e devitalizzazioni per trattare infezioni profonde e salvare il dente quando possibile.',
  'Pedodonzia (odontoiatria infantile)': 'Percorsi dedicati ai bambini, dalla prevenzione alle prime cure, con attenzione a serenità e fiducia.',
  'Ortodonzia e Allineatori invisibili (adulti e bimbi)': 'Soluzioni ortodontiche per adulti e bambini, anche con allineatori trasparenti e piani su misura.',
  'Estetica diretta (faccette in composito)': 'Faccette e restauri diretti in composito per armonizzare forma, proporzioni e naturalezza del sorriso.',
  'Parodontologia (cure gengivali)': 'Diagnosi e terapie per gengive e tessuti di sostegno, pensate per stabilizzare e proteggere il sorriso.',
  'Protesi fissa e mobile': 'Soluzioni protesiche fisse o mobili per recuperare estetica, masticazione e comfort quotidiano.',
  'Estetica Indiretta (faccette in porcellana)': 'Faccette in ceramica e soluzioni estetiche indirette per risultati resistenti, luminosi e naturali.',
  'Chirurgia Stomatologica': 'Interventi chirurgici del cavo orale, comprese estrazioni e procedure specialistiche pianificate con cura.',
  'Implantologia tradizionale e computer guidata': 'Impianti dentali tradizionali o guidati digitalmente per sostituire denti mancanti in modo preciso.',
  'Gnatologia (disturbi articolazione temporo-mandibolare)': 'Valutazione di articolazione, masticazione e bruxismo per migliorare equilibrio e comfort funzionale.',
  'Dispositivi contro il russamento e le apnee notturne': 'Dispositivi intraorali personalizzati per contribuire alla gestione di russamento e apnee notturne.',
};

const categoryLabels: Record<string, string> = {
  'Prevenzione ed estetica': 'Estetica e prevenzione',
};

const categorySummaries: Record<string, string> = {
  'Prevenzione ed estetica': 'Controllo, igiene e armonia estetica del sorriso.',
  'Odontoiatria conservativa': 'Cure per mantenere i denti naturali sani e funzionali.',
  'Ortodonzia e funzione': 'Allineamento, articolazione e benessere della masticazione.',
  'Chirurgia, impianti e protesi': 'Riabilitazioni complesse, impianti e salute gengivale.',
};

const cardPalette = [
  { bg: 'var(--soft-blue-bg)', accent: 'var(--brand-blue)', line: 'rgba(var(--brand-blue-rgb), 0.2)' },
  { bg: 'var(--soft-blue-bg)', accent: 'var(--brand-blue)', line: 'rgba(var(--brand-blue-rgb), 0.2)' },
  { bg: 'var(--soft-blue-bg)', accent: 'var(--brand-blue)', line: 'rgba(var(--brand-blue-rgb), 0.18)' },
  { bg: 'var(--soft-blue-bg)', accent: 'var(--warning)', line: 'rgba(var(--warning-rgb), 0.2)' },
  { bg: 'var(--soft-blue-bg)', accent: 'var(--success)', line: 'rgba(var(--success-rgb), 0.18)' },
  { bg: 'var(--soft-blue-bg)', accent: 'var(--error)', line: 'rgba(var(--error-rgb), 0.18)' },
];

const treatmentRank = (label: string) => {
  const index = treatmentOrder.indexOf(label);
  return index === -1 ? Number.MAX_SAFE_INTEGER : index;
};

const treatmentCategories = site.treatmentMenu.map((category) => ({
  ...category,
  displayLabel: categoryLabels[category.label] || category.label,
  summary: categorySummaries[category.label],
}));

const treatments = treatmentCategories
  .flatMap((category) =>
    category.items.map((item) => ({
      ...item,
      title: treatmentMenuLabels[item.label] || formatParentheticalDetail(item.label),
      description: treatmentDescriptions[item.label],
      categoryLabel: category.displayLabel,
      categorySummary: category.summary,
      categoryImage: category.image,
      categoryImageAlt: category.imageAlt,
    })),
  )
  .sort((a, b) => treatmentRank(a.label) - treatmentRank(b.label));
---

<BaseLayout
  title={`Trattamenti | ${site.name}`}
  description="Tutti i trattamenti odontoiatrici dello Studio Dentistico Federzoni Granata: prevenzione, estetica, ortodonzia, implantologia, chirurgia e protesi."
  ogImage="/assets/feature-stack/tecnologia-studio.jpg"
  canonicalPath="/trattamenti/"
  transparentHeader
>
  <div class="treatments-page">
    <section class="treatments-hero" aria-labelledby="treatments-title">
      <div class="treatments-hero-panel" data-transparent-header-region>
        <div class="treatments-wrap treatments-hero-copy">
          <h1 id="treatments-title">Trattamenti odontoiatrici</h1>
          <p>
            Ogni percorso parte da una valutazione completa e viene costruito intorno alla tua salute orale:
            prevenzione, estetica, funzione e riabilitazione vengono coordinate con tecnologie digitali e attenzione
            alla persona.
          </p>
        </div>
      </div>
      <figure class="treatments-hero-media">
        <img
          src="/assets/original/2022/03/dentista-modena-reggio-emilia.jpg"
          alt="Valutazione digitale nello Studio Dentistico Federzoni Granata"
          loading="eager"
        />
      </figure>
    </section>

    <section class="treatments-directory" aria-labelledby="directory-title">
      <div class="treatments-wrap">
        <div class="directory-head">
          <div>
            <p class="treatments-kicker">I percorsi dello studio</p>
            <h2 id="directory-title">Scegli la sezione più adatta</h2>
          </div>
          <p>
            Le card raccolgono le principali aree di trattamento dello studio e portano alle schede dedicate, dove
            approfondire indicazioni, obiettivi e modalità di cura.
          </p>
        </div>

        <div class="category-strip" aria-label="Categorie dei trattamenti">
          {treatmentCategories.map((category) => (
            <article class="category-pill">
              <img src={category.image} alt="" loading="lazy" />
              <span>
                <strong>{category.displayLabel}</strong>
                <small>{category.summary}</small>
              </span>
            </article>
          ))}
        </div>

        <div class="treatment-grid">
          {treatments.map((treatment, index) => {
            const palette = cardPalette[index % cardPalette.length];

            return (
              <a
                class="treatment-card"
                href={treatment.href}
                style={`--card-bg: ${palette.bg}; --card-accent: ${palette.accent}; --card-line: ${palette.line};`}
              >
                <span class="card-jump" aria-hidden="true">↗</span>
                <span class="card-media" aria-hidden="true">
                  <img src={treatment.categoryImage} alt="" loading="lazy" />
                </span>
                <span class="card-category">{treatment.categoryLabel}</span>
                <h3>{treatment.title}</h3>
                <p>{treatment.description}</p>
                <span class="card-action">
                  Vai alla sezione
                  <span aria-hidden="true">→</span>
                </span>
              </a>
            );
          })}

          <aside class="consult-card">
            <p class="consult-label">Valutazione clinica</p>
            <h3>Non sai da dove iniziare?</h3>
            <p>
              Raccontaci cosa ti serve: il team ti aiuta a individuare il percorso più adatto tra prevenzione,
              estetica, ortodonzia, chirurgia o riabilitazione.
            </p>
            <a href="/richiesta/">Richiedi una visita <span aria-hidden="true">↗</span></a>
          </aside>
        </div>

        <div class="directory-foot">
          <a href="/">← Torna alla Home</a>
          <span>{site.name}</span>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .treatments-page {
    --treatments-hero-bg: var(--blue-dark);
    --treatments-blue: var(--brand-blue);
    --treatments-blue-dark: var(--brand-cta);
    --treatments-ink: var(--text-dark);
    --treatments-muted: var(--muted-text);
    --treatments-soft: var(--background);
    --treatments-line: var(--border);
    background: var(--surface-white);
    color: var(--treatments-ink);
    font-family: "Inter", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    letter-spacing: 0;
  }

  .treatments-page :global(a) {
    color: inherit;
  }

  .treatments-wrap {
    width: min(1240px, calc(100% - 42px));
    margin: 0 auto;
  }

  .treatments-hero {
    background: var(--surface-white);
  }

  .treatments-hero-panel {
    min-height: clamp(500px, 54vw, 690px);
    display: grid;
    align-items: center;
    background: var(--treatments-hero-bg);
    color: var(--surface-white);
  }

  .treatments-kicker {
    display: flex;
    gap: 14px;
    align-items: center;
    margin: 0 0 24px;
    color: var(--treatments-blue);
    font-size: 0.84rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    line-height: 1.25;
    text-transform: uppercase;
  }

  .treatments-kicker::before {
    content: "";
    width: 52px;
    height: 2px;
    background: currentColor;
  }

  .treatments-hero h1 {
    max-width: 1500px;
    margin: 0 auto;
    color: var(--surface-white);
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: 7.1rem;
    font-weight: 500;
    letter-spacing: 0;
    line-height: 0.9;
    text-align: center;
    text-wrap: balance;
    text-transform: uppercase;
  }

  .treatments-hero-copy > p:not(.treatments-kicker) {
    max-width: 1280px;
    margin: 36px auto 0;
    color: var(--aqua);
    font-size: 2rem;
    font-weight: 650;
    line-height: 1.32;
    text-align: center;
  }

  .treatments-hero-media {
    margin: 0;
    height: clamp(320px, 39vw, 540px);
    overflow: hidden;
    background: var(--soft-blue-bg);
  }

  .treatments-hero-media img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center 48%;
  }

  .treatments-directory {
    padding: 82px 0 98px;
    background: var(--surface-white);
  }

  .directory-head {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(340px, 0.6fr);
    gap: 42px;
    align-items: end;
    margin-bottom: 34px;
  }

  .directory-head h2 {
    max-width: 720px;
    margin: 0;
    color: var(--treatments-blue-dark);
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: 3.1rem;
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1;
  }

  .directory-head > p {
    margin: 0;
    color: var(--treatments-muted);
    font-size: 1.08rem;
    line-height: 1.5;
  }

  .category-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-bottom: 34px;
  }

  .category-pill {
    min-height: 122px;
    display: grid;
    grid-template-columns: 64px minmax(0, 1fr);
    gap: 16px;
    align-items: center;
    border: 1px solid var(--treatments-line);
    border-radius: 8px;
    padding: 16px;
    background: var(--surface-white);
  }

  .category-pill img {
    width: 64px;
    aspect-ratio: 1;
    border-radius: 8px;
    object-fit: cover;
  }

  .category-pill strong,
  .category-pill small {
    display: block;
  }

  .category-pill strong {
    color: var(--treatments-blue-dark);
    font-size: 1rem;
    font-weight: 800;
    line-height: 1.15;
  }

  .category-pill small {
    margin-top: 7px;
    color: var(--treatments-muted);
    font-size: 0.88rem;
    line-height: 1.35;
  }

  .treatment-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
  }

  .treatment-card,
  .consult-card {
    min-height: 342px;
    border-radius: 8px;
  }

  .treatment-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding: 28px;
    overflow: hidden;
    border: 1px solid var(--card-line);
    background: var(--card-bg);
    color: var(--treatments-ink);
    text-decoration: none;
    box-shadow: 0 16px 42px rgba(var(--brand-primary-dark-rgb), 0.08);
    transition: border-color 160ms ease, box-shadow 160ms ease, transform 160ms ease;
  }

  .treatment-card:hover {
    border-color: color-mix(in srgb, var(--card-accent) 50%, white);
    box-shadow: 0 22px 54px rgba(var(--brand-primary-dark-rgb), 0.14);
    transform: translateY(-3px);
  }

  .card-jump {
    position: absolute;
    top: 22px;
    right: 24px;
    color: color-mix(in srgb, var(--card-accent) 65%, white);
    font-size: 1.28rem;
    line-height: 1;
  }

  .card-media {
    width: 82px;
    height: 60px;
    display: block;
    border-radius: 8px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.55);
  }

  .card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-category {
    width: fit-content;
    border-radius: 999px;
    padding: 7px 10px;
    background: rgba(255, 255, 255, 0.62);
    color: var(--card-accent);
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .treatment-card h3 {
    max-width: 12ch;
    margin: auto 0 0;
    color: var(--treatments-blue-dark);
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: 1.78rem;
    font-weight: 650;
    letter-spacing: 0;
    line-height: 1.02;
  }

  .treatment-card p {
    margin: 0;
    color: var(--text-dark);
    font-size: 1rem;
    line-height: 1.42;
  }

  .card-action {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: center;
    margin-top: auto;
    border-top: 1px solid var(--card-line);
    padding-top: 18px;
    color: var(--treatments-blue-dark);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .consult-card {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 20px;
    padding: 32px;
    background: var(--treatments-blue-dark);
    color: var(--surface-white);
    box-shadow: 0 24px 62px rgba(21, 90, 148, 0.24);
  }

  .consult-label {
    margin: 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .consult-card h3 {
    max-width: 10ch;
    margin: 0;
    color: var(--surface-white);
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: 2.05rem;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.04;
  }

  .consult-card p:not(.consult-label) {
    margin: 0;
    color: rgba(255, 255, 255, 0.82);
    font-size: 1rem;
    line-height: 1.5;
  }

  .consult-card a {
    min-height: 68px;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    border: 1px solid rgba(var(--surface-white-rgb), 0.64);
    border-radius: 12px;
    padding: 0 24px;
    background: var(--surface-white);
    color: var(--treatments-blue-dark);
    font-size: 1.03rem;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.2;
    text-align: center;
    text-decoration: none;
    text-transform: none;
    transition: background-color 160ms ease, border-color 160ms ease, transform 160ms ease;
  }

  .consult-card a:hover {
    background: var(--soft-blue-bg);
    color: var(--treatments-blue-dark);
    transform: translateY(-1px);
  }

  .consult-card a span {
    font-size: 1.45rem;
    line-height: 1;
  }

  .directory-foot {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    align-items: center;
    margin-top: 70px;
    border-top: 1px solid var(--treatments-line);
    padding-top: 28px;
    color: var(--treatments-muted);
    font-size: 0.88rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .directory-foot a {
    text-decoration: none;
  }

  .directory-foot a:hover {
    color: var(--treatments-blue-dark);
  }

  @media (max-width: 1120px) {
    .treatments-hero h1 {
      font-size: 5.4rem;
    }

    .treatments-hero-copy > p:not(.treatments-kicker) {
      font-size: 1.55rem;
    }

    .directory-head {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .directory-head > p {
      max-width: 760px;
    }

    .category-strip {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .treatment-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .treatments-wrap {
      width: min(100% - 30px, 1240px);
    }

    .treatments-hero {
      background: var(--surface-white);
    }

    .treatments-kicker {
      margin-bottom: 18px;
      font-size: 0.78rem;
    }

    .treatments-kicker::before {
      width: 34px;
    }

    .treatments-hero h1 {
      font-size: 2.9rem;
    }

    .treatments-hero-copy > p:not(.treatments-kicker) {
      margin-top: 26px;
      font-size: 1.12rem;
    }

    .treatments-directory {
      padding: 58px 0 68px;
    }

    .directory-head h2 {
      font-size: 2.35rem;
    }

    .category-strip,
    .treatment-grid {
      grid-template-columns: 1fr;
    }

    .category-pill {
      min-height: 106px;
    }

    .treatment-card,
    .consult-card {
      min-height: 298px;
      padding: 24px;
    }

    .treatment-card h3 {
      max-width: 14ch;
      font-size: 1.58rem;
    }

    .consult-card h3 {
      max-width: none;
      font-size: 1.82rem;
    }

    .directory-foot {
      display: grid;
      margin-top: 48px;
      font-size: 0.78rem;
    }
  }
</style>
