---
import BaseLayout from '../components/BaseLayout.astro';
import { site } from '../data/site';

const title = `Richiedi una valutazione - ${site.name}`;
const description =
  'Scegli il trattamento, indica il problema e invia una richiesta di appuntamento allo Studio Dentistico Federzoni Granata.';

const treatmentOptions = site.treatmentMenu.flatMap((category) =>
  category.items.map((item) => ({
    categoryId: category.id,
    categoryLabel: category.label,
    label: item.label,
    href: item.href,
  }))
);

const problemOptionsByCategory = {
  'prevenzione-estetica': [
    'Vorrei fare un controllo o una seduta di igiene',
    'Ho macchie o discromie sui denti',
    'Vorrei migliorare il sorriso',
    'Cerco una valutazione estetica completa',
  ],
  'cure-bambini': [
    'Ho dolore o fastidio a un dente',
    'Sento sensibilita al caldo o al freddo',
    'Penso di avere una carie o una vecchia otturazione da controllare',
    'Vorrei prenotare una visita per un bambino',
  ],
  'ortodonzia-funzione': [
    'Vorrei allineare i denti',
    'Ho fastidi alla mandibola o all articolazione',
    'Vorrei valutare allineatori trasparenti',
    'Ho bisogno di informazioni su russamento o apnee notturne',
  ],
  'chirurgia-gengive-protesi': [
    'Mi manca uno o piu denti',
    'Ho gengive che sanguinano o si ritirano',
    'Devo valutare un estrazione o un intervento',
    'Vorrei informazioni su impianti o protesi',
  ],
};

const requestConfig = {
  treatments: treatmentOptions,
  problemOptionsByCategory,
  timeSlots: ['09:00', '10:00', '11:00', '14:30', '15:30', '16:30', '17:30'],
};

const requestConfigJson = JSON.stringify(requestConfig).replace(/</g, '\\u003c');
---

<BaseLayout title={title} description={description} ogImage={site.heroImage} canonicalPath="/richiesta/">
  <section class="request-page" aria-labelledby="request-step-title">
    <div class="request-shell">
      <form class="request-form" data-request-form novalidate>
        <script id="request-config" type="application/json" set:html={requestConfigJson}></script>
        <input type="hidden" name="treatment" data-field="treatment" />
        <input type="hidden" name="treatmentCategory" data-field="treatmentCategory" />
        <input type="hidden" name="problem" data-field="problem" />
        <input type="hidden" name="preferredDate" data-field="preferredDate" />
        <input type="hidden" name="preferredTime" data-field="preferredTime" />

        <div class="request-progress" aria-hidden="true">
          <span data-progress-bar></span>
        </div>

        <p class="request-step-count" data-step-count>Step 1 di 4</p>

        <fieldset class="request-step is-active" data-step="0">
          <legend>
            <span class="quiz-kicker">Trattamento</span>
            <strong id="request-step-title">Per quale trattamento vuoi prenotare?</strong>
          </legend>

          <div class="treatment-groups">
            {site.treatmentMenu.map((category) => (
              <article class="treatment-group">
                <h2>{category.label}</h2>
                <div class="quiz-options">
                  {category.items.map((item) => (
                    <button
                      class="choice-btn"
                      type="button"
                      data-choice="treatment"
                      data-category-id={category.id}
                      data-category-label={category.label}
                      data-treatment-label={item.label}
                    >
                      {item.label}
                    </button>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </fieldset>

        <fieldset class="request-step" data-step="1" hidden>
          <legend>
            <span class="quiz-kicker">Esigenza</span>
            <strong>Quale situazione descrive meglio il tuo problema?</strong>
          </legend>

          <p class="selected-summary" data-selected-treatment>Seleziona prima un trattamento.</p>
          <div class="quiz-options quiz-options-large" data-problem-options></div>
        </fieldset>

        <fieldset class="request-step" data-step="2" hidden>
          <legend>
            <span class="quiz-kicker">Data e orario</span>
            <strong>Quando preferiresti venire in studio?</strong>
          </legend>

          <div class="date-time-grid">
            <div class="calendar-card">
              <div class="calendar-head">
                <button class="calendar-nav" type="button" data-calendar-prev aria-label="Mese precedente">‹</button>
                <p class="calendar-title" data-calendar-title></p>
                <button class="calendar-nav" type="button" data-calendar-next aria-label="Mese successivo">›</button>
              </div>
              <div class="calendar-weekdays" aria-hidden="true">
                <span>Lun</span>
                <span>Mar</span>
                <span>Mer</span>
                <span>Gio</span>
                <span>Ven</span>
                <span>Sab</span>
                <span>Dom</span>
              </div>
              <div class="calendar-grid" data-calendar-grid></div>
            </div>

            <div class="slot-card">
              <p class="slot-title">Orario preferito</p>
              <p class="slot-date" data-selected-date>Nessuna data selezionata</p>
              <div class="slot-grid" data-slot-grid></div>
            </div>
          </div>
        </fieldset>

        <fieldset class="request-step" data-step="3" hidden>
          <legend>
            <span class="quiz-kicker">Contatti</span>
            <strong>Lasciaci i tuoi dati</strong>
          </legend>

          <div class="field-grid">
            <label>
              <span>Nome intero</span>
              <input type="text" name="fullName" autocomplete="name" required />
            </label>
            <label>
              <span>Numero di telefono</span>
              <input type="tel" name="phone" autocomplete="tel" required />
            </label>
            <label class="field-wide">
              <span>Email</span>
              <input type="email" name="email" autocomplete="email" required />
            </label>
            <label class="field-wide">
              <span>Dettagli prima della visita <em>facoltativo</em></span>
              <textarea name="details" rows="4"></textarea>
            </label>
          </div>

          <p class="privacy-copy">
            Inviando la richiesta autorizzi lo studio a ricontattarti per gestire la preferenza di appuntamento indicata.
          </p>
        </fieldset>

        <p class="request-error" data-request-error role="alert" aria-live="polite"></p>

        <div class="request-actions">
          <button class="request-btn request-btn-outline" type="button" data-prev-step hidden>Indietro</button>
          <button class="request-btn request-btn-primary" type="button" data-next-step>Continua</button>
          <button class="request-btn request-btn-primary" type="submit" data-submit-request hidden>Invia la richiesta</button>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>

<style is:global>
  body {
    background: #fff;
  }

  .request-page {
    min-height: calc(100vh - var(--nav-height));
    padding: clamp(28px, 5vw, 58px) 0 78px;
    background: #fff;
    color: #17203a;
  }

  .request-shell {
    width: min(1180px, calc(100% - 48px));
    margin: 0 auto;
  }

  .quiz-kicker {
    display: block;
    margin: 0 0 10px;
    color: #1e37b7;
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .request-form {
    position: relative;
    min-height: calc(100vh - var(--nav-height) - 136px);
    padding: 0;
    background: transparent;
  }

  .request-progress {
    height: 8px;
    overflow: hidden;
    border-radius: 999px;
    background: #edf0f7;
  }

  .request-progress span {
    display: block;
    width: 25%;
    height: 100%;
    border-radius: inherit;
    background: #1e37b7;
    transition: width 220ms ease;
  }

  .request-step-count {
    margin: 20px 0 28px;
    color: #6d7483;
    font-weight: 900;
  }

  .request-step {
    min-width: 0;
    margin: 0;
    padding: 0;
    border: 0;
  }

  .request-step[hidden] {
    display: none;
  }

  .request-step legend {
    width: 100%;
    margin: 0 0 26px;
    padding: 0;
  }

  .request-step legend strong {
    display: block;
    max-width: 820px;
    color: #0f1f63;
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1.12;
  }

  .treatment-groups {
    display: grid;
    gap: 18px;
  }

  .treatment-group {
    border: 1px solid #e5e9f3;
    border-radius: 16px;
    padding: 18px;
    background: #fbfcff;
  }

  .treatment-group h2 {
    margin: 0 0 14px;
    color: #0f1f63;
    font-size: 1.04rem;
    line-height: 1.25;
  }

  .quiz-options {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .quiz-options-large {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .choice-btn,
  .date-btn,
  .slot-btn {
    border: 1px solid #dfe5f1;
    border-radius: 14px;
    background: #fff;
    color: #17203a;
    font: inherit;
    font-weight: 900;
    line-height: 1.25;
    text-align: left;
    cursor: pointer;
    transition: border-color 160ms ease, background 160ms ease, color 160ms ease, transform 160ms ease, box-shadow 160ms ease;
  }

  .choice-btn {
    min-height: 68px;
    padding: 18px;
  }

  .choice-btn:hover,
  .date-btn:hover,
  .slot-btn:hover {
    border-color: rgba(30, 55, 183, 0.42);
    transform: translateY(-1px);
    box-shadow: 0 14px 30px rgba(15, 31, 99, 0.08);
  }

  .choice-btn.is-selected,
  .date-btn.is-selected,
  .slot-btn.is-selected {
    border-color: #1e37b7;
    background: #1e37b7;
    color: #fff;
    box-shadow: 0 18px 34px rgba(30, 55, 183, 0.22);
  }

  .selected-summary {
    display: inline-flex;
    max-width: 100%;
    margin: 0 0 22px;
    border-radius: 999px;
    padding: 10px 16px;
    background: #f0f4ff;
    color: #1e37b7;
    font-weight: 900;
  }

  .date-time-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(260px, 0.8fr);
    gap: 22px;
  }

  .calendar-card,
  .slot-card {
    border: 1px solid #e5e9f3;
    border-radius: 18px;
    padding: 20px;
    background: #fbfcff;
  }

  .calendar-head {
    display: grid;
    grid-template-columns: 42px 1fr 42px;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
  }

  .calendar-title,
  .slot-title,
  .slot-date {
    margin: 0;
    color: #0f1f63;
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-weight: 900;
    line-height: 1.25;
    text-align: center;
  }

  .calendar-nav {
    width: 42px;
    height: 42px;
    border: 1px solid #dfe5f1;
    border-radius: 50%;
    background: #fff;
    color: #1e37b7;
    font-size: 1.6rem;
    font-weight: 900;
    line-height: 1;
    cursor: pointer;
  }

  .calendar-nav:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .calendar-weekdays,
  .calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 8px;
  }

  .calendar-weekdays {
    margin-bottom: 8px;
    color: #818897;
    font-size: 0.78rem;
    font-weight: 900;
    text-align: center;
    text-transform: uppercase;
  }

  .date-btn {
    min-height: 52px;
    padding: 0;
    text-align: center;
  }

  .date-btn:disabled {
    border-color: transparent;
    background: transparent;
    color: #b9bec9;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .calendar-empty {
    min-height: 52px;
  }

  .slot-card {
    display: flex;
    flex-direction: column;
  }

  .slot-title {
    text-align: left;
  }

  .slot-date {
    margin-top: 8px;
    color: #667083;
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: 0.96rem;
    text-align: left;
  }

  .slot-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin-top: 22px;
  }

  .slot-btn {
    min-height: 48px;
    padding: 10px;
    text-align: center;
  }

  .field-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .field-grid label {
    display: grid;
    gap: 8px;
    color: #17203a;
    font-weight: 900;
  }

  .field-grid label span {
    line-height: 1.25;
  }

  .field-grid em {
    color: #727b8e;
    font-style: normal;
    font-weight: 700;
  }

  .field-wide {
    grid-column: 1 / -1;
  }

  .field-grid input,
  .field-grid textarea {
    width: 100%;
    border: 1px solid #dfe5f1;
    border-radius: 14px;
    padding: 15px 16px;
    background: #fbfcff;
    color: #17203a;
    font: inherit;
    font-weight: 700;
    outline: none;
    transition: border-color 160ms ease, box-shadow 160ms ease, background 160ms ease;
  }

  .field-grid textarea {
    resize: vertical;
  }

  .field-grid input:focus,
  .field-grid textarea:focus {
    border-color: #1e37b7;
    background: #fff;
    box-shadow: 0 0 0 4px rgba(30, 55, 183, 0.1);
  }

  .field-grid .is-invalid {
    border-color: #c43b4d;
    box-shadow: 0 0 0 4px rgba(196, 59, 77, 0.1);
  }

  .privacy-copy {
    margin: 18px 0 0;
    color: #6d7483;
    font-size: 0.95rem;
    font-weight: 700;
  }

  .request-error {
    min-height: 26px;
    margin: 24px 0 0;
    color: #c43b4d;
    font-weight: 900;
  }

  .request-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 12px;
    margin-top: 26px;
  }

  .request-btn {
    min-height: 54px;
    border: 1px solid transparent;
    border-radius: 14px;
    padding: 14px 24px;
    font: inherit;
    font-weight: 900;
    cursor: pointer;
    transition: background 160ms ease, border-color 160ms ease, color 160ms ease, transform 160ms ease, box-shadow 160ms ease;
  }

  .request-btn:hover {
    transform: translateY(-1px);
  }

  .request-btn-primary {
    margin-left: auto;
    background: #1e37b7;
    color: #fff;
    box-shadow: 0 18px 34px rgba(30, 55, 183, 0.22);
  }

  .request-btn-primary:hover {
    background: #0f1f63;
  }

  .request-btn-outline {
    border-color: #dfe5f1;
    background: #fff;
    color: #1e37b7;
  }

  .request-btn-outline:hover {
    border-color: rgba(30, 55, 183, 0.35);
    background: #f4f6ff;
  }

  @media (max-width: 860px) {
    .request-page {
      padding: 22px 0 64px;
    }

    .request-form {
      min-height: 0;
    }

    .quiz-options,
    .quiz-options-large,
    .date-time-grid,
    .field-grid {
      grid-template-columns: 1fr;
    }

    .slot-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .request-actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .request-btn,
    .request-btn-primary {
      width: 100%;
      margin-left: 0;
    }
  }

  @media (max-width: 520px) {
    .request-shell {
      width: min(100% - 24px, 1180px);
    }

    .request-step legend strong {
      font-size: 1.62rem;
    }

    .calendar-card,
    .slot-card,
    .treatment-group {
      padding: 14px;
    }

    .calendar-head {
      grid-template-columns: 38px 1fr 38px;
      gap: 8px;
    }

    .calendar-nav {
      width: 38px;
      height: 38px;
    }

    .calendar-weekdays,
    .calendar-grid {
      gap: 5px;
    }

    .date-btn,
    .calendar-empty {
      min-height: 42px;
      font-size: 0.88rem;
    }
  }
</style>

<script>
  const form = document.querySelector('[data-request-form]');
  const configEl = document.getElementById('request-config');

  if (form instanceof HTMLFormElement && configEl?.textContent) {
    const config = JSON.parse(configEl.textContent);
    const steps = Array.from(form.querySelectorAll('[data-step]'));
    const progressBar = form.querySelector('[data-progress-bar]');
    const stepCount = form.querySelector('[data-step-count]');
    const errorBox = form.querySelector('[data-request-error]');
    const prevButton = form.querySelector('[data-prev-step]');
    const nextButton = form.querySelector('[data-next-step]');
    const submitButton = form.querySelector('[data-submit-request]');
    const selectedTreatment = form.querySelector('[data-selected-treatment]');
    const problemOptions = form.querySelector('[data-problem-options]');
    const calendarGrid = form.querySelector('[data-calendar-grid]');
    const calendarTitle = form.querySelector('[data-calendar-title]');
    const calendarPrev = form.querySelector('[data-calendar-prev]');
    const calendarNext = form.querySelector('[data-calendar-next]');
    const selectedDateLabel = form.querySelector('[data-selected-date]');
    const slotGrid = form.querySelector('[data-slot-grid]');
    const fields = {
      treatment: form.querySelector('[data-field="treatment"]'),
      treatmentCategory: form.querySelector('[data-field="treatmentCategory"]'),
      problem: form.querySelector('[data-field="problem"]'),
      preferredDate: form.querySelector('[data-field="preferredDate"]'),
      preferredTime: form.querySelector('[data-field="preferredTime"]'),
    };

    const state = {
      step: 0,
      treatment: '',
      categoryId: '',
      categoryLabel: '',
      problem: '',
      preferredDate: '',
      preferredTime: '',
    };

    const formatMonth = new Intl.DateTimeFormat('it-IT', { month: 'long', year: 'numeric' });
    const formatDay = new Intl.DateTimeFormat('it-IT', { weekday: 'long', day: 'numeric', month: 'long' });
    const today = new Date();
    today.setHours(0, 0, 0, 0);

    const dateKey = (date) => {
      const year = date.getFullYear();
      const month = String(date.getMonth() + 1).padStart(2, '0');
      const day = String(date.getDate()).padStart(2, '0');
      return `${year}-${month}-${day}`;
    };

    const dateFromKey = (key) => {
      const [year, month, day] = key.split('-').map(Number);
      return new Date(year, month - 1, day);
    };

    const availableDates = [];
    for (let offset = 1; offset <= 45; offset += 1) {
      const candidate = new Date(today);
      candidate.setDate(today.getDate() + offset);
      const day = candidate.getDay();
      if (day !== 0 && day !== 6) {
        availableDates.push(dateKey(candidate));
      }
    }

    const availableDateSet = new Set(availableDates);
    const minDate = dateFromKey(availableDates[0]);
    const maxDate = dateFromKey(availableDates[availableDates.length - 1]);
    let visibleMonth = new Date(minDate.getFullYear(), minDate.getMonth(), 1);

    const setError = (message = '') => {
      if (errorBox) {
        errorBox.textContent = message;
      }
    };

    const syncHiddenFields = () => {
      if (fields.treatment) fields.treatment.value = state.treatment;
      if (fields.treatmentCategory) fields.treatmentCategory.value = state.categoryLabel;
      if (fields.problem) fields.problem.value = state.problem;
      if (fields.preferredDate) fields.preferredDate.value = state.preferredDate;
      if (fields.preferredTime) fields.preferredTime.value = state.preferredTime;
    };

    const renderProblemOptions = () => {
      if (!problemOptions) return;
      const options = config.problemOptionsByCategory[state.categoryId] || [
        'Vorrei una prima valutazione',
        'Ho dolore o fastidio',
        'Vorrei migliorare estetica o funzione',
        'Ho bisogno di capire il percorso piu adatto',
      ];

      problemOptions.innerHTML = '';
      options.forEach((option) => {
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'choice-btn';
        button.dataset.choice = 'problem';
        button.textContent = option;
        button.setAttribute('aria-pressed', String(state.problem === option));
        if (state.problem === option) {
          button.classList.add('is-selected');
        }
        problemOptions.append(button);
      });
    };

    const renderSlots = () => {
      if (!slotGrid) return;
      slotGrid.innerHTML = '';
      config.timeSlots.forEach((slot) => {
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'slot-btn';
        button.dataset.timeSlot = slot;
        button.textContent = slot;
        button.setAttribute('aria-pressed', String(state.preferredTime === slot));
        if (state.preferredTime === slot) {
          button.classList.add('is-selected');
        }
        slotGrid.append(button);
      });
    };

    const renderCalendar = () => {
      if (!calendarGrid || !calendarTitle) return;
      calendarGrid.innerHTML = '';
      calendarTitle.textContent = formatMonth.format(visibleMonth);

      const year = visibleMonth.getFullYear();
      const month = visibleMonth.getMonth();
      const firstDay = new Date(year, month, 1);
      const firstWeekday = (firstDay.getDay() + 6) % 7;
      const daysInMonth = new Date(year, month + 1, 0).getDate();

      for (let i = 0; i < firstWeekday; i += 1) {
        const empty = document.createElement('span');
        empty.className = 'calendar-empty';
        calendarGrid.append(empty);
      }

      for (let day = 1; day <= daysInMonth; day += 1) {
        const date = new Date(year, month, day);
        const key = dateKey(date);
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'date-btn';
        button.dataset.date = key;
        button.textContent = String(day);
        button.disabled = !availableDateSet.has(key);
        button.setAttribute('aria-label', formatDay.format(date));
        button.setAttribute('aria-pressed', String(state.preferredDate === key));
        if (state.preferredDate === key) {
          button.classList.add('is-selected');
        }
        calendarGrid.append(button);
      }

      const previousMonth = new Date(year, month - 1, 1);
      const nextMonth = new Date(year, month + 1, 1);
      if (calendarPrev instanceof HTMLButtonElement) {
        calendarPrev.disabled = previousMonth < new Date(minDate.getFullYear(), minDate.getMonth(), 1);
      }
      if (calendarNext instanceof HTMLButtonElement) {
        calendarNext.disabled = nextMonth > new Date(maxDate.getFullYear(), maxDate.getMonth(), 1);
      }
    };

    const updateSelectedDateLabel = () => {
      if (!selectedDateLabel) return;
      selectedDateLabel.textContent = state.preferredDate
        ? formatDay.format(dateFromKey(state.preferredDate))
        : 'Nessuna data selezionata';
    };

    const renderStep = () => {
      steps.forEach((step, index) => {
        const isActive = index === state.step;
        step.toggleAttribute('hidden', !isActive);
        step.classList.toggle('is-active', isActive);
      });

      if (progressBar instanceof HTMLElement) {
        progressBar.style.width = `${((state.step + 1) / steps.length) * 100}%`;
      }
      if (stepCount) {
        stepCount.textContent = `Step ${state.step + 1} di ${steps.length}`;
      }
      if (prevButton instanceof HTMLButtonElement) {
        prevButton.hidden = state.step === 0;
      }
      if (nextButton instanceof HTMLButtonElement) {
        nextButton.hidden = state.step === steps.length - 1;
      }
      if (submitButton instanceof HTMLButtonElement) {
        submitButton.hidden = state.step !== steps.length - 1;
      }

      setError();
    };

    const selectChoice = (button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      const choiceType = button.dataset.choice;

      if (choiceType === 'treatment') {
        state.treatment = button.dataset.treatmentLabel || '';
        state.categoryId = button.dataset.categoryId || '';
        state.categoryLabel = button.dataset.categoryLabel || '';
        state.problem = '';

        form.querySelectorAll('[data-choice="treatment"]').forEach((option) => {
          const isSelected = option === button;
          option.classList.toggle('is-selected', isSelected);
          option.setAttribute('aria-pressed', String(isSelected));
        });

        if (selectedTreatment) {
          selectedTreatment.textContent = `${state.categoryLabel}: ${state.treatment}`;
        }
        renderProblemOptions();
      }

      if (choiceType === 'problem') {
        state.problem = button.textContent?.trim() || '';
        form.querySelectorAll('[data-choice="problem"]').forEach((option) => {
          const isSelected = option === button;
          option.classList.toggle('is-selected', isSelected);
          option.setAttribute('aria-pressed', String(isSelected));
        });
      }

      syncHiddenFields();
      setError();
    };

    const markInvalid = (input, invalid) => {
      if (input instanceof HTMLElement) {
        input.classList.toggle('is-invalid', invalid);
      }
    };

    const validateContactStep = () => {
      const fullName = form.elements.namedItem('fullName');
      const phone = form.elements.namedItem('phone');
      const email = form.elements.namedItem('email');
      const emailValue = email instanceof HTMLInputElement ? email.value.trim() : '';
      const isEmailValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailValue);

      const missingName = !(fullName instanceof HTMLInputElement) || fullName.value.trim().length < 2;
      const missingPhone = !(phone instanceof HTMLInputElement) || phone.value.trim().length < 6;
      const missingEmail = !isEmailValid;

      markInvalid(fullName, missingName);
      markInvalid(phone, missingPhone);
      markInvalid(email, missingEmail);

      if (missingName || missingPhone || missingEmail) {
        setError('Compila nome, telefono ed email per inviare la richiesta.');
        return false;
      }

      return true;
    };

    const validateCurrentStep = () => {
      if (state.step === 0 && !state.treatment) {
        setError('Seleziona un trattamento per continuare.');
        return false;
      }
      if (state.step === 1 && !state.problem) {
        setError('Seleziona la situazione piu vicina al tuo problema.');
        return false;
      }
      if (state.step === 2 && (!state.preferredDate || !state.preferredTime)) {
        setError('Scegli una data e una fascia oraria preferita.');
        return false;
      }
      if (state.step === 3) {
        return validateContactStep();
      }

      setError();
      return true;
    };

    form.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const choiceButton = target.closest('[data-choice]');
      if (choiceButton) {
        selectChoice(choiceButton);
        return;
      }

      const dateButton = target.closest('[data-date]');
      if (dateButton instanceof HTMLButtonElement && !dateButton.disabled) {
        state.preferredDate = dateButton.dataset.date || '';
        state.preferredTime = '';
        syncHiddenFields();
        renderCalendar();
        renderSlots();
        updateSelectedDateLabel();
        setError();
        return;
      }

      const slotButton = target.closest('[data-time-slot]');
      if (slotButton instanceof HTMLButtonElement) {
        state.preferredTime = slotButton.dataset.timeSlot || '';
        syncHiddenFields();
        renderSlots();
        setError();
      }
    });

    nextButton?.addEventListener('click', () => {
      if (!validateCurrentStep()) return;
      state.step = Math.min(state.step + 1, steps.length - 1);
      renderStep();
    });

    prevButton?.addEventListener('click', () => {
      state.step = Math.max(state.step - 1, 0);
      renderStep();
    });

    calendarPrev?.addEventListener('click', () => {
      visibleMonth = new Date(visibleMonth.getFullYear(), visibleMonth.getMonth() - 1, 1);
      renderCalendar();
    });

    calendarNext?.addEventListener('click', () => {
      visibleMonth = new Date(visibleMonth.getFullYear(), visibleMonth.getMonth() + 1, 1);
      renderCalendar();
    });

    form.addEventListener('input', (event) => {
      markInvalid(event.target, false);
      setError();
    });

    form.addEventListener('submit', (event) => {
      event.preventDefault();
      if (!validateCurrentStep()) return;

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
        submitButton.textContent = 'Invio in corso';
      }

      window.location.href = '/thank-you-page/';
    });

    renderProblemOptions();
    renderCalendar();
    renderSlots();
    updateSelectedDateLabel();
    syncHiddenFields();
    renderStep();
  }
</script>
