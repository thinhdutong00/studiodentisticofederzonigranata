---
import BaseLayout from '../components/BaseLayout.astro';
import { site } from '../data/site';

const pageDescription =
  'Prima visita odontoiatrica a Modena e Reggio Emilia: diagnosi chiara, priorità, tempi e costi prima di iniziare.';

const intentButtons = [
  { label: 'Dolore o urgenza', href: '/prenota-urgenza/' },
  { label: 'Impianti', href: '/richiesta/' },
  { label: 'Controllo generale', href: '/richiesta/' },
  { label: 'Secondo parere', href: '/richiesta/' },
];

const visitSteps = [
  {
    title: 'La tua storia clinica',
    text: 'Apriamo la cartella anamnestica e raccogliamo salute generale, farmaci, allergie, interventi e cure precedenti. Ogni dettaglio è un piccolo indizio che aiuta a leggere il quadro intero.',
  },
  {
    title: 'Ascolto ed aspettative',
    text: 'Diamo spazio a esigenze, timori e aspettative: cosa senti, cosa vorresti cambiare, cosa immagini per il tuo sorriso. Poi presentiamo i trattamenti possibili, con parole semplici e senza fretta.',
  },
  {
    title: 'Check orale specialistico',
    text: 'Lo specialista esegue la visita del cavo orale e, quando serve, una radiografia computer guidata. Sullo schermo osserviamo in tempo reale denti, gengive e tessuti, come una mappa appena illuminata.',
  },
  {
    title: 'Confronto dell’esame',
    text: 'Rileggiamo insieme ciò che è emerso, arriviamo a conclusioni chiare e valutiamo i percorsi possibili in base ai risultati. La scelta nasce dal confronto, non dalla fretta.',
  },
];

const evaluationAreas = [
  {
    label: 'Il problema principale',
    text: 'Da dove nasce il disturbo, il dubbio o il desiderio che ti porta in studio.',
  },
  {
    label: 'Denti e gengive',
    text: 'Carie, vecchie cure, fratture, infiammazione, sanguinamento e stabilità.',
  },
  {
    label: 'Radiografie ed esami',
    text: 'Valutiamo ciò che hai già. Se serve altro, lo indichiamo in modo mirato.',
  },
  {
    label: 'Opzioni di cura',
    text: 'Quando ci sono più strade, spieghiamo vantaggi, limiti e senso clinico.',
  },
  {
    label: 'Priorità e tempi',
    text: 'Non tutto va fatto subito. Distinguiamo urgenze, priorità e controlli.',
  },
  {
    label: 'Preventivo',
    text: 'Il piano viene collegato a tempi e costi, prima della decisione.',
  },
];

const preparationItems = [
  'Radiografie, TAC, referti o preventivi già ricevuti.',
  'Farmaci assunti e allergie note.',
  'Bite, apparecchi, mascherine o protesi.',
  'Domande, dubbi, paure o obiettivi estetici.',
];

const reasonIcons = {
  toothPain: `
    <path d="M17.5 8.5c2.7-1.2 4.8.4 6.5 1.1 1.7-.7 3.8-2.3 6.5-1.1 5.5 2.4 6.2 9.8 3.1 15.4-1.3 2.4-2.1 4.8-2.5 7.5-.7 4.4-2.2 8.1-5 8.1-1.7 0-2.3-2.3-2.7-4.8-.3-2.1-.8-4.1-1.4-4.1s-1.1 2-1.4 4.1c-.4 2.5-1 4.8-2.7 4.8-2.8 0-4.3-3.7-5-8.1-.4-2.7-1.2-5.1-2.5-7.5-3.1-5.6-2.4-13 3.1-15.4Z" />
    <path d="M32 12.5 28.5 18H34l-4 6.5" />
  `,
  bleedingGums: `
    <path d="M24 10.5c3.5 4.3 5.2 7.2 5.2 9.8a5.2 5.2 0 0 1-10.4 0c0-2.6 1.7-5.5 5.2-9.8Z" />
    <path d="M12.5 28c3.2-3.8 7-5.7 11.5-5.7S32.3 24.2 35.5 28" />
    <path d="M14 30.5c2.3 4.1 5.7 6.2 10 6.2s7.7-2.1 10-6.2" />
  `,
  implant: `
    <path d="M18 8.5h12a4.5 4.5 0 0 1 4.5 4.5v2.5A6.5 6.5 0 0 1 28 22h-8a6.5 6.5 0 0 1-6.5-6.5V13A4.5 4.5 0 0 1 18 8.5Z" />
    <path d="M24 22v18" />
    <path d="M19 27h10" />
    <path d="M20 32h8" />
    <path d="M21 37h6" />
  `,
  orthodontics: `
    <path d="M10.5 20.5c3.3-5.6 7.8-8.4 13.5-8.4s10.2 2.8 13.5 8.4" />
    <path d="M12 26h24" />
    <rect x="13" y="22" width="6" height="8" rx="2" />
    <rect x="21" y="22" width="6" height="8" rx="2" />
    <rect x="29" y="22" width="6" height="8" rx="2" />
    <path d="M14.5 34c2.9 2.2 6.1 3.3 9.5 3.3s6.6-1.1 9.5-3.3" />
  `,
  aesthetics: `
    <path d="M12.5 28.5c3.5 5.8 7.3 8.7 11.5 8.7s8-2.9 11.5-8.7" />
    <path d="M15 20.5c2.4-5.1 5.4-7.7 9-7.7s6.6 2.6 9 7.7" />
    <path d="M24 13.5v20" />
    <path d="M18.8 16.5 17.5 31" />
    <path d="m29.2 16.5 1.3 14.5" />
    <path d="m38 8.5 1.2 3.1 3.3 1.2-3.3 1.3-1.2 3.1-1.2-3.1-3.3-1.3 3.3-1.2L38 8.5Z" />
    <path d="m10 12.5.8 2.1 2.2.9-2.2.8-.8 2.2-.8-2.2-2.2-.8 2.2-.9.8-2.1Z" />
  `,
  checkup: `
    <rect x="13" y="10" width="22" height="30" rx="4" />
    <path d="M20 10V8h8v2" />
    <path d="m18 25 4 4 8-9" />
    <path d="M18 34h12" />
  `,
  calendar: `
    <rect x="10" y="11" width="28" height="27" rx="4" />
    <path d="M16 8v6" />
    <path d="M32 8v6" />
    <path d="M10 19h28" />
    <circle cx="24" cy="31" r="7" />
    <path d="M24 27.5V31l3 1.8" />
  `,
  secondOpinion: `
    <path d="M12 13h18a5 5 0 0 1 5 5v7a5 5 0 0 1-5 5h-8.5L14 36v-6h-2a5 5 0 0 1-5-5v-7a5 5 0 0 1 5-5Z" />
    <path d="M18 20h11" />
    <path d="M18 25h7" />
    <circle cx="33.5" cy="32.5" r="5.5" />
    <path d="m37.5 36.5 3.5 3.5" />
  `,
};

const goodReasons = [
  {
    icon: reasonIcons.toothPain,
    title: 'Mi fa male un dente',
    text: 'Capire l’origine del dolore aiuta a decidere subito cosa fare.',
  },
  {
    icon: reasonIcons.bleedingGums,
    title: 'Ho le gengive che sanguinano',
    text: 'Il sanguinamento è un segnale. Va letto, non normalizzato.',
  },
  {
    icon: reasonIcons.implant,
    title: 'Voglio sapere se mi servono impianti',
    text: 'Valutiamo denti mancanti, osso, gengive e alternative possibili.',
  },
  {
    icon: reasonIcons.orthodontics,
    title: 'Vorrei raddrizzare i denti',
    text: 'Allineatori e apparecchi partono da diagnosi e obiettivi realistici.',
  },
  {
    icon: reasonIcons.aesthetics,
    title: 'Mi interessano faccette o estetica',
    text: 'Prima dell’estetica guardiamo salute, funzione e aspettative.',
  },
  {
    icon: reasonIcons.checkup,
    title: 'Voglio un controllo generale',
    text: 'Anche senza dolore, un controllo può intercettare problemi iniziali.',
  },
  {
    icon: reasonIcons.calendar,
    title: 'Non vado dal dentista da anni',
    text: 'Si riparte senza giudizio. Una priorità alla volta.',
  },
  {
    icon: reasonIcons.secondOpinion,
    title: 'Ho un preventivo e voglio un secondo parere',
    text: 'Rileggiamo diagnosi, opzioni, tempi e senso del piano proposto.',
  },
];

const offices = site.offices.map((office) => ({
  ...office,
  mapHref: `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(office.address)}`,
}));
---

<BaseLayout
  title={`Prima visita | ${site.name}`}
  description={pageDescription}
  ogImage="/assets/original/2022/03/dentista-modena-reggio-emilia.jpg"
  canonicalPath="/prima-visita/"
  transparentHeader
>
  <div class="first-visit-page">
    <section class="fv-hero" aria-labelledby="first-visit-title">
      <div class="fv-hero-panel" data-transparent-header-region>
        <div class="fv-wrap fv-hero-inner">
          <div class="fv-hero-copy">
            <p class="fv-kicker">Prima visita odontoiatrica</p>
            <h1 id="first-visit-title">Prima visita</h1>
            <p>
              Dolore, gengive, impianti, denti storti, estetica, controllo o secondo parere.
              Ti diciamo cosa c’è, cosa serve e cosa aspettarti prima di iniziare.
            </p>
            <div class="fv-intent-links" aria-label="Richieste frequenti">
              {intentButtons.map((item) => <a href={item.href}>{item.label}</a>)}
            </div>
          </div>
        </div>
      </div>
      <figure class="fv-hero-media">
        <img src="/assets/original/2022/03/dentista-modena-reggio-emilia.jpg" alt="Visita nello Studio Dentistico Federzoni Granata" loading="eager" />
      </figure>
    </section>

    <section class="fv-intro" aria-labelledby="intro-title">
      <div class="fv-wrap fv-intro-grid">
        <div>
          <p class="fv-kicker">Il punto di partenza</p>
          <h2 id="intro-title">Partiamo da ciò che ti serve</h2>
        </div>
        <div class="fv-intro-copy">
          <p>
            Prima visita non vuol dire “vieni senza motivo”. Vuol dire: ti valutiamo per la prima volta nel nostro studio.
          </p>
          <p>
            Tu porti un problema, un desiderio o un dubbio. Noi lo traduciamo in diagnosi, priorità e piano di cura.
          </p>
        </div>
      </div>
    </section>

    <section id="come-funziona" class="fv-steps-section" aria-labelledby="steps-title">
      <div class="fv-wrap">
        <div class="fv-section-head fv-section-head-right">
          <p class="fv-kicker">Come si svolge</p>
          <h2 id="steps-title">La tua prima visita</h2>
        </div>

        <div class="fv-step-rail">
          {visitSteps.map((step, index) => (
            <article class="fv-step-card">
              <span class="fv-step-number">{index + 1}.</span>
              <div class="fv-step-body">
                <h3>{step.title}</h3>
              </div>
              <details class="fv-step-more">
                <summary class="fv-step-link" aria-label={`Leggi di più: ${step.title}`}>
                  Leggi di più
                  <span aria-hidden="true">+</span>
                </summary>
                <div class="fv-step-more-panel">
                  <p>{step.text}</p>
                </div>
              </details>
            </article>
          ))}
        </div>

        <div class="fv-step-cta">
          <a class="fv-button fv-button-primary" href="/richiesta/">Richiedi informazioni <span aria-hidden="true">↗</span></a>
        </div>
      </div>
    </section>

    <section class="fv-split fv-split-soft" aria-labelledby="diagnosis-title">
      <div class="fv-wrap fv-split-grid">
        <figure class="fv-split-image">
          <img src="/assets/feature-stack/tecnologia-studio.jpg" alt="Tecnologia digitale per la valutazione odontoiatrica" loading="eager" />
        </figure>
        <div class="fv-split-copy">
          <p class="fv-kicker">Diagnosi prima del piano</p>
          <h2 id="diagnosis-title">Prima capiamo il caso, poi costruiamo il percorso</h2>
          <p>
            Una buona visita trasforma un problema confuso in informazioni utili: diagnosi, urgenza, opzioni, esami necessari.
          </p>
          <p>
            Se il percorso richiede più passaggi, lo diciamo. Prima si capisce, poi si decide.
          </p>
          <a class="fv-inline-link" href="/trattamenti/">Scopri i trattamenti <span aria-hidden="true">↗</span></a>
        </div>
      </div>
    </section>

    <section class="fv-evaluation" aria-labelledby="evaluation-title">
      <div class="fv-wrap">
        <div class="fv-section-head fv-section-head-centered">
          <p class="fv-kicker">Cosa valutiamo</p>
          <h2 id="evaluation-title">La visita serve a mettere ordine</h2>
          <p>
            Dal sintomo al piano. Dal dubbio alla scelta. Senza improvvisare.
          </p>
        </div>

        <div class="fv-evaluation-grid">
          {evaluationAreas.map((area) => (
            <article class="fv-evaluation-card">
              <strong>{area.label}</strong>
              <p>{area.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="fv-trust-band" aria-labelledby="trust-title">
      <div class="fv-wrap fv-trust-grid">
        <div>
          <p class="fv-kicker">Un approccio chiaro</p>
          <h2 id="trust-title">Non serve aspettare il dolore</h2>
        </div>
        <div class="fv-trust-copy">
          <p>
            Molti problemi dentali restano silenziosi: carie iniziali, gengive infiammate, vecchie otturazioni, denti instabili.
          </p>
          <p>
            Controllare non significa curare tutto. Significa sapere cosa osservare e cosa affrontare.
          </p>
        </div>
      </div>
    </section>

    <section class="fv-reasons-section" aria-labelledby="reasons-title">
      <div class="fv-wrap">
        <div class="fv-section-head">
          <p class="fv-kicker">Quando prenotarla</p>
          <h2 id="reasons-title">Qual è il tuo motivo?</h2>
        </div>

        <div class="fv-reasons-grid">
          {goodReasons.map((reason) => (
            <article class="fv-reason-card">
              <span class="fv-reason-icon" aria-hidden="true">
                <svg viewBox="0 0 48 48" focusable="false" set:html={reason.icon} />
              </span>
              <div class="fv-reason-copy">
                <h3>{reason.title}</h3>
                <p>{reason.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="fv-split" aria-labelledby="prepare-title">
      <div class="fv-wrap fv-split-grid fv-split-grid-reverse">
        <div class="fv-split-copy">
          <p class="fv-kicker">Prima dell'appuntamento</p>
          <h2 id="prepare-title">Cosa portare alla prima visita</h2>
          <p>
            Se hai documenti recenti, portali. Se non hai nulla, va bene: partiamo dalla visita.
          </p>
          <ul class="fv-prep-list">
            {preparationItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <figure class="fv-split-image">
          <img src="/assets/original/2021/02/HOME.jpg" alt="Dottor Stefano Granata e Dottoressa Chiara Federzoni" loading="eager" />
        </figure>
      </div>
    </section>

    <section class="fv-final" aria-labelledby="final-title">
      <div class="fv-wrap fv-final-inner">
        <div>
          <p class="fv-kicker">Prenota la tua prima visita</p>
          <h2 id="final-title" aria-label="Hai un dubbio? Iniziamo da lì">
            <span>Hai un dubbio?</span>
            <span>Iniziamo da lì</span>
          </h2>
          <p>
            Se hai dolore, un controllo rimandato, gengive che sanguinano,
            denti storti, impianti o estetica da valutare, raccontaci cosa sta succedendo.
            Ti richiamiamo noi, ascoltiamo il motivo della richiesta e troviamo
            l’appuntamento più comodo tra Modena e Reggio Emilia.
          </p>
        </div>
        <div class="fv-final-actions">
          <a class="fv-button fv-button-primary" href="/richiesta/">Prenota visita <span aria-hidden="true">↗</span></a>
          <div class="fv-office-list" aria-label="Sedi dello studio">
            {offices.map((office) => (
              <a href={office.mapHref} target="_blank" rel="noreferrer">
                <strong>{office.city}</strong>
                <span>{office.address}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  const visitStepDetails = Array.from(document.querySelectorAll('.fv-step-more')).filter(
    (step): step is HTMLDetailsElement => step instanceof HTMLDetailsElement,
  );
  const reduceVisitStepMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const getVisitStepPanel = (step: HTMLDetailsElement) => step.querySelector<HTMLElement>('.fv-step-more-panel');
  const onVisitStepHeightEnd = (panel: HTMLElement, callback: () => void) => {
    const handleTransitionEnd = (event: TransitionEvent) => {
      if (event.propertyName !== 'height') return;
      panel.removeEventListener('transitionend', handleTransitionEnd);
      callback();
    };

    panel.addEventListener('transitionend', handleTransitionEnd);
  };

  const openVisitStep = (step: HTMLDetailsElement) => {
    const panel = getVisitStepPanel(step);
    if (!panel) {
      step.open = true;
      return;
    }

    step.open = true;

    if (reduceVisitStepMotion) {
      panel.style.height = 'auto';
      panel.style.opacity = '1';
      panel.style.transform = 'translateY(0)';
      return;
    }

    panel.style.height = '0px';
    panel.style.opacity = '0';
    panel.style.transform = 'translateY(-6px)';

    requestAnimationFrame(() => {
      panel.style.height = `${panel.scrollHeight}px`;
      panel.style.opacity = '1';
      panel.style.transform = 'translateY(0)';
    });

    onVisitStepHeightEnd(panel, () => {
      if (step.open) panel.style.height = 'auto';
    });
  };

  const closeVisitStep = (step: HTMLDetailsElement) => {
    const panel = getVisitStepPanel(step);
    if (!step.open || !panel) {
      step.open = false;
      return;
    }

    if (reduceVisitStepMotion) {
      panel.style.height = '0px';
      panel.style.opacity = '0';
      panel.style.transform = 'translateY(-6px)';
      step.open = false;
      return;
    }

    panel.style.height = `${panel.offsetHeight}px`;
    panel.style.opacity = '1';
    panel.style.transform = 'translateY(0)';

    requestAnimationFrame(() => {
      panel.style.height = '0px';
      panel.style.opacity = '0';
      panel.style.transform = 'translateY(-6px)';
    });

    onVisitStepHeightEnd(panel, () => {
      step.open = false;
    });
  };

  visitStepDetails.forEach((currentStep) => {
    currentStep.querySelector('summary')?.addEventListener('click', (event) => {
      event.preventDefault();

      if (currentStep.open) {
        closeVisitStep(currentStep);
        return;
      }

      visitStepDetails.forEach((step) => {
        if (step !== currentStep) closeVisitStep(step);
      });
      openVisitStep(currentStep);
    });
  });
</script>

<style>
  .first-visit-page {
    --fv-blue: var(--brand-cta);
    --fv-blue-bright: var(--brand-blue);
    --fv-blue-soft: var(--soft-blue-bg);
    --fv-ink: var(--brand-primary-dark);
    --fv-muted: var(--muted-text);
    --fv-line: rgba(var(--brand-blue-rgb), 0.2);
    background: var(--surface-white);
    color: var(--fv-ink);
    font-family: "Inter", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    letter-spacing: 0;
  }

  .first-visit-page :global(a) {
    color: inherit;
  }

  .fv-wrap {
    width: min(1510px, calc(100% - 30px));
    margin: 0 auto;
  }

  .fv-hero {
    background: var(--surface-white);
    color: var(--surface-white);
  }

  .fv-hero-panel {
    min-height: calc(78svh - var(--nav-height));
    display: grid;
    background: var(--blue-dark);
  }

  .fv-hero-inner {
    min-height: inherit;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 96px 0;
  }

  .fv-breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.84rem;
    font-weight: 800;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .fv-breadcrumb a {
    text-decoration: none;
  }

  .fv-breadcrumb a:hover {
    color: var(--surface-white);
  }

  .fv-hero-copy {
    width: min(100%, 1360px);
    margin: 0 auto;
    text-align: center;
  }

  .fv-kicker {
    margin: 0 0 14px;
    color: var(--fv-blue-bright);
    font-size: 0.88rem;
    font-weight: 900;
    letter-spacing: 0;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .fv-hero .fv-kicker,
  .fv-final .fv-kicker {
    color: var(--aqua);
  }

  .fv-hero h1 {
    max-width: none;
    margin: 0;
    color: var(--surface-white);
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(4.8rem, 10.6vw, 10.75rem);
    font-weight: 400;
    letter-spacing: 0;
    line-height: 0.88;
    text-transform: uppercase;
  }

  .fv-hero-copy > p:not(.fv-kicker) {
    max-width: 880px;
    margin: 34px auto 0;
    color: var(--aqua);
    font-size: clamp(1.2rem, 1.75vw, 1.65rem);
    font-weight: 700;
    line-height: 1.25;
  }

  .fv-hero-media {
    height: clamp(360px, 42vw, 620px);
    margin: 0;
    overflow: hidden;
    background: var(--border);
  }

  .fv-hero-media img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center 42%;
  }

  .fv-actions,
  .fv-final-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
  }

  .fv-actions {
    margin-top: 34px;
  }

  .fv-intent-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    max-width: 760px;
    margin: 22px auto 0;
  }

  .fv-intent-links a {
    min-height: 38px;
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(var(--brand-blue-rgb), 0.42);
    border-radius: 999px;
    padding: 0 14px;
    background: rgba(var(--brand-blue-rgb), 0.12);
    color: var(--soft-blue-bg);
    font-size: 0.84rem;
    font-weight: 800;
    line-height: 1.2;
    text-decoration: none;
  }

  .fv-intent-links a:hover {
    border-color: rgba(var(--brand-blue-rgb), 0.74);
    background: rgba(var(--brand-blue-rgb), 0.2);
    color: var(--surface-white);
