---
import BaseLayout from '../components/BaseLayout.astro';
import ContentPage from '../components/ContentPage.astro';
import { site } from '../data/site';

const page = site.pages.find((item) => item.path === '/');
if (!page) throw new Error('Homepage data not found');
---

<BaseLayout title={page.title} description={page.description} ogImage={page.ogImage || site.heroImage} canonicalPath="/">
  <ContentPage page={page} />
</BaseLayout>
