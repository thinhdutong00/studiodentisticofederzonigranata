---
import BaseLayout from '../components/BaseLayout.astro';
import { site } from '../data/site';

const title = `Richiesta ricevuta - ${site.name}`;
const description =
  'La tua richiesta e stata ricevuta dallo Studio Dentistico Federzoni Granata. La segreteria ti ricontattera per confermare la disponibilita.';
---

<BaseLayout title={title} description={description} ogImage={site.heroImage} canonicalPath="/thank-you-page/">
  <section class="thank-you-page" aria-labelledby="thank-you-title">
    <div class="thank-you-shell">
      <p class="thank-you-kicker">Richiesta inviata</p>
      <h1 id="thank-you-title">Grazie, abbiamo ricevuto la tua richiesta.</h1>
      <p>
        La segreteria dello Studio Dentistico Federzoni Granata ti ricontattera per verificare i dettagli e confermare data e orario della visita.
      </p>

      <div class="thank-you-actions">
        <a class="thank-you-btn thank-you-btn-primary" href="/">Torna alla home <span aria-hidden="true">↗</span></a>
        <a class="thank-you-btn thank-you-btn-outline" href="/#trattamenti">I nostri trattamenti <span aria-hidden="true">↗</span></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  :global(body) {
    background: var(--background);
  }

  .thank-you-page {
    display: grid;
    min-height: calc(100vh - var(--nav-height));
    place-items: center;
    padding: 80px 0;
    background: var(--background);
  }

  .thank-you-shell {
    width: min(900px, calc(100% - 32px));
    border: 1px solid rgba(var(--brand-cta-rgb), 0.1);
    border-radius: 22px;
    padding: clamp(28px, 6vw, 64px);
    background: var(--surface-white);
    box-shadow: 0 26px 70px rgba(15, 31, 99, 0.12);
    text-align: center;
  }

  .thank-you-kicker {
    margin: 0 0 12px;
    color: var(--brand-cta);
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .thank-you-shell h1 {
    max-width: 760px;
    margin: 0 auto 18px;
    color: var(--brand-primary-dark);
    font-size: clamp(2.35rem, 6vw, 4.5rem);
  }

  .thank-you-shell p {
    max-width: 650px;
    margin: 0 auto;
    color: var(--muted-text);
    font-size: 1.12rem;
    font-weight: 700;
    line-height: 1.6;
  }

  .thank-you-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-top: 34px;
  }

  .thank-you-btn {
    display: inline-flex;
    width: min(100%, 304px);
    min-height: 68px;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    border: 1px solid rgba(var(--brand-primary-dark-rgb), 0.52);
    border-radius: 12px;
    padding: 0 24px;
    color: var(--brand-primary-dark);
    font-size: 1.03rem;
    font-weight: 700;
    line-height: 1.2;
    text-align: center;
    text-decoration: none;
    transition: background 160ms ease, border-color 160ms ease, color 160ms ease, transform 160ms ease, box-shadow 160ms ease;
  }

  .thank-you-btn:hover {
    transform: translateY(-1px);
  }

  .thank-you-btn-primary {
    background: transparent;
    color: var(--brand-primary-dark);
    box-shadow: none;
  }

  .thank-you-btn-primary:hover {
    background: rgba(var(--brand-primary-dark-rgb), 0.06);
    color: var(--brand-primary-dark);
  }

  .thank-you-btn-outline {
    border-color: rgba(var(--brand-primary-dark-rgb), 0.52);
    background: transparent;
    color: var(--brand-primary-dark);
  }

  .thank-you-btn-outline:hover {
    border-color: var(--brand-primary-dark);
    background: rgba(var(--brand-primary-dark-rgb), 0.06);
    color: var(--brand-primary-dark);
  }

  .thank-you-btn span {
    font-size: 1.45rem;
    line-height: 1;
  }

  @media (max-width: 560px) {
    .thank-you-page {
      padding: 48px 0;
    }

    .thank-you-actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .thank-you-btn {
      width: 100%;
    }
  }
</style>
