---
import BaseLayout from '../components/BaseLayout.astro';
import { patientReviews } from '../data/reviews';
import { site } from '../data/site';

const starsFor = (rating: number) => `${'★'.repeat(rating)}${'☆'.repeat(5 - rating)}`;
---

<BaseLayout
  title={`Recensioni pazienti | ${site.name}`}
  description="Le opinioni dei pazienti dello Studio Dentistico Federzoni Granata."
  canonicalPath="/recensioni/"
>
  <section class="reviews-page" aria-labelledby="reviews-title">
    <div class="reviews-wrap">
      <p class="reviews-eyebrow">Recensioni dei pazienti</p>
      <div class="reviews-head">
        <h1 id="reviews-title">I Nostri Pazienti Dicono</h1>
        <a href="/richiesta/">Prenota visita</a>
      </div>

      <div class="reviews-grid">
        {patientReviews.map((review) => (
          <article class="review-card">
            <header class="review-card-head">
              {review.avatar ? (
                <img class="review-avatar" src={review.avatar} alt={`Foto profilo di ${review.author}`} loading="lazy" />
              ) : (
                <span class="review-avatar" aria-hidden="true">{review.initials}</span>
              )}
              <div class="review-person">
                <h2>{review.author}</h2>
                <p>Recensione Google • {review.relativeTime}</p>
              </div>
            </header>
            <span class="review-stars" aria-label={`${review.rating} stelle su 5`}>{starsFor(review.rating)}</span>
            {review.text ? (
              <p class="review-text">{review.text}</p>
            ) : (
              <p class="review-text review-text-muted">Valutazione senza testo.</p>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .reviews-page {
    padding: 112px 0;
    background: #fff;
  }

  .reviews-wrap {
    width: min(100% - 48px, 1510px);
    margin: 0 auto;
  }

  .reviews-eyebrow {
    margin: 0 0 18px;
    color: #347cc2;
    font-family: Montserrat, "Century Gothic", CenturyGothic, AppleGothic, sans-serif;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .reviews-head {
    display: flex;
    justify-content: space-between;
    gap: 32px;
    align-items: center;
    margin-bottom: 54px;
  }

  .reviews-head h1 {
    max-width: 980px;
    margin: 0;
    color: var(--blue-dark);
    font-size: clamp(3.4rem, 6.6vw, 6rem);
    font-weight: 700;
    line-height: 0.98;
  }

  .reviews-head a {
    display: inline-flex;
    min-height: 58px;
    align-items: center;
    justify-content: center;
    padding: 0 28px;
    background: #347cc2;
    color: #fff;
    font-weight: 900;
    text-decoration: none;
    text-transform: uppercase;
    transition: background-color 160ms ease, color 160ms ease;
  }

  .reviews-head a:hover {
    background: var(--blue-dark);
    color: #fff;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    background: rgba(52, 124, 194, 0.22);
  }

  .review-card {
    min-height: 260px;
    display: flex;
    flex-direction: column;
    gap: 22px;
    padding: 30px;
    background: #edf7ff;
    transition: background-color 160ms ease, color 160ms ease;
  }

  .review-card:hover {
    background: var(--blue-dark);
  }

  .review-card-head {
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr);
    gap: 16px;
    align-items: center;
  }

  .review-avatar {
    width: 56px;
    height: 56px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: #d9f0ff;
    color: var(--blue-dark);
    font-size: 1rem;
    font-weight: 900;
    line-height: 1;
    object-fit: cover;
    text-transform: uppercase;
  }

  .review-person {
    min-width: 0;
    display: grid;
    gap: 4px;
  }

  .review-person h2 {
    margin: 0;
    color: var(--blue-dark);
    font-size: 1.18rem;
    font-weight: 800;
    line-height: 1.15;
  }

  .review-person p {
    margin: 0;
    color: #347cc2;
    font-size: 0.86rem;
    font-weight: 800;
    line-height: 1.3;
  }

  .review-stars {
    color: #347cc2;
    font-size: 1.15rem;
    letter-spacing: 0.08em;
    line-height: 1;
  }

  .review-text {
    margin: 0;
    color: #3f4e4d;
    font-family: Inter, ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(1.08rem, 1.25vw, 1.34rem);
    font-weight: 500;
    line-height: 1.35;
  }

  .review-text-muted {
    color: rgba(63, 78, 77, 0.68);
    font-style: italic;
  }

  .review-card:hover .review-avatar {
    background: rgba(255, 255, 255, 0.18);
    color: #fff;
  }

  .review-card:hover .review-person h2,
  .review-card:hover .review-person p,
  .review-card:hover .review-stars,
  .review-card:hover .review-text {
    color: #fff;
  }

  @media (max-width: 980px) {
    .reviews-head {
      display: block;
    }

    .reviews-head h1 {
      margin-bottom: 28px;
      font-size: clamp(3rem, 13vw, 4.5rem);
    }

    .reviews-grid {
      grid-template-columns: 1fr;
    }

    .review-card {
      min-height: 230px;
      padding: 24px;
    }
  }
</style>
