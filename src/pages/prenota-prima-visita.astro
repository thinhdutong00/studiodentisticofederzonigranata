---
import BaseLayout from '../components/BaseLayout.astro';
import { site } from '../data/site';

const title = `Prenota prima visita - ${site.name}`;
const description =
  'Modulo multi-step dedicato alla prima visita odontoiatrica dello Studio Dentistico Federzoni Granata.';

const visitReasons = [
  'Dolore o urgenza',
  'Impianti',
  'Controllo generale',
  'Secondo parere',
  'Estetica del sorriso',
  'Gengive o sanguinamento',
  'Ortodonzia e allineatori',
  'Prima visita per bambino',
];

const visitGoals = [
  'Capire da dove nasce il problema',
  'Ricevere una diagnosi completa',
  'Mostrare radiografie o preventivi',
  'Valutare tempi e costi',
  'Riprendere un controllo rimandato',
  'Essere richiamato dalla segreteria',
];

const offices = site.offices.map((office) => office.city);
const availabilityOptions = [
  'Prima disponibilità',
  'Mattina',
  'Pomeriggio',
  'Entro una settimana',
  'Da concordare',
];

const firstVisitConfigJson = JSON.stringify({
  visitReasons,
  visitGoals,
  offices,
  availabilityOptions,
}).replace(/</g, '\\u003c');
---

<BaseLayout
  title={title}
  description={description}
  ogImage={site.heroImage}
  canonicalPath="/prenota-prima-visita/"
  headerCtaHref="/prenota-prima-visita/"
>
  <section class="first-visit-request-page" aria-labelledby="first-visit-request-title">
    <div class="first-visit-request-shell">
      <header class="first-visit-request-head">
        <p>Prima visita</p>
        <h1 id="first-visit-request-title">Raccontaci da dove vuoi iniziare</h1>
        <span>
          Il modulo raccoglie le informazioni essenziali prima del contatto dello studio:
          motivo, obiettivo, sede preferita e disponibilità.
        </span>
      </header>

      <form class="first-visit-request-form" data-first-visit-form novalidate>
        <script id="first-visit-config" type="application/json" set:html={firstVisitConfigJson}></script>
        <input type="hidden" name="visitReason" data-field="visitReason" />
        <input type="hidden" name="visitGoal" data-field="visitGoal" />
        <input type="hidden" name="office" data-field="office" />
        <input type="hidden" name="availability" data-field="availability" />

        <div class="first-visit-progress" aria-hidden="true">
          <span data-progress-bar></span>
        </div>

        <p class="first-visit-step-count" data-step-count>Step 1 di 4</p>

        <fieldset class="first-visit-step is-active" data-step="0">
          <legend>
            <span class="first-visit-kicker">Motivo della visita</span>
            <strong>Per cosa vuoi prenotare?</strong>
          </legend>

          <div class="first-visit-options">
            {visitReasons.map((option) => (
              <button class="first-visit-choice" type="button" data-choice="visitReason" data-value={option}>
                {option}
              </button>
            ))}
          </div>
        </fieldset>

        <fieldset class="first-visit-step" data-step="1" hidden>
          <legend>
            <span class="first-visit-kicker">Obiettivo</span>
            <strong>Che cosa ti aspetti dal primo incontro?</strong>
          </legend>

          <div class="first-visit-options">
            {visitGoals.map((option) => (
              <button class="first-visit-choice" type="button" data-choice="visitGoal" data-value={option}>
                {option}
              </button>
            ))}
          </div>

          <label class="first-visit-notes">
            <span>Vuoi aggiungere qualcosa? <em>facoltativo</em></span>
            <textarea name="notes" rows="4" placeholder="Sintomi, dubbi, esami già fatti o preferenze particolari"></textarea>
          </label>
        </fieldset>

        <fieldset class="first-visit-step" data-step="2" hidden>
          <legend>
            <span class="first-visit-kicker">Sede e disponibilità</span>
            <strong>Dove e quando preferisci venire?</strong>
          </legend>

          <div class="first-visit-split">
            <div>
              <h2>Sede preferita</h2>
              <div class="first-visit-options first-visit-options-compact">
                {offices.map((office) => (
                  <button class="first-visit-choice" type="button" data-choice="office" data-value={office}>
                    {office}
                  </button>
                ))}
              </div>
            </div>

            <div>
              <h2>Disponibilità</h2>
              <div class="first-visit-options first-visit-options-compact">
                {availabilityOptions.map((option) => (
                  <button class="first-visit-choice" type="button" data-choice="availability" data-value={option}>
                    {option}
                  </button>
                ))}
              </div>
            </div>
          </div>
        </fieldset>

        <fieldset class="first-visit-step" data-step="3" hidden>
          <legend>
            <span class="first-visit-kicker">Contatti</span>
            <strong>Lasciaci i dati per ricontattarti</strong>
          </legend>

          <div class="first-visit-field-grid">
            <label>
              <span>Nome e cognome</span>
              <input type="text" name="fullName" autocomplete="name" required />
            </label>
            <label>
              <span>Telefono</span>
              <input type="tel" name="phone" autocomplete="tel" required />
            </label>
            <label class="first-visit-field-wide">
              <span>Email</span>
              <input type="email" name="email" autocomplete="email" required />
            </label>
            <label class="first-visit-field-wide">
              <span>Messaggio <em>facoltativo</em></span>
              <textarea name="message" rows="4"></textarea>
            </label>
          </div>

          <p class="first-visit-privacy">
            Inviando il modulo autorizzi lo studio a ricontattarti per organizzare la prima visita.
          </p>
        </fieldset>

        <p class="first-visit-error" data-first-visit-error role="alert" aria-live="polite"></p>

        <div class="first-visit-actions">
          <button class="first-visit-btn first-visit-btn-outline" type="button" data-prev-step hidden>Indietro</button>
          <button class="first-visit-btn first-visit-btn-primary" type="button" data-next-step>Continua <span aria-hidden="true">↗</span></button>
          <button class="first-visit-btn first-visit-btn-primary" type="submit" data-submit-first-visit hidden>Invia richiesta <span aria-hidden="true">↗</span></button>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>

<style is:global>
  body {
    background: var(--surface-white);
  }

  .first-visit-request-page {
    min-height: calc(100vh - var(--nav-height));
    padding: clamp(34px, 6vw, 78px) 0 86px;
    background:
      linear-gradient(180deg, rgba(238, 246, 251, 0.78) 0%, rgba(255, 255, 255, 0) 48%),
      var(--surface-white);
    color: var(--text-dark);
  }

  .first-visit-request-shell {
    width: min(1180px, calc(100% - 48px));
    margin: 0 auto;
  }

  .first-visit-request-head {
    display: grid;
    gap: 16px;
    max-width: 900px;
    margin-bottom: clamp(28px, 5vw, 52px);
  }

  .first-visit-request-head p,
  .first-visit-kicker {
    margin: 0;
    color: var(--brand-blue);
    font-size: 15px;
    font-weight: 800;
    letter-spacing: normal;
    text-transform: uppercase;
  }

  .first-visit-request-head h1 {
    max-width: 820px;
    margin: 0;
    color: var(--brand-primary-dark);
    font-size: clamp(56px, 8vw, 118px);
    font-weight: 500;
    letter-spacing: -0.2px;
    line-height: 0.92;
    text-transform: uppercase;
  }

  .first-visit-request-head span {
    max-width: 660px;
    color: var(--muted-text);
    font-size: clamp(18px, 2vw, 24px);
    font-weight: 500;
    line-height: 1.28;
  }

  .first-visit-request-form {
    position: relative;
    overflow: hidden;
    min-height: 560px;
    padding: clamp(26px, 4vw, 48px);
    border: 1px solid var(--border);
    border-radius: 24px;
    background: var(--surface-white);
    box-shadow: 0 28px 80px rgba(var(--brand-cta-rgb), 0.12);
  }

  .first-visit-progress {
    height: 8px;
    overflow: hidden;
    border-radius: 999px;
    background: var(--border);
  }

  .first-visit-progress span {
    display: block;
    width: 25%;
    height: 100%;
    border-radius: inherit;
    background: var(--brand-primary-dark);
    transition: width 220ms ease;
  }

  .first-visit-step-count {
    margin: 20px 0 30px;
    color: var(--muted-text);
    font-weight: 800;
  }

  .first-visit-step {
    min-width: 0;
    margin: 0;
    padding: 0;
    border: 0;
  }

  .first-visit-step[hidden] {
    display: none;
  }

  .first-visit-step legend {
    display: grid;
    gap: 12px;
    max-width: 850px;
    margin-bottom: 28px;
    padding: 0;
  }

  .first-visit-step legend strong {
    color: var(--brand-primary-dark);
    font-size: clamp(32px, 5vw, 66px);
    font-weight: 500;
    letter-spacing: -0.2px;
    line-height: 0.98;
  }

  .first-visit-options {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .first-visit-options-compact {
    grid-template-columns: 1fr;
  }

  .first-visit-choice {
    min-height: 84px;
    padding: 20px 22px;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: var(--soft-blue-bg);
    color: var(--brand-primary-dark);
    font: inherit;
    font-size: clamp(18px, 2vw, 24px);
    font-weight: 700;
    line-height: 1.14;
    text-align: left;
    cursor: pointer;
    transition:
      border-color 180ms ease,
      background 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .first-visit-choice:hover,
  .first-visit-choice.is-selected {
    border-color: var(--brand-primary-dark);
    background: var(--brand-primary-dark);
    color: var(--surface-white);
    transform: translateY(-2px);
  }

  .first-visit-split {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(20px, 4vw, 44px);
  }

  .first-visit-split h2 {
    margin: 0 0 14px;
    color: var(--brand-blue);
    font-size: 18px;
    font-weight: 800;
    letter-spacing: normal;
    text-transform: uppercase;
  }

  .first-visit-notes,
  .first-visit-field-grid label {
    display: grid;
    gap: 10px;
    color: var(--brand-primary-dark);
    font-weight: 800;
  }

  .first-visit-notes {
    margin-top: 22px;
  }

  .first-visit-notes span,
  .first-visit-field-grid span {
    font-size: 14px;
    letter-spacing: normal;
    text-transform: uppercase;
  }

  .first-visit-notes em,
  .first-visit-field-grid em {
    color: var(--muted-text);
    font-style: normal;
    font-weight: 600;
    text-transform: none;
  }

  .first-visit-notes textarea,
  .first-visit-field-grid input,
  .first-visit-field-grid textarea {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--surface-white);
    color: var(--text-dark);
    font: inherit;
    font-size: 17px;
    line-height: 1.4;
  }

  .first-visit-notes textarea,
  .first-visit-field-grid textarea {
    resize: vertical;
    min-height: 118px;
    padding: 16px;
  }

  .first-visit-field-grid input {
    min-height: 58px;
    padding: 0 16px;
  }

  .first-visit-field-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .first-visit-field-wide {
    grid-column: 1 / -1;
  }

  .first-visit-privacy {
    max-width: 620px;
    margin: 18px 0 0;
    color: var(--muted-text);
    font-weight: 500;
    line-height: 1.4;
  }

  .first-visit-error {
    min-height: 24px;
    margin: 24px 0 0;
    color: var(--error);
    font-weight: 800;
  }

  .first-visit-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: flex-end;
    margin-top: 16px;
  }

  .first-visit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 54px;
    padding: 0 24px;
    border-radius: 999px;
    font: inherit;
    font-size: 16px;
    font-weight: 800;
    line-height: 1;
    cursor: pointer;
    transition:
      background 180ms ease,
      border-color 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .first-visit-btn:hover {
    transform: translateY(-2px);
  }

  .first-visit-btn-primary {
    border: 1px solid var(--brand-cta);
    background: var(--brand-cta);
    color: var(--surface-white);
  }

  .first-visit-btn-primary:hover {
    border-color: var(--brand-cta-hover);
    background: var(--brand-cta-hover);
  }

  .first-visit-btn-outline {
    border: 1px solid var(--border);
    background: var(--surface-white);
    color: var(--brand-primary-dark);
  }

  .first-visit-btn:disabled {
    cursor: wait;
    opacity: 0.7;
    transform: none;
  }

  @media (max-width: 760px) {
    .first-visit-request-shell {
      width: min(100% - 28px, 1180px);
    }

    .first-visit-request-form {
      min-height: auto;
      padding: 22px;
      border-radius: 18px;
    }

    .first-visit-options,
    .first-visit-split,
    .first-visit-field-grid {
      grid-template-columns: 1fr;
    }

    .first-visit-choice {
      min-height: 72px;
    }

    .first-visit-actions {
      justify-content: stretch;
    }

    .first-visit-btn {
      flex: 1 1 100%;
    }
  }

  .first-visit-request-page {
    padding: clamp(50px, 7vw, 96px) 0 96px;
    background: var(--background);
  }

  .first-visit-request-shell {
    width: min(890px, calc(100% - 32px));
  }

  .first-visit-request-head {
    margin: 0 0 18px;
  }

  .first-visit-request-head p,
  .first-visit-request-head span {
    display: none;
  }

  .first-visit-request-head h1 {
    max-width: 900px;
    color: var(--text-dark);
    font-size: clamp(2.25rem, 6vw, 4.5rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 0.96;
    text-transform: none;
  }

  .first-visit-request-form {
    min-height: auto;
    overflow: visible;
    border-radius: 20px;
    padding: clamp(28px, 4vw, 40px);
    box-shadow: 0 28px 70px rgba(var(--brand-primary-dark-rgb), 0.1);
  }

  .first-visit-progress {
    height: 8px;
    margin-bottom: 20px;
    background: rgba(var(--brand-blue-rgb), 0.18);
  }

  .first-visit-progress span {
    background: var(--brand-cta);
  }

  .first-visit-step-count {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .first-visit-kicker {
    display: block;
    margin-bottom: 12px;
    color: var(--brand-cta);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.18em;
  }

  .first-visit-step legend {
    display: block;
    margin-bottom: 22px;
  }

  .first-visit-step legend strong {
    display: block;
    color: var(--text-dark);
    font-size: clamp(1.65rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.08;
  }

  .first-visit-options,
  .first-visit-options-compact {
    grid-template-columns: 1fr;
    gap: 12px;
  }

  .first-visit-choice {
    position: relative;
    min-height: 74px;
    border-color: rgba(var(--brand-primary-dark-rgb), 0.14);
    border-radius: 14px;
    padding: 20px 76px 20px 20px;
    background: var(--surface-white);
    color: var(--text-dark);
    font-size: 1rem;
    font-weight: 800;
    box-shadow: none;
  }

  .first-visit-choice::after {
    content: "";
    position: absolute;
    top: 50%;
    right: 20px;
    width: 34px;
    height: 34px;
    border: 4px solid rgba(var(--brand-primary-dark-rgb), 0.24);
    border-radius: 999px;
    transform: translateY(-50%);
    transition: border-color 160ms ease, box-shadow 160ms ease, background 160ms ease;
  }

  .first-visit-choice:hover {
    border-color: rgba(var(--brand-cta-rgb), 0.38);
    background: var(--surface-white);
    color: var(--text-dark);
    box-shadow: 0 14px 28px rgba(var(--brand-primary-dark-rgb), 0.08);
    transform: translateY(-1px);
  }

  .first-visit-choice.is-selected {
    border-color: var(--brand-cta);
    background: var(--brand-cta);
    color: var(--surface-white);
    box-shadow: 0 18px 34px rgba(var(--brand-cta-rgb), 0.22);
  }

  .first-visit-choice.is-selected::after {
    border-color: var(--surface-white);
    background: var(--surface-white);
    box-shadow: inset 0 0 0 8px var(--brand-cta);
  }

  .first-visit-btn {
    border-radius: 14px;
    font-weight: 800;
  }

  .first-visit-btn[hidden] {
    display: none !important;
  }

  .first-visit-btn-primary {
    background: var(--brand-cta);
    box-shadow: 0 18px 34px rgba(var(--brand-cta-rgb), 0.22);
  }

  .first-visit-btn-primary:hover {
    background: var(--brand-cta-hover);
  }

  @media (max-width: 620px) {
    .first-visit-request-page {
      padding: 34px 0 70px;
    }

    .first-visit-request-shell {
      width: min(100% - 32px, 890px);
    }

    .first-visit-request-head h1 {
      font-size: clamp(2rem, 11vw, 3.35rem);
    }

    .first-visit-request-form {
      padding: 24px;
      border-radius: 18px;
    }

    .first-visit-choice {
      min-height: 68px;
      padding: 18px 66px 18px 16px;
    }

    .first-visit-choice::after {
      right: 16px;
      width: 34px;
      height: 34px;
    }
  }
</style>

<script>
  const firstVisitForm = document.querySelector('[data-first-visit-form]');

  if (firstVisitForm instanceof HTMLFormElement) {
    const steps = Array.from(firstVisitForm.querySelectorAll('[data-step]'));
    const progressBar = firstVisitForm.querySelector('[data-progress-bar]');
    const stepCount = firstVisitForm.querySelector('[data-step-count]');
    const prevButton = firstVisitForm.querySelector('[data-prev-step]');
    const nextButton = firstVisitForm.querySelector('[data-next-step]');
    const submitButton = firstVisitForm.querySelector('[data-submit-first-visit]');
    const errorBox = firstVisitForm.querySelector('[data-first-visit-error]');
    const hiddenFields = Array.from(firstVisitForm.querySelectorAll('[data-field]'));
    const state = {
      visitReason: '',
      visitGoal: '',
      office: '',
      availability: '',
    };

    const normalizeValue = (value) =>
      String(value || '')
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .toLowerCase()
        .trim();

    const setError = (message) => {
      if (errorBox) {
        errorBox.textContent = message;
      }
    };

    const currentStep = () => Number(firstVisitForm.dataset.currentStep || 0);

    const syncHiddenFields = () => {
      hiddenFields.forEach((field) => {
        if (!(field instanceof HTMLInputElement)) return;
        const key = field.dataset.field;
        if (key && Object.prototype.hasOwnProperty.call(state, key)) {
          field.value = state[key];
        }
      });
    };

    const setCurrentStep = (stepIndex) => {
      const nextIndex = Math.max(0, Math.min(stepIndex, steps.length - 1));
      firstVisitForm.dataset.currentStep = String(nextIndex);
      steps.forEach((step, index) => {
        const active = index === nextIndex;
        step.toggleAttribute('hidden', !active);
        step.classList.toggle('is-active', active);
      });

      if (progressBar instanceof HTMLElement) {
        progressBar.style.width = `${((nextIndex + 1) / steps.length) * 100}%`;
      }

      if (stepCount) {
        stepCount.textContent = `Step ${nextIndex + 1} di ${steps.length}`;
      }

      if (prevButton instanceof HTMLButtonElement) {
        prevButton.hidden = nextIndex === 0;
      }

      if (nextButton instanceof HTMLButtonElement) {
        nextButton.hidden = nextIndex === steps.length - 1;
      }

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.hidden = nextIndex !== steps.length - 1;
      }

      setError('');
    };

    const selectChoice = (button) => {
      const key = button.dataset.choice;
      const value = button.dataset.value || '';
      if (!key || !Object.prototype.hasOwnProperty.call(state, key)) return;

      state[key] = value;
      Array.from(firstVisitForm.querySelectorAll(`[data-choice="${key}"]`)).forEach((choice) => {
        const selected = choice === button;
        choice.classList.toggle('is-selected', selected);
        if (choice instanceof HTMLButtonElement) {
          choice.setAttribute('aria-pressed', String(selected));
        }
      });

      syncHiddenFields();
      setError('');
    };

    const canContinue = () => {
      switch (currentStep()) {
        case 0:
          return Boolean(state.visitReason);
        case 1:
          return Boolean(state.visitGoal);
        case 2:
          return Boolean(state.office && state.availability);
        default:
          return true;
      }
    };

    const validationMessage = () => {
      switch (currentStep()) {
        case 0:
          return 'Scegli il motivo principale della prima visita.';
        case 1:
          return 'Scegli che cosa ti aspetti dal primo incontro.';
        case 2:
          return 'Seleziona una sede e una disponibilità indicativa.';
        default:
          return 'Completa i campi richiesti.';
      }
    };

    firstVisitForm.addEventListener('click', (event) => {
      const target = event.target instanceof Element ? event.target.closest('[data-choice]') : null;
      if (target instanceof HTMLButtonElement) {
        selectChoice(target);
      }
    });

    if (nextButton instanceof HTMLButtonElement) {
      nextButton.addEventListener('click', () => {
        if (!canContinue()) {
          setError(validationMessage());
          return;
        }
        setCurrentStep(currentStep() + 1);
      });
    }

    if (prevButton instanceof HTMLButtonElement) {
      prevButton.addEventListener('click', () => setCurrentStep(currentStep() - 1));
    }

    const requestedReason = new URLSearchParams(window.location.search).get('motivo');
    if (requestedReason) {
      const reasonButton = Array.from(firstVisitForm.querySelectorAll('[data-choice="visitReason"]')).find(
        (button) => normalizeValue(button.dataset.value) === normalizeValue(requestedReason),
      );
      if (reasonButton instanceof HTMLButtonElement) {
        selectChoice(reasonButton);
      }
    }

    firstVisitForm.addEventListener('submit', (event) => {
      event.preventDefault();
      const requiredFields = Array.from(firstVisitForm.querySelectorAll('input[required]'));
      const missingRequired = requiredFields.some(
        (field) => field instanceof HTMLInputElement && !field.value.trim(),
      );
      const emailField = firstVisitForm.elements.namedItem('email');

      if (missingRequired || (emailField instanceof HTMLInputElement && !emailField.checkValidity())) {
        setError('Compila nome, telefono ed email per inviare la richiesta.');
        return;
      }

      syncHiddenFields();
      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
        submitButton.textContent = 'Richiesta inviata';
      }

      window.setTimeout(() => {
        window.location.href = '/thank-you-page/';
      }, 450);
    });

    setCurrentStep(0);
    syncHiddenFields();
  }
</script>
