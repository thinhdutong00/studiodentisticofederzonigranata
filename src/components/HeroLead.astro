---
interface Props {
  kicker?: string;
  title: string;
  description?: string;
  image?: string;
  compact?: boolean;
}

const {
  kicker = 'Studio dentistico Federzoni Granata',
  title,
  description,
  image,
  compact = false,
} = Astro.props;
---

<section class:list={['hero-lead', compact && 'hero-lead-compact']} style={image ? `--hero-image: url('${image}')` : undefined}>
  <div class="container hero-lead-inner">
    <div class="hero-copy">
      <p class="eyebrow">{kicker}</p>
      <h1>{title}</h1>
      {description && <p class="hero-description">{description}</p>}
      <div class="hero-actions" aria-label="Azioni principali">
        <a class="button button-on-dark" href="/richiesta/">Prenota una visita <span aria-hidden="true">↗</span></a>
        <a class="button button-outline button-on-dark" href="#trattamenti">I nostri trattamenti <span aria-hidden="true">↗</span></a>
      </div>
    </div>
  </div>
</section>
