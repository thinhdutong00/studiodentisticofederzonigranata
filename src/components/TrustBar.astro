---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
const items = [
  { value: '30+', label: 'anni di esperienza multidisciplinare' },
  { value: '2', label: 'studi a Modena e Reggio Emilia' },
  { value: '24/7', label: 'richiesta informazioni dal sito' },
  { value: 'Digitale', label: 'tecnologie e implantologia guidata' },
];
---

<div class:list={['trust-bar', compact && 'trust-bar-compact']} aria-label="Punti di forza dello studio">
  {items.map((item) => (
    <div class="trust-item">
      <strong>{item.value}</strong>
      <span>{item.label}</span>
    </div>
  ))}
</div>
