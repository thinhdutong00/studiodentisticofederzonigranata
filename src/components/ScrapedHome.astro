---
import { site } from '../data/site';
import { featuredPatientReviews } from '../data/reviews';
import { formatParentheticalDetail } from '../utils/formatParentheticalDetail';

const heroImage = '/assets/original/2022/03/dentista-modena-reggio-emilia.jpg';
const starsFor = (rating: number) => `${'★'.repeat(rating)}${'☆'.repeat(5 - rating)}`;

const treatmentOrder = [
  'Igiene orale e Prevenzione',
  'Sbiancamento',
  'Conservativa (otturazioni)',
  'Endodonzia (devitalizzazioni)',
  'Pedodonzia (odontoiatria infantile)',
  'Ortodonzia e Allineatori invisibili (adulti e bimbi)',
  'Estetica diretta (faccette in composito)',
  'Parodontologia (cure gengivali)',
  'Protesi fissa e mobile',
  'Estetica Indiretta (faccette in porcellana)',
  'Chirurgia Stomatologica',
  'Implantologia tradizionale e computer guidata',
  'Gnatologia (disturbi articolazione temporo-mandibolare)',
  'Dispositivi contro il russamento e le apnee notturne',
];

const treatmentMenuLabels: Record<string, string> = {
  'Estetica diretta (faccette in composito)': 'Faccette in composito',
  'Estetica Indiretta (faccette in porcellana)': 'Faccette in ceramica',
};

const treatmentDescriptions: Record<string, string> = {
  'Igiene orale e Prevenzione': 'Controlli periodici, sedute di igiene e indicazioni personalizzate per mantenere denti e gengive in salute.',
  Sbiancamento: 'Trattamenti professionali per migliorare il colore del sorriso in modo controllato e rispettoso dei tessuti dentali.',
  'Conservativa (otturazioni)': 'Otturazioni, restauri e ricostruzioni per recuperare i denti danneggiati preservando la struttura naturale.',
  'Endodonzia (devitalizzazioni)': 'Cure canalari e devitalizzazioni per trattare infezioni profonde e salvare il dente quando possibile.',
  'Pedodonzia (odontoiatria infantile)': 'Percorsi dedicati ai bambini, dalla prevenzione alle prime cure, con attenzione a serenità e fiducia.',
  'Ortodonzia e Allineatori invisibili (adulti e bimbi)': 'Soluzioni ortodontiche per adulti e bambini, anche con allineatori trasparenti e piani su misura.',
  'Estetica diretta (faccette in composito)': 'Faccette e restauri diretti in composito per armonizzare forma, proporzioni e naturalezza del sorriso.',
  'Parodontologia (cure gengivali)': 'Diagnosi e terapie per gengive e tessuti di sostegno, pensate per stabilizzare e proteggere il sorriso.',
  'Protesi fissa e mobile': 'Soluzioni protesiche fisse o mobili per recuperare estetica, masticazione e comfort quotidiano.',
  'Estetica Indiretta (faccette in porcellana)': 'Faccette in ceramica e soluzioni estetiche indirette per risultati resistenti, luminosi e naturali.',
  'Chirurgia Stomatologica': 'Interventi chirurgici del cavo orale, comprese estrazioni e procedure specialistiche pianificate con cura.',
  'Implantologia tradizionale e computer guidata': 'Impianti dentali tradizionali o guidati digitalmente per sostituire denti mancanti in modo preciso.',
  'Gnatologia (disturbi articolazione temporo-mandibolare)': 'Valutazione di articolazione, masticazione e bruxismo per migliorare equilibrio e comfort funzionale.',
  'Dispositivi contro il russamento e le apnee notturne': 'Dispositivi intraorali personalizzati per contribuire alla gestione di russamento e apnee notturne.',
};

const services = site.treatmentMenu
  .flatMap((category) => category.items)
  .sort((a, b) => treatmentOrder.indexOf(a.label) - treatmentOrder.indexOf(b.label))
  .map((item) => ({
    title: treatmentMenuLabels[item.label] || formatParentheticalDetail(item.label),
    description: treatmentDescriptions[item.label],
    href: item.href,
  }));

const specialistFeature = {
  title: 'L’attenzione dei migliori specialisti.',
  text: 'Il nostro team di professionisti a tua disposizione.',
  cta: 'Guarda il nostro team completo',
  href: '/chi-siamo/',
  image: '/assets/original/2021/02/HOME.jpg',
  alt: 'Dottor Stefano Granata e Dottoressa Chiara Federzoni nello studio dentistico',
};

const technologyFeature = {
  titleLead: 'Tecnologia all’avanguardia per una',
  titleAccent: 'cura dentale di precisione.',
  text: 'Esplora i nostri servizi',
  href: '/trattamenti/',
  image: '/assets/original/2021/03/IL-DIGITALE-scaled.jpg',
  alt: 'Schermo computer con pianificazione digitale di una cura dentale',
};

const workplaceFeature = {
  title: 'Non denti da catalogo, ma un sorriso che sembri tuo,',
  titleEnd: 'solo migliore.',
  text: '',
  image: '/assets/feature-stack/paziente-scanner-digitale.jpg',
  alt: 'Paziente durante una scansione digitale del sorriso',
  links: [
    { label: 'Un piano chiaro prima di qualsiasi trattamento', href: '/trattamenti/' },
    { label: 'Oltre 30 anni di esperienza per proteggere salute, funzione ed estetica', href: '/chi-siamo/' },
    { label: 'Un sorriso studiato sul tuo viso, non su uno standard', href: '/casi-clinici/' },
  ],
};

const clinicalCarouselDetails: Record<string, { description: string; image: string; imageAlt: string; imagePosition: string }> = {
  Estetica: {
    description: 'Casi dedicati all’armonia del sorriso, al colore, alla forma e alla naturalezza del risultato finale.',
    image: '/assets/menu/casi-clinici-estetica.jpg',
    imageAlt: 'Donna che sorride allo specchio durante una visita estetica',
    imagePosition: '45% 52%',
  },
  Protesi: {
    description: 'Riabilitazioni protesiche fisse e mobili per recuperare funzione masticatoria, stabilità ed estetica.',
    image: '/assets/menu/casi-clinici-protesi.png',
    imageAlt: 'Progettazione digitale di una protesi dentale al computer',
    imagePosition: '54% 50%',
  },
  Parodontologia: {
    description: 'Percorsi dedicati alla salute delle gengive e dei tessuti di sostegno del sorriso.',
    image: '/assets/menu/casi-clinici-parodontologia.png',
    imageAlt: 'Controllo parodontale su gengive e denti',
    imagePosition: '54% 48%',
  },
  Implantologia: {
    description: 'Casi con impianti dentali, dalla progettazione alla riabilitazione anche con approccio digitale.',
    image: '/assets/menu/casi-clinici-implantologia.png',
    imageAlt: 'Impianto dentale con corona e gengiva',
    imagePosition: '50% 52%',
  },
  Ortodonzia: {
    description: 'Allineamenti dentali e correzioni funzionali per adulti e bambini, anche con allineatori.',
    image: '/assets/menu/casi-clinici-ortodonzia.png',
    imageAlt: 'Allineatore trasparente applicato sul sorriso',
    imagePosition: '52% 50%',
  },
  Conservativa: {
    description: 'Restauri, otturazioni e ricostruzioni conservative per recuperare i denti naturali.',
    image: '/assets/menu/casi-clinici-conservativa.png',
    imageAlt: 'Restauro conservativo su molare',
    imagePosition: '52% 48%',
  },
  Endodonzia: {
    description: 'Cure canalari e salvataggio del dente quando carie profonde o traumi compromettono la polpa.',
    image: '/assets/menu/casi-clinici-endodonzia.png',
    imageAlt: 'Trattamento endodontico su sezione di dente',
    imagePosition: '50% 48%',
  },
  Video: {
    description: 'Contenuti video per osservare da vicino percorsi, risultati e dettagli dei trattamenti eseguiti.',
    image: '/assets/menu/casi-clinici-video.jpg',
    imageAlt: 'Equipe odontoiatrica durante una procedura clinica',
    imagePosition: '48% 45%',
  },
};

const clinicalCarouselOrder = [
  'Video',
  'Estetica',
  'Protesi',
  'Parodontologia',
  'Implantologia',
  'Conservativa',
  'Ortodonzia',
  'Endodonzia',
];

const clinicalCarouselItems = clinicalCarouselOrder.flatMap((label) => {
  const item = site.clinicalLinks.find((clinicalLink) => clinicalLink.label === label);
  const details = clinicalCarouselDetails[label];

  if (!item || !details) return [];

  return [{
    ...item,
    description: details.description,
    image: details.image,
    imageAlt: details.imageAlt,
    imagePosition: details.imagePosition,
  }];
});

const locationOffices = site.offices.map((office) => {
  const query = encodeURIComponent(office.address);
  const slug = office.city
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/\s+/g, '-');

  return {
    ...office,
    slug,
    mapEmbed: `https://www.google.com/maps?q=${query}&output=embed`,
    mapHref: `https://www.google.com/maps/search/?api=1&query=${query}`,
    hoursRows: office.hours.split(';').map((row) => {
      const [label, ...value] = row.split(':');

      return {
        label: label.trim(),
        value: value.join(':').trim(),
        closed: /chiuso/i.test(row),
      };
    }),
  };
});

---

<div class="scraped-home">
  <section class="scraped-hero" aria-label="Studio dentistico Federzoni Granata" style={`--hero-image: url('${heroImage}')`} data-transparent-header-region>
    <div class="scraped-hero-shade"></div>
    <div class="scraped-hero-copy">
      <p class="scraped-pretitle">Studio dentistico a Modena e Reggio Emilia · Oltre 30 anni di esperienza</p>
      <h1>Un sorriso che sembri tuo, solo migliore.</h1>
      <p class="scraped-hero-description">
        Curiamo salute, funzione ed estetica della bocca per adulti e bambini con un piano chiaro prima di iniziare,
        spiegazioni semplici e risultati naturali pensati sul tuo viso.
      </p>
      <div class="scraped-hero-actions" aria-label="Azioni principali">
        <a class="scraped-hero-button scraped-hero-button-primary" href="/prenota-prima-visita/">
          <span>Prenota una valutazione</span>
          <span aria-hidden="true">↗</span>
        </a>
        <a class="scraped-hero-button scraped-hero-button-secondary" href="/trattamenti/">
          <span>I nostri trattamenti</span>
          <span aria-hidden="true">↗</span>
        </a>
      </div>
    </div>
    <a class="scraped-scroll" href="#trattamenti-home">Scorri</a>
  </section>

  <section id="trattamenti-home" class="services-section" aria-labelledby="services-title">
    <div class="scraped-wrap">
      <div class="scraped-section-head">
        <p class="scraped-eyebrow">Trattamenti dello studio</p>
        <h2 id="services-title">I nostri trattamenti</h2>
      </div>
      <div class="services-rail">
        {services.map((service, index) => (
          <a class="service-card" href={service.href}>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="feature-stack" id="metodo-studio" aria-label="Servizi e valore dello studio">
    <div class="scraped-wrap feature-stack-inner">
      <section class="feature-split feature-specialists">
        <div class="feature-copy">
          <h2>{specialistFeature.title}</h2>
          <p>{specialistFeature.text}</p>
          <a class="feature-button" href={specialistFeature.href}>
            {specialistFeature.cta}
            <span aria-hidden="true">↗</span>
          </a>
        </div>
        <figure class="feature-image">
          <img src={specialistFeature.image} alt={specialistFeature.alt} loading="eager" />
        </figure>
      </section>

      <a class="feature-hero" href={technologyFeature.href} aria-label={technologyFeature.text}>
        <img src={technologyFeature.image} alt={technologyFeature.alt} loading="eager" />
        <span class="feature-hero-shade" aria-hidden="true"></span>
        <div class="feature-hero-copy">
          <h2>
            {technologyFeature.titleLead}
            <strong>{technologyFeature.titleAccent}</strong>
          </h2>
          <p>{technologyFeature.text}</p>
        </div>
      </a>

      <section class="feature-split feature-workplace">
        <figure class="feature-image">
          <img src={workplaceFeature.image} alt={workplaceFeature.alt} loading="eager" />
        </figure>
        <div class="feature-copy">
          <h2>
            {workplaceFeature.title} <span class="feature-title-nowrap">{workplaceFeature.titleEnd}</span>
          </h2>
          {workplaceFeature.text && <p>{workplaceFeature.text}</p>}
          <div class="feature-button-list">
            {workplaceFeature.links.map((link) => (
              <a class="feature-button" href={link.href}>
                {link.label}
                <span aria-hidden="true">↗</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    </div>
  </section>

  <section class="clinical-carousel-section" aria-labelledby="clinical-carousel-title" data-clinical-carousel>
    <div class="clinical-carousel-head">
      <p class="scraped-eyebrow">Guarda i nostri</p>
      <h2 id="clinical-carousel-title">Casi clinici</h2>
    </div>

    <div class="clinical-carousel-shell">
      <button class="clinical-carousel-arrow clinical-carousel-arrow-prev" type="button" aria-label="Scorri i casi clinici precedenti" data-clinical-carousel-prev>
        <span aria-hidden="true">‹</span>
      </button>

      <div class="clinical-carousel-track" data-clinical-carousel-track>
        {clinicalCarouselItems.map((item) => (
          <a class="clinical-carousel-card" href={item.href} style={`--clinical-card-position: ${item.imagePosition};`}>
            <img src={item.image} alt={item.imageAlt} loading="lazy" />
            <span class="clinical-carousel-shade" aria-hidden="true"></span>
            <span class="clinical-carousel-card-copy">
              <strong>{item.label}</strong>
              <small>{item.description}</small>
            </span>
          </a>
        ))}
      </div>

      <button class="clinical-carousel-arrow clinical-carousel-arrow-next" type="button" aria-label="Scorri i casi clinici successivi" data-clinical-carousel-next>
        <span aria-hidden="true">›</span>
      </button>
    </div>
  </section>

  <section class="insights-section" aria-labelledby="insights-title">
    <div class="scraped-wrap">
      <div class="insights-head">
        <h2 id="insights-title">I Nostri Pazienti Dicono</h2>
        <a href="/recensioni/">Tutte le recensioni</a>
      </div>
      <div class="insights-grid">
        {featuredPatientReviews.map((item) => (
          <a class="insight-card" href="/recensioni/">
            <div class="review-card-head">
              {item.avatar ? (
                <img class="review-avatar" src={item.avatar} alt={`Foto profilo di ${item.author}`} loading="lazy" />
              ) : (
                <span class="review-avatar" aria-hidden="true">{item.initials}</span>
              )}
              <div class="review-card-person">
                <strong>{item.author}</strong>
                <small>Recensione Google • {item.relativeTime}</small>
              </div>
            </div>
            <span class="review-stars" aria-label={`${item.rating} stelle su 5`}>{starsFor(item.rating)}</span>
            <p class="review-card-copy">{item.text}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="prefooter-section" aria-labelledby="prefooter-title">
    <div class="scraped-wrap prefooter-cta">
      <div class="prefooter-copy">
        <p class="prefooter-eyebrow">Prenota la tua visita</p>
        <h2 id="prefooter-title">Il prossimo passo per la salute del tuo sorriso</h2>
        <p>
          Raccontaci le tue esigenze: lo studio ti ricontatterà per indicarti il percorso più adatto e fissare l’appuntamento nella sede più comoda.
        </p>
      </div>
      <div class="prefooter-action">
        <a class="prefooter-button" href="/richiesta/">Prenota visita <span aria-hidden="true">↗</span></a>
        <span>Studi a Modena e Reggio Emilia</span>
      </div>
    </div>
  </section>

  <section class="locations-section" aria-labelledby="locations-title" data-locations-map-section>
    <div class="locations-layout">
      <div class="locations-copy">
        <p class="locations-eyebrow">Sedi e accessibilità</p>
        <h2 id="locations-title">Dove trovarci</h2>

        <div class="location-list">
          {locationOffices.map((office, index) => (
            <article
              class:list={['location-card', index === 0 && 'location-card-open']}
              id={office.slug}
              data-location-card
              data-map-src={office.mapEmbed}
              data-map-title={`Mappa dello studio dentistico di ${office.city}`}
              data-map-city={office.city}
              data-map-address={office.address}
              data-map-href={office.mapHref}>
              <button
                class="location-card-trigger"
                type="button"
                aria-expanded={index === 0 ? 'true' : 'false'}
                aria-controls={`sede-${office.slug}-panel`}>
                <span class="location-card-title">
                  <small>Studio dentistico di</small>
                  <strong>{office.city}</strong>
                </span>
                <i aria-hidden="true"></i>
              </button>

              <div class="location-card-panel" id={`sede-${office.slug}-panel`} hidden={index !== 0}>
                <div class="location-detail">
                  <span>Indirizzo</span>
                  <strong>{office.address}</strong>
                </div>

                <div class="location-detail">
                  <span>Telefono</span>
                  <a href={office.phoneHref}>{office.phone}</a>
                </div>

                <div class="location-detail">
                  <span>Email</span>
                  <a href={office.emailHref}>{office.email}</a>
                </div>

                <div class="location-hours" aria-label={`Orari ${office.city}`}>
                  <p>Orari</p>
                  {office.hoursRows.map((row) => (
                    <div class:list={['location-hours-row', row.closed && 'location-hours-row-closed']}>
                      <span>{row.label}</span>
                      <strong>{row.value}</strong>
                    </div>
                  ))}
                </div>

                <a class="location-route" href={office.mapHref} target="_blank" rel="noreferrer">
                  Apri percorso
                  <span aria-hidden="true">↗</span>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="locations-map-stack" aria-label="Mappa dello studio selezionato">
        {locationOffices[0] && (
          <article class="location-map-card" aria-label={`Mappa ${locationOffices[0].city}`}>
            <iframe
              src={locationOffices[0].mapEmbed}
              title={`Mappa dello studio dentistico di ${locationOffices[0].city}`}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              data-location-map></iframe>
            <div class="location-map-caption">
              <strong data-location-map-city>{locationOffices[0].city}</strong>
              <span data-location-map-address>{locationOffices[0].address}</span>
              <a href={locationOffices[0].mapHref} target="_blank" rel="noreferrer" data-location-map-link>Apri su Google Maps <span aria-hidden="true">↗</span></a>
            </div>
          </article>
        )}
      </div>
    </div>
  </section>

  <script>
    const clinicalCarousels = document.querySelectorAll('[data-clinical-carousel]');

    clinicalCarousels.forEach((carousel) => {
      const track = carousel.querySelector('[data-clinical-carousel-track]');
      const prev = carousel.querySelector('[data-clinical-carousel-prev]');
      const next = carousel.querySelector('[data-clinical-carousel-next]');

      if (!(track instanceof HTMLElement)) return;

      const originalCards = Array.from(track.querySelectorAll('.clinical-carousel-card')).filter(
        (card) => card instanceof HTMLElement,
      );

      if (originalCards.length < 2) return;

      const cloneCard = (card) => {
        const clone = card.cloneNode(true);
        if (clone instanceof HTMLElement) {
          clone.dataset.carouselClone = 'true';
          clone.setAttribute('aria-hidden', 'true');
          clone.setAttribute('tabindex', '-1');
        }
        return clone;
      };

      const beforeClones = originalCards.map(cloneCard);
      const afterClones = originalCards.map(cloneCard);

      beforeClones
        .slice()
        .reverse()
        .forEach((clone) => track.insertBefore(clone, track.firstChild));
      afterClones.forEach((clone) => track.appendChild(clone));

      const firstOriginal = originalCards[0];
      const firstAfterClone = afterClones[0];

      if (!(firstOriginal instanceof HTMLElement) || !(firstAfterClone instanceof HTMLElement)) return;

      const getScrollAmount = () => {
        const card = track.querySelector('.clinical-carousel-card');
        if (!(card instanceof HTMLElement)) return track.clientWidth * 0.78;

        const styles = window.getComputedStyle(track);
        const gap = Number.parseFloat(styles.columnGap || styles.gap || '0');

        return card.offsetWidth + gap;
      };

      const getLoopMetrics = () => {
        const start = firstOriginal.offsetLeft;
        const width = firstAfterClone.offsetLeft - start;

        return { start, width };
      };

      const normalizeLoopPosition = () => {
        const { start, width } = getLoopMetrics();
        if (width <= 0) return;

        while (track.scrollLeft < start) {
          track.scrollLeft += width;
        }

        while (track.scrollLeft >= start + width) {
          track.scrollLeft -= width;
        }
      };

      const setInitialScroll = () => {
        track.scrollLeft = getLoopMetrics().start + firstOriginal.offsetWidth / 2;
      };

      const scrollLoop = (direction) => {
        normalizeLoopPosition();
        track.scrollBy({ left: direction * getScrollAmount(), behavior: 'smooth' });
        window.setTimeout(normalizeLoopPosition, 420);
      };

      let scrollFrame = 0;

      track.addEventListener(
        'scroll',
        () => {
          window.cancelAnimationFrame(scrollFrame);
          scrollFrame = window.requestAnimationFrame(normalizeLoopPosition);
        },
        { passive: true },
      );

      requestAnimationFrame(setInitialScroll);
      window.addEventListener('load', setInitialScroll, { once: true });
      window.addEventListener('resize', () => requestAnimationFrame(setInitialScroll));

      prev?.addEventListener('click', () => {
        scrollLoop(-1);
      });

      next?.addEventListener('click', () => {
        scrollLoop(1);
      });
    });

    const locationSections = document.querySelectorAll('[data-locations-map-section]');

    locationSections.forEach((section) => {
      const cards = Array.from(section.querySelectorAll('[data-location-card]'));
      const map = section.querySelector('[data-location-map]');
      const mapCity = section.querySelector('[data-location-map-city]');
      const mapAddress = section.querySelector('[data-location-map-address]');
      const mapLink = section.querySelector('[data-location-map-link]');

      const activateCard = (card) => {
        cards.forEach((item) => {
          const isOpen = item === card;
          const button = item.querySelector('.location-card-trigger');
          const panel = item.querySelector('.location-card-panel');

          item.classList.toggle('location-card-open', isOpen);
          button?.setAttribute('aria-expanded', String(isOpen));

          if (panel) {
            panel.hidden = !isOpen;
          }
        });

        if (map instanceof HTMLIFrameElement && card.dataset.mapSrc && map.src !== card.dataset.mapSrc) {
          map.src = card.dataset.mapSrc;
        }

        if (card.dataset.mapTitle) {
          map?.setAttribute('title', card.dataset.mapTitle);
        }

        if (mapCity && card.dataset.mapCity) {
          mapCity.textContent = card.dataset.mapCity;
        }

        if (mapAddress && card.dataset.mapAddress) {
          mapAddress.textContent = card.dataset.mapAddress;
        }

        if (mapLink instanceof HTMLAnchorElement && card.dataset.mapHref) {
          mapLink.href = card.dataset.mapHref;
        }
      };

      cards.forEach((card) => {
        const button = card.querySelector('.location-card-trigger');
        button?.addEventListener('click', () => activateCard(card));
      });
    });
  </script>
</div>

<style>
  .scraped-home {
    --cdm-green: var(--brand-primary-dark);
    --cdm-green-deep: var(--brand-primary-dark);
    --cdm-lime: var(--brand-blue);
    --cdm-action: var(--brand-cta);
    --cdm-paper: var(--surface-white);
    --cdm-soft: var(--background);
    --cdm-text: var(--brand-primary-dark);
    background: var(--cdm-paper);
    color: var(--cdm-text);
    font-family: "Inter", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    letter-spacing: -0.01em;
  }

  .scraped-home :global(a) {
