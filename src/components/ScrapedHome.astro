---
import { site } from '../data/site';

const heroImage = '/assets/original/2022/03/dentista-modena-reggio-emilia.jpg';

const treatmentOrder = [
  'Igiene orale e Prevenzione',
  'Sbiancamento',
  'Conservativa (otturazioni)',
  'Endodonzia (devitalizzazioni)',
  'Pedodonzia (odontoiatria infantile)',
  'Ortodonzia e Allineatori invisibili (adulti e bimbi)',
  'Estetica diretta (faccette in composito)',
  'Parodontologia (cure gengivali)',
  'Protesi fissa e mobile',
  'Estetica Indiretta (faccette in porcellana)',
  'Chirurgia Stomatologica',
  'Implantologia tradizionale e computer guidata',
  'Gnatologia (disturbi articolazione temporo-mandibolare)',
  'Dispositivi contro il russamento e le apnee notturne',
];

const treatmentMenuLabels: Record<string, string> = {
  'Estetica diretta (faccette in composito)': 'Faccette in composito',
  'Estetica Indiretta (faccette in porcellana)': 'Faccette in ceramica',
};

const treatmentDescriptions: Record<string, string> = {
  'Igiene orale e Prevenzione': 'Controlli periodici, sedute di igiene e indicazioni personalizzate per mantenere denti e gengive in salute.',
  Sbiancamento: 'Trattamenti professionali per migliorare il colore del sorriso in modo controllato e rispettoso dei tessuti dentali.',
  'Conservativa (otturazioni)': 'Otturazioni, restauri e ricostruzioni per recuperare i denti danneggiati preservando la struttura naturale.',
  'Endodonzia (devitalizzazioni)': 'Cure canalari e devitalizzazioni per trattare infezioni profonde e salvare il dente quando possibile.',
  'Pedodonzia (odontoiatria infantile)': 'Percorsi dedicati ai bambini, dalla prevenzione alle prime cure, con attenzione a serenità e fiducia.',
  'Ortodonzia e Allineatori invisibili (adulti e bimbi)': 'Soluzioni ortodontiche per adulti e bambini, anche con allineatori trasparenti e piani su misura.',
  'Estetica diretta (faccette in composito)': 'Faccette e restauri diretti in composito per armonizzare forma, proporzioni e naturalezza del sorriso.',
  'Parodontologia (cure gengivali)': 'Diagnosi e terapie per gengive e tessuti di sostegno, pensate per stabilizzare e proteggere il sorriso.',
  'Protesi fissa e mobile': 'Soluzioni protesiche fisse o mobili per recuperare estetica, masticazione e comfort quotidiano.',
  'Estetica Indiretta (faccette in porcellana)': 'Faccette in ceramica e soluzioni estetiche indirette per risultati resistenti, luminosi e naturali.',
  'Chirurgia Stomatologica': 'Interventi chirurgici del cavo orale, comprese estrazioni e procedure specialistiche pianificate con cura.',
  'Implantologia tradizionale e computer guidata': 'Impianti dentali tradizionali o guidati digitalmente per sostituire denti mancanti in modo preciso.',
  'Gnatologia (disturbi articolazione temporo-mandibolare)': 'Valutazione di articolazione, masticazione e bruxismo per migliorare equilibrio e comfort funzionale.',
  'Dispositivi contro il russamento e le apnee notturne': 'Dispositivi intraorali personalizzati per contribuire alla gestione di russamento e apnee notturne.',
};

const services = site.treatmentMenu
  .flatMap((category) => category.items)
  .sort((a, b) => treatmentOrder.indexOf(a.label) - treatmentOrder.indexOf(b.label))
  .map((item) => ({
    title: treatmentMenuLabels[item.label] || item.label,
    description: treatmentDescriptions[item.label],
    href: item.href,
  }));

const specialistFeature = {
  title: 'L’attenzione dei migliori specialisti.',
  text: 'Il nostro team di professionisti a tua disposizione.',
  cta: 'Trova il medico o il professionista',
  href: 'https://centrodimedicina.com/medici/',
  image: '/assets/feature-stack/specialisti.jpg',
  alt: 'Medico che rassicura un paziente durante una visita',
};

const technologyFeature = {
  titleLead: 'Tecnologia all’avanguardia per una',
  titleAccent: 'medicina di precisione.',
  text: 'Esplora i nostri servizi',
  href: 'https://centrodimedicina.com/servizi-e-prestazioni/',
  image: '/assets/feature-stack/tecnologia.jpg',
  alt: 'Tecnologia medica avanzata per diagnosi di precisione',
};

const workplaceFeature = {
  title: 'Medicina del lavoro, welfare sanitario e convenzioni.',
  text: 'Scopri i nostri servizi per i tuoi collaboratori.',
  image: '/assets/feature-stack/welfare.jpg',
  alt: 'Blocchi con icone dedicate al welfare sanitario',
  links: [
    { label: 'La prevenzione in azienda', href: 'https://centrodimedicina.com/medicina-del-lavoro/' },
    { label: 'Fondi e convenzioni', href: 'https://centrodimedicina.com/convenzioni-welfare/' },
    { label: 'Welfare sanitario e convenzioni', href: 'https://centrodimedicina.com/convenzioni-welfare/' },
  ],
};

const locationOffices = site.offices.map((office) => {
  const query = encodeURIComponent(office.address);
  const slug = office.city
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/\s+/g, '-');

  return {
    ...office,
    slug,
    mapEmbed: `https://www.google.com/maps?q=${query}&output=embed`,
    mapHref: `https://www.google.com/maps/search/?api=1&query=${query}`,
    hoursRows: office.hours.split(';').map((row) => {
      const [label, ...value] = row.split(':');

      return {
        label: label.trim(),
        value: value.join(':').trim(),
        closed: /chiuso/i.test(row),
      };
    }),
  };
});

const insights = [
  {
    category: 'Eventi, News & eventi, Tour della prevenzione',
    title: 'Villorba: genitori e adolescenti al centro dell’incontro con Osvaldo Poli',
    href: 'https://centrodimedicina.com/villorba-incontro-osvaldo-poli-genitori-adolescenti/',
  },
  {
    category: 'News & eventi',
    title: 'Giornate Lignanesi di Medicina e Chirurgia della Riproduzione Umana: appuntamento il 25 e 26 maggio 2026',
    href: 'https://centrodimedicina.com/giornate-lignanesi-di-medicina-e-chirurgia-della-riproduzione-umana-appuntamento-il-25-e-26-maggio-2026/',
  },
  {
    category: 'News, News & eventi',
    title: 'PROCTOLive 2026 a Mestre: congresso proctologia',
    href: 'https://centrodimedicina.com/proctolive-2026-mestre-chirurgia-proctologica/',
  },
  {
    category: 'Benessere fisico, Blog',
    title: 'Emorroidi: quando preoccuparsi e quando si possono trattare senza chirurgia',
    href: 'https://centrodimedicina.com/emorroidi-quando-preoccuparsi-e-quando-si-possono-trattare-senza-chirurgia/',
  },
  {
    category: 'Benessere fisico, Blog',
    title: 'Lipedema: come riconoscerlo e trattarlo. Il ruolo della fisioterapia',
    href: 'https://centrodimedicina.com/lipedema-come-riconoscerlo-e-trattarlo-il-ruolo-della-fisioterapia/',
  },
  {
    category: 'Blog della salute',
    title: 'Fertilità e nutrizione',
    href: 'https://centrodimedicina.com/infiammazione-cronica-fertilita-e-nutrizione-perche-proteggere-la-salute-riproduttiva/',
  },
];
---

<div class="scraped-home">
  <section class="scraped-hero" aria-label="Centro di medicina" style={`--hero-image: url('${heroImage}')`}>
    <div class="scraped-hero-shade"></div>
    <div class="scraped-hero-copy">
      <p class="scraped-pretitle">Centro di medicina</p>
      <h1>Il network per la tua salute</h1>
    </div>
    <a class="scraped-scroll" href="#aiuto">Scorri</a>
  </section>

  <section id="aiuto" class="booking-section" aria-labelledby="booking-title">
    <div class="scraped-wrap booking-grid">
      <div class="booking-intro">
        <p class="scraped-eyebrow">Come possiamo aiutarti?</p>
        <h2 id="booking-title">Prenota o chiedi informazioni.</h2>
        <p>
          Hai un fondo?
          <a href="https://centrodimedicina.com/convenzioni-welfare/#layout_page_accordion_text_5">Scopri le prestazioni convenzionate</a>
        </p>
      </div>

      <form class="booking-form" aria-label="Ricerca prestazione">
        <label>
          <span>Seleziona una prestazione:</span>
          <select disabled>
            <option>Digita il nome della prestazione</option>
          </select>
        </label>
        <label>
          <span>Seleziona una sede:</span>
          <select disabled>
            <option>Qualsiasi sede</option>
          </select>
        </label>
        <label>
          <span>Seleziona un medico:</span>
          <select disabled>
            <option>Qualsiasi medico</option>
          </select>
        </label>
        <button type="button" disabled>Cerca</button>
        <p>
          Non conosci il nome della prestazione?
          <a href="https://centrodimedicina.com/servizi-e-prestazioni/">Consulta l’elenco completo</a>
          oppure
          <a href="https://centrodimedicina.com/contatti/">Contattaci</a>
        </p>
      </form>
    </div>

  </section>

  <section class="services-section" aria-labelledby="services-title">
    <div class="scraped-wrap">
      <div class="scraped-section-head">
        <p class="scraped-eyebrow">Trattamenti dello studio</p>
        <h2 id="services-title">I nostri trattamenti</h2>
      </div>
      <div class="services-rail">
        {services.map((service, index) => (
          <a class="service-card" href={service.href}>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="feature-stack" aria-label="Servizi e valore dello studio">
    <div class="scraped-wrap feature-stack-inner">
      <section class="feature-split feature-specialists">
        <div class="feature-copy">
          <h2>{specialistFeature.title}</h2>
          <p>{specialistFeature.text}</p>
          <a class="feature-button" href={specialistFeature.href}>
            {specialistFeature.cta}
            <span aria-hidden="true">↗</span>
          </a>
        </div>
        <figure class="feature-image">
          <img src={specialistFeature.image} alt={specialistFeature.alt} loading="eager" />
        </figure>
      </section>

      <a class="feature-hero" href={technologyFeature.href} aria-label={technologyFeature.text}>
        <img src={technologyFeature.image} alt={technologyFeature.alt} loading="eager" />
        <span class="feature-hero-shade" aria-hidden="true"></span>
        <div class="feature-hero-copy">
          <h2>
            {technologyFeature.titleLead}
            <strong>{technologyFeature.titleAccent}</strong>
          </h2>
          <p>{technologyFeature.text}</p>
        </div>
      </a>

      <section class="feature-split feature-workplace">
        <figure class="feature-image">
          <img src={workplaceFeature.image} alt={workplaceFeature.alt} loading="eager" />
        </figure>
        <div class="feature-copy">
          <h2>{workplaceFeature.title}</h2>
          <p>{workplaceFeature.text}</p>
          <div class="feature-button-list">
            {workplaceFeature.links.map((link) => (
              <a class="feature-button" href={link.href}>
                {link.label}
                <span aria-hidden="true">↗</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    </div>
  </section>

  <section class="insights-section" aria-labelledby="insights-title">
    <div class="scraped-wrap">
      <div class="insights-head">
        <h2 id="insights-title">Approfondimenti</h2>
        <a href="https://centrodimedicina.com/blog/">Tutti gli articoli</a>
      </div>
      <div class="insights-grid">
        {insights.map((item) => (
          <a class="insight-card" href={item.href}>
            <span>{item.category}</span>
            <h3>{item.title}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="prefooter-section" aria-label="Newsletter e network">
    <div class="scraped-wrap prefooter-grid">
      <div class="newsletter-panel">
        <h2>La newsletter della salute</h2>
        <p>
          Prevenzione, cura, sane abitudini, novità: ricevi periodicamente aggiornamenti utili alla tua salute e benessere dal network Centro di medicina.
        </p>
        <form class="newsletter-form">
          <label>
            <span>Inserisci la tua email</span>
            <input type="email" placeholder="Il tuo indirizzo email" />
          </label>
          <button type="button">Iscriviti ora</button>
        </form>
      </div>
      <div class="network-panel">
        <h2>Il network per la tua salute</h2>
        <p>
          Affidati a Centro di medicina, una rete di cliniche poliambulatoriali private e convenzionate a servizio delle tue esigenze di salute.
        </p>
        <a href="https://centrodimedicina.com/about/">Conosci il nostro gruppo</a>
      </div>
    </div>
  </section>

  <section class="locations-section" aria-labelledby="locations-title" data-locations-map-section>
    <div class="locations-layout">
      <div class="locations-copy">
        <p class="locations-eyebrow">Sedi e accessibilità</p>
        <h2 id="locations-title">Dove trovarci</h2>

        <div class="location-list">
          {locationOffices.map((office, index) => (
            <article
              class:list={['location-card', index === 0 && 'location-card-open']}
              id={office.slug}
              data-location-card
              data-map-src={office.mapEmbed}
              data-map-title={`Mappa dello studio dentistico di ${office.city}`}
              data-map-city={office.city}
              data-map-address={office.address}
              data-map-href={office.mapHref}>
              <button
                class="location-card-trigger"
                type="button"
                aria-expanded={index === 0 ? 'true' : 'false'}
                aria-controls={`sede-${office.slug}-panel`}>
                <span class="location-card-title">
                  <small>Studio dentistico di</small>
                  <strong>{office.city}</strong>
                </span>
                <i aria-hidden="true"></i>
              </button>

              <div class="location-card-panel" id={`sede-${office.slug}-panel`} hidden={index !== 0}>
                <div class="location-detail">
                  <span>Indirizzo</span>
                  <strong>{office.address}</strong>
                </div>

                <div class="location-detail">
                  <span>Telefono</span>
                  <a href={office.phoneHref}>{office.phone}</a>
                </div>

                <div class="location-detail">
                  <span>Email</span>
                  <a href={office.emailHref}>{office.email}</a>
                </div>

                <div class="location-hours" aria-label={`Orari ${office.city}`}>
                  <p>Orari</p>
                  {office.hoursRows.map((row) => (
                    <div class:list={['location-hours-row', row.closed && 'location-hours-row-closed']}>
                      <span>{row.label}</span>
                      <strong>{row.value}</strong>
                    </div>
                  ))}
                </div>

                <a class="location-route" href={office.mapHref} target="_blank" rel="noreferrer">
                  Apri percorso
                  <span aria-hidden="true">↗</span>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="locations-map-stack" aria-label="Mappa dello studio selezionato">
        {locationOffices[0] && (
          <article class="location-map-card" aria-label={`Mappa ${locationOffices[0].city}`}>
            <iframe
              src={locationOffices[0].mapEmbed}
              title={`Mappa dello studio dentistico di ${locationOffices[0].city}`}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              data-location-map></iframe>
            <div class="location-map-caption">
              <strong data-location-map-city>{locationOffices[0].city}</strong>
              <span data-location-map-address>{locationOffices[0].address}</span>
              <a href={locationOffices[0].mapHref} target="_blank" rel="noreferrer" data-location-map-link>Apri su Google Maps</a>
            </div>
          </article>
        )}
      </div>
    </div>
  </section>

  <script>
    const locationSections = document.querySelectorAll('[data-locations-map-section]');

    locationSections.forEach((section) => {
      const cards = Array.from(section.querySelectorAll('[data-location-card]'));
      const map = section.querySelector('[data-location-map]');
      const mapCity = section.querySelector('[data-location-map-city]');
      const mapAddress = section.querySelector('[data-location-map-address]');
      const mapLink = section.querySelector('[data-location-map-link]');

      const activateCard = (card) => {
        cards.forEach((item) => {
          const isOpen = item === card;
          const button = item.querySelector('.location-card-trigger');
          const panel = item.querySelector('.location-card-panel');

          item.classList.toggle('location-card-open', isOpen);
          button?.setAttribute('aria-expanded', String(isOpen));

          if (panel) {
            panel.hidden = !isOpen;
          }
        });

        if (map instanceof HTMLIFrameElement && card.dataset.mapSrc && map.src !== card.dataset.mapSrc) {
          map.src = card.dataset.mapSrc;
        }

        if (card.dataset.mapTitle) {
          map?.setAttribute('title', card.dataset.mapTitle);
        }

        if (mapCity && card.dataset.mapCity) {
          mapCity.textContent = card.dataset.mapCity;
        }

        if (mapAddress && card.dataset.mapAddress) {
          mapAddress.textContent = card.dataset.mapAddress;
        }

        if (mapLink instanceof HTMLAnchorElement && card.dataset.mapHref) {
          mapLink.href = card.dataset.mapHref;
        }
      };

      cards.forEach((card) => {
        const button = card.querySelector('.location-card-trigger');
        button?.addEventListener('click', () => activateCard(card));
      });
    });
  </script>
</div>

<style>
  .scraped-home {
    --cdm-green: #005924;
    --cdm-green-deep: #003e1a;
    --cdm-lime: #99c555;
    --cdm-action: #78c51c;
    --cdm-paper: #ffffff;
    --cdm-soft: #f3f6ef;
    --cdm-text: #005924;
    background: var(--cdm-paper);
    color: var(--cdm-text);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    letter-spacing: -0.01em;
  }

  .scraped-home :global(a) {
    color: inherit;
  }

  .scraped-wrap {
    width: min(1510px, calc(100% - 30px));
    margin: 0 auto;
  }

  .scraped-hero {
    position: relative;
    min-height: 100svh;
    display: grid;
    place-items: center;
    overflow: hidden;
    background-image: var(--hero-image);
    background-position: center;
    background-size: cover;
    color: #fff;
    isolation: isolate;
  }

  .scraped-hero-shade {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(180deg, rgba(0, 55, 22, 0.38), rgba(0, 55, 22, 0.66)),
      linear-gradient(90deg, rgba(0, 55, 22, 0.7), rgba(0, 55, 22, 0.12) 62%, rgba(0, 55, 22, 0.5));
  }

  .scraped-hero-copy {
    width: min(1280px, calc(100% - 30px));
    margin: 0 auto;
    padding: 150px 0 120px;
    text-align: center;
  }

  .scraped-pretitle,
  .scraped-eyebrow {
    margin: 0;
    font-size: clamp(1rem, 1.1vw, 1.125rem);
    font-weight: 500;
    line-height: 1.25;
    text-transform: uppercase;
  }

  .scraped-pretitle {
    margin-bottom: 18px;
    color: #fff;
  }

  .scraped-hero h1 {
    max-width: 13ch;
    margin: 0 auto;
    color: #fff;
    font-family: Inter, ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(4rem, 10vw, 9rem);
    font-weight: 400;
    line-height: 0.9;
    text-transform: uppercase;
    overflow-wrap: anywhere;
    hyphens: auto;
  }

  .scraped-scroll {
    position: absolute;
    right: 30px;
    bottom: 28px;
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    text-transform: uppercase;
  }

  .booking-section {
    background: var(--blue-dark);
    color: #fff;
    padding: 80px 0;
  }

  .booking-grid {
    display: grid;
    grid-template-columns: minmax(260px, 0.8fr) minmax(0, 1.4fr);
    gap: 48px;
    align-items: start;
  }

  .booking-intro h2,
  .scraped-section-head h2,
  .insights-head h2,
  .prefooter-section h2 {
    margin: 10px 0 0;
    color: inherit;
    font-family: Inter, ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(2rem, 4.8vw, 4.75rem);
    font-weight: 500;
    line-height: 1.05;
  }

  .booking-intro p {
    max-width: 520px;
    margin: 24px 0 0;
    color: rgba(255, 255, 255, 0.82);
    font-size: clamp(1.1rem, 1.7vw, 1.6rem);
    font-weight: 500;
    line-height: 1.35;
  }

  .booking-intro a,
  .booking-form a {
    color: var(--aqua);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }

  .booking-form {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    align-items: end;
  }

  .booking-form label {
    min-width: 0;
    display: grid;
    gap: 8px;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .booking-form select,
  .newsletter-form input {
    width: 100%;
    min-height: 58px;
    border: 1px solid rgba(255, 255, 255, 0.38);
    border-radius: 0;
    padding: 0 16px;
    background: #fff;
    color: var(--blue-dark);
    font: inherit;
  }

  .booking-form button,
  .newsletter-form button {
    min-height: 58px;
    border: 0;
    padding: 0 24px;
    background: var(--blue);
    color: #fff;
    font: inherit;
    font-size: 0.95rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .booking-form button:disabled,
  .booking-form select:disabled {
    cursor: not-allowed;
    opacity: 1;
  }

  .booking-form p {
    grid-column: 1 / -1;
    margin: 8px 0 0;
    color: rgba(255, 255, 255, 0.76);
  }

  .services-section,
  .insights-section {
    padding: 96px 0;
    background: #fff;
  }

  .scraped-section-head {
    display: flex;
    justify-content: space-between;
    gap: 32px;
    align-items: end;
    margin-bottom: 42px;
  }

  .scraped-section-head .scraped-eyebrow {
    color: var(--cdm-green);
  }

  .services-rail {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    background: rgba(0, 89, 36, 0.18);
  }

  .service-card {
    min-height: 330px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 24px;
    padding: 28px;
    background: var(--cdm-soft);
    color: var(--cdm-green);
    text-decoration: none;
    transition: background-color 160ms ease, color 160ms ease;
  }

  .service-card:hover {
    background: var(--cdm-green);
