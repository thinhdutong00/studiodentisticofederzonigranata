---
import ContactForm from './ContactForm.astro';
import FeatureCards from './FeatureCards.astro';
import ScrapedHome from './ScrapedHome.astro';
import SectionBand from './SectionBand.astro';
import TreatmentStickyCta from './TreatmentStickyCta.astro';
import { site, type SitePage } from '../data/site';

interface Props {
  page: SitePage;
}

const { page } = Astro.props;
const titleBlock = page.blocks.find((block) => block.type === 'heading');
const pageTitle = titleBlock?.text || page.navTitle;
const bodyBlocks = page.path === '/' ? page.blocks : page.blocks.filter((block) => block !== titleBlock);

const cleanHeading = (text = '') =>
  text
    .replace(/Dottoressa(?=[A-ZÀ-Ý])/g, 'Dottoressa ')
    .replace(/Dottor(?=[A-ZÀ-Ý])/g, 'Dottor ')
    .replace('Casi CliniciEsempi di lavori eseguiti dallo studio odontoiatrico', 'Casi Clinici')
    .trim();

const clinicalItems = site.clinicalLinks.map((item) => ({ label: item.label, href: item.href }));

const videoBlocks = page.path === '/video/' ? page.blocks : [];
const videoIntroHtml = videoBlocks[1] && 'html' in videoBlocks[1] ? videoBlocks[1].html : '';
const videoLeadHtml = videoBlocks[3] && 'html' in videoBlocks[3] ? videoBlocks[3].html : '';
const videoChannelTitle = videoBlocks[4]?.type === 'heading' ? videoBlocks[4].text : 'Studio Dentistico Federzoni Granata';
const videoItems = [
  { id: '5T0EhOcKp9k', title: 'Ponte Maryland', description: 'Ponte adesivo per sostituire un dente quando non si può inserire un impianto.' },
  { id: 'UrDSGXJzbhQ', title: 'Denti in giornata', description: 'Una riflessione sui tempi corretti per ripristinare funzione e salute orale.' },
  { id: 'Ji1plubRtSs', title: 'Parodontologia o implantologia', description: 'Quando preservare i denti e quando valutare gli impianti.' },
  { id: 'gl4tqBSwyic', title: 'Ortodonzia e allineatori', description: 'Allineatori trasparenti per giovani e adulti.' },
  { id: 'ePNtvPhQu1Q', title: 'Tecnologie implantari', description: 'Strumenti e diagnosi per valutare l’inserimento degli impianti.' },
  { id: 'kDj5PXvsj0A', title: 'TAC e visita approfondita', description: 'CBCT, diagnosi e pianificazione accurata del trattamento.' },
  { id: 'yALQdE_9-rE', title: 'Chirurgia guidata', description: 'Progettazione digitale e mascherine chirurgiche per interventi guidati.' },
  { id: 'isanVOgd-wE', title: 'Implantologia rigenerativa', description: 'Corso teorico pratico di implantologia rigenerativa.' },
  { id: 'gCRq49_54IA', title: 'Visita senza impegno', description: 'Perché diagnosi, prognosi e piano di trattamento richiedono tempo.' },
];

const faqItems = [
  {
    question: 'Come posso prenotare una visita?',
    answer: 'Puoi usare il modulo di prenotazione online oppure contattare direttamente lo studio. Dopo la richiesta verrai ricontattato per definire sede, disponibilità e motivo della visita.',
  },
  {
    question: 'Cosa devo portare alla prima visita?',
    answer: 'Porta eventuali radiografie, referti, bite o documentazione clinica recente. Se non hai esami disponibili, lo studio valuterà durante la visita quali approfondimenti siano necessari.',
  },
  {
    question: 'Lo studio segue anche bambini e ragazzi?',
    answer: 'Sì, sono disponibili percorsi dedicati ai bambini e agli adolescenti, con attenzione alla prevenzione, alla serenità durante la visita e alla valutazione ortodontica quando indicata.',
  },
  {
    question: 'Posso richiedere una visita urgente?',
    answer: 'Sì. In caso di dolore, trauma o gonfiore puoi inviare una richiesta o chiamare lo studio: il team ti aiuterà a capire la priorità e la prima disponibilità utile.',
  },
  {
    question: 'Quali trattamenti vengono eseguiti nello studio?',
    answer: 'Lo studio si occupa di prevenzione, igiene, conservativa, endodonzia, ortodonzia, parodontologia, implantologia, protesi, estetica dentale e altri trattamenti odontoiatrici su piano personalizzato.',
  },
  {
    question: 'Sono disponibili allineatori trasparenti?',
    answer: 'Sì, gli allineatori trasparenti possono essere valutati per adulti e ragazzi. L’indicazione dipende dalla diagnosi ortodontica e dagli obiettivi clinici del singolo caso.',
  },
  {
    question: 'Lo studio lavora con tecnologie digitali?',
    answer: 'Sì, vengono utilizzate tecnologie digitali per diagnosi, progettazione e pianificazione dei trattamenti, con l’obiettivo di rendere il percorso più preciso e controllato.',
  },
  {
    question: 'Ci sono sedi a Modena e Reggio Emilia?',
    answer: 'Sì, lo Studio Dentistico Federzoni Granata riceve nelle sedi di Modena e Reggio Emilia. In fase di prenotazione puoi indicare la sede più comoda per te.',
  },
  {
    question: 'Accettate convenzioni o fondi sanitari?',
    answer: 'Puoi segnalare eventuali fondi, assicurazioni o casse sanitarie: ti indicheremo quale documentazione può essere rilasciata per la richiesta di rimborso.',
  },
];

const emergencyHeroImage = '/assets/menu/faq.jpg';
const emergencyCopy = [
  'Un dolore improvviso, un trauma o un gonfiore non vanno rimandati. Nelle urgenze dentali lo Studio Dentistico Federzoni Granata ti aiuta a capire rapidamente la priorita del problema e il percorso piu adatto per intervenire.',
  'Puoi inviare una richiesta dedicata indicando sintomi, intensita del dolore, sede preferita e disponibilita. La segreteria raccogliera le informazioni essenziali e ti ricontattera per organizzare la visita urgente nel modo piu rapido possibile.',
];
const aestheticHeroImage = '/assets/menu/casi-clinici-estetica.jpg';

const conventionsHeroImage = '/assets/menu/convenzioni-studio.jpg';
const conventionsSteps = [
  {
    title: 'Segnala il tuo fondo',
    text: 'Quando prenoti la visita puoi indicarci il nome della tua assicurazione, cassa sanitaria o fondo di riferimento.',
  },
  {
    title: 'Verifica la documentazione',
    text: 'La segreteria ti aiuta a capire quali documenti amministrativi possono essere utili in base alle regole previste dal tuo piano.',
  },
  {
    title: 'Richiedi il rimborso',
    text: 'Dopo la prestazione potrai presentare la documentazione al tuo ente secondo le modalità stabilite dalla tua copertura sanitaria.',
  },
];
---

{page.path === '/' ? (
  <ScrapedHome />
) : page.path === '/video/' ? (
  <>
    <section class="page-hero">
      <div class="container">
        <p class="eyebrow">{site.name}</p>
        <h1>{cleanHeading(pageTitle)}</h1>
        {page.description && <p>{page.description}</p>}
      </div>
    </section>

    <SectionBand eyebrow="Video" title="Scopri il nostro studio dentistico!" lead="Guarda i contenuti video dello Studio Dentistico Federzoni Granata e approfondisci tecnologie, trattamenti e casi clinici.">
      {videoIntroHtml && <div class="rich-text container-narrow" set:html={videoIntroHtml} />}
      <div class="youtube-channel-card">
        <div>
          <p class="eyebrow">YouTube</p>
          <h2>{videoChannelTitle}</h2>
          {videoLeadHtml && <div class="rich-text" set:html={videoLeadHtml} />}
        </div>
        <a class="button button-outline" href="https://www.youtube.com/channel/UCO-D1kTMKZIFAE2oT6maghg/" target="_blank" rel="noopener noreferrer">Apri il canale</a>
      </div>
    </SectionBand>

    <SectionBand eyebrow="Canale YouTube" title="Video dello studio" tone="cream">
      <div class="video-grid">
        {videoItems.map((video) => (
          <article class="video-card">
            <div class="video-frame">
              <iframe
                src={`https://www.youtube-nocookie.com/embed/${video.id}`}
                title={video.title}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              />
            </div>
            <div class="video-card-body">
              <h3>{video.title}</h3>
              <p>{video.description}</p>
              <a href={`https://www.youtube.com/watch?v=${video.id}`} target="_blank" rel="noopener noreferrer">Guarda su YouTube</a>
            </div>
          </article>
        ))}
      </div>
    </SectionBand>

    <SectionBand eyebrow="Casi Clinici" title="Categorie cliniche">
      <FeatureCards items={clinicalItems} numbered />
    </SectionBand>
  </>
) : page.path === '/faq/' ? (
  <>
    <section class="faq-accordion-section" aria-labelledby="faq-accordion-title">
      <div class="container faq-accordion-wrap">
        <header class="faq-accordion-head">
          <p class="eyebrow">Domande frequenti</p>
          <h2 id="faq-accordion-title">Risposte rapide prima della visita</h2>
        </header>

        <div class="faq-accordion-list">
          {faqItems.map((item) => (
            <details class="faq-accordion-item">
              <summary>
                <span>{item.question}</span>
                <i aria-hidden="true"></i>
              </summary>
              <div class="faq-accordion-answer">
                <p>{item.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  </>
) : page.path === '/urgenze/' ? (
  <>
    <section class="emergency-hero" aria-labelledby="emergency-title" data-transparent-header-region>
      <div class="emergency-hero-inner">
        <h1 id="emergency-title">Urgenze dentali</h1>
        <p>Dolore, trauma o gonfiore: raccontaci cosa sta succedendo e ti ricontatteremo per la prima disponibilita utile.</p>
      </div>
    </section>

    <figure class="emergency-media">
      <img src={emergencyHeroImage} alt="Visita odontoiatrica nello studio dentistico" loading="eager" />
    </figure>

    <section class="emergency-copy-section" aria-label="Informazioni sulle urgenze dentali">
      <div class="emergency-copy-wrap">
        {emergencyCopy.map((paragraph) => <p>{paragraph}</p>)}
        <div class="emergency-cta">
          <a href="/prenota-urgenza/">Prenota urgenza</a>
        </div>
      </div>
    </section>
  </>
) : page.path === '/convenzioni/' ? (
  <>
    <section class="conventions-hero" aria-labelledby="conventions-title" data-transparent-header-region>
      <div class="conventions-hero-inner">
        <h1 id="conventions-title">Convenzioni</h1>
        <p>Informazioni chiare per usare fondi sanitari, casse e assicurazioni nel tuo percorso odontoiatrico.</p>
      </div>
    </section>

    <figure class="conventions-media">
      <img src={conventionsHeroImage} alt="Sala operativa dello Studio Dentistico Federzoni Granata" loading="eager" />
    </figure>

    <section class="conventions-intro" aria-label="Convenzioni dello studio dentistico">
      <div class="conventions-intro-wrap">
        <p class="eyebrow">Studio Dentistico Federzoni Granata</p>
        <p class="conventions-lead">
          Se hai una copertura sanitaria, un fondo o una cassa assistenziale, lo studio può fornirti la documentazione amministrativa necessaria per presentare la richiesta al tuo ente.
        </p>
        <div class="conventions-copy-grid">
          <p>
            Ogni piano sanitario ha regole, tempi e modalità proprie. Per questo, durante la prenotazione, ti consigliamo di comunicarci il nome del fondo o dell'assicurazione: potremo orientarti sui documenti che lo studio può rilasciare.
          </p>
          <p>
            Il nostro obiettivo è rendere il passaggio semplice e ordinato: visita, preventivo quando necessario, ricevute e indicazioni amministrative vengono gestiti con attenzione, così hai tutto il necessario per procedere con serenità.
          </p>
        </div>
      </div>
    </section>

    <section class="conventions-process" aria-labelledby="conventions-process-title">
      <div class="conventions-process-wrap">
        <div class="conventions-process-head">
          <p class="eyebrow">Come funziona</p>
          <h2 id="conventions-process-title">Un percorso semplice, dalla prenotazione alla richiesta</h2>
        </div>
        <div class="conventions-step-grid">
          {conventionsSteps.map((item, index) => (
            <article class="conventions-step">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="conventions-final-cta" aria-labelledby="conventions-cta-title">
      <div class="conventions-final-cta-inner">
        <div>
          <p class="eyebrow">Prenotazione</p>
          <h2 id="conventions-cta-title">Vuoi informazioni sulla tua convenzione?</h2>
          <p>Compila il modulo di prenotazione e indica il tuo fondo, la tua cassa sanitaria o la tua assicurazione: ti ricontatteremo per organizzare la visita e darti le indicazioni utili.</p>
        </div>
        <a class="button button-primary" href="/richiesta/">Vai al modulo di prenotazione</a>
      </div>
    </section>
  </>
) : page.path === '/estetica/' ? (
  <>
    <section class="aesthetic-hero" aria-labelledby="aesthetic-title" data-transparent-header-region>
      <div class="aesthetic-hero-inner">
        <h1 id="aesthetic-title">Estetica dentale</h1>
        {page.description && <p>{page.description}</p>}
      </div>
    </section>

    <figure class="aesthetic-hero-media">
      <img src={aestheticHeroImage} alt="Paziente durante una visita di estetica dentale" loading="eager" />
    </figure>

    <section class="aesthetic-content-section" aria-label="Contenuto della pagina Estetica">
      <div class="aesthetic-content-wrap">
        <div class="aesthetic-content-body">
          {bodyBlocks.map((block) => {
            if (block.type === 'heading') {
              const Tag = `h${Math.min(Math.max(block.level, 1), 6)}`;
              return <Tag id={block.id}>{cleanHeading(block.text)}</Tag>;
            }
            if (block.type === 'paragraph') return <Fragment set:html={block.html} />;
            if (block.type === 'list') return <Fragment set:html={block.html} />;
            if (block.type === 'html') return <div set:html={block.html} />;
            if (block.type === 'image') {
              return (
                <figure class="aesthetic-case-figure">
                  <img src={block.src} alt={block.alt} loading="lazy" />
                  {block.alt && <figcaption>{block.alt}</figcaption>}
                </figure>
              );
            }
            if (block.type === 'embed') {
              return (
                <div class="content-embed">
                  <p>Contenuto esterno</p>
                  <a class="button" href={block.url} target="_blank" rel="noopener noreferrer">{block.label}</a>
                </div>
              );
            }
          })}
        </div>
      </div>
    </section>
  </>
) : (
  <>
    <section class="page-hero" data-treatment-sticky-hero={page.kind === 'treatment' ? '' : undefined}>
      <div class="container">
        <p class="eyebrow">{page.kind === 'article' ? 'Approfondimenti' : site.name}</p>
        <h1>{cleanHeading(pageTitle)}</h1>
        {page.description && <p>{page.description}</p>}
      </div>
    </section>

    <section class="section">
      <div class="container content-shell">
        <div class="content-body">
          {bodyBlocks.map((block) => {
            if (block.type === 'heading') {
              const Tag = `h${Math.min(Math.max(block.level, 1), 6)}`;
              return <Tag id={block.id}>{cleanHeading(block.text)}</Tag>;
            }
            if (block.type === 'paragraph') return <Fragment set:html={block.html} />;
            if (block.type === 'list') return <Fragment set:html={block.html} />;
            if (block.type === 'html') return <div set:html={block.html} />;
            if (block.type === 'image') {
              return (
                <figure class="content-figure">
                  <img src={block.src} alt={block.alt} loading="lazy" />
                  {block.alt && <figcaption>{block.alt}</figcaption>}
                </figure>
              );
            }
            if (block.type === 'embed') {
              return (
                <div class="content-embed">
                  <p>Contenuto esterno</p>
                  <a class="button" href={block.url} target="_blank" rel="noopener noreferrer">{block.label}</a>
                </div>
              );
            }
          })}

          {page.kind === 'clinical' && (
            <div class="link-grid" aria-label="Altre categorie cliniche">
              {site.clinicalLinks.filter((item) => item.href !== page.path).map((item) => <a class="link-card" href={item.href}>{item.label}<span aria-hidden="true">→</span></a>)}
            </div>
          )}

          {page.hasContactForm && <ContactForm />}
        </div>
      </div>
    </section>

    {page.kind === 'treatment' && <TreatmentStickyCta treatment={cleanHeading(pageTitle)} />}
  </>
)}

<style>
  .aesthetic-hero {
    min-height: clamp(560px, 68vh, 810px);
    display: grid;
    place-items: center;
    padding: 118px 0 100px;
    background: var(--blue-dark);
    color: #fff;
    text-align: center;
  }

  .aesthetic-hero-inner {
    width: min(1700px, calc(100% - 56px));
    margin: 0 auto;
  }

  .aesthetic-hero h1 {
    max-width: 1260px;
    margin: 0 auto;
    color: #fff;
    font-family: "Inter", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 7rem;
    font-weight: 400;
    letter-spacing: 0;
    line-height: 0.88;
    text-transform: uppercase;
    text-wrap: balance;
  }

  .aesthetic-hero p {
    max-width: 980px;
    margin: 38px auto 0;
    color: var(--aqua);
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.18;
  }

  .aesthetic-hero-media {
    height: clamp(420px, 52vw, 780px);
    margin: 0;
    overflow: hidden;
    background: #eef3f6;
  }

  .aesthetic-hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 48%;
  }

  .aesthetic-content-section {
    padding: 108px 0 122px;
    background: #fff;
  }

  .aesthetic-content-wrap {
    width: min(1240px, calc(100% - 56px));
    margin: 0 auto;
  }

  .aesthetic-content-body {
    color: #263f44;
    font-size: 1.12rem;
    line-height: 1.62;
  }

  :global(.aesthetic-content-body > p:first-child) {
    max-width: 1120px;
    margin: 0 0 88px;
    color: var(--blue-dark);
    font-family: "Inter", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 4.45rem;
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: 0;
  }

  :global(.aesthetic-content-body p) {
    margin: 0 0 22px;
  }

  .aesthetic-content-body h2,
  .aesthetic-content-body h3 {
    margin: 78px 0 24px;
    color: var(--blue-dark);
    font-size: 2.25rem;
    line-height: 1.05;
  }

  .aesthetic-content-body h3:first-of-type {
    margin-top: 0;
  }

  .aesthetic-case-figure {
    margin: 0 0 74px;
    overflow: hidden;
    border-radius: 8px;
    background: #f5f7f8;
    box-shadow: 0 18px 48px rgba(36, 48, 51, 0.12);
  }

  .aesthetic-case-figure img {
    width: 100%;
    max-height: 780px;
    object-fit: cover;
  }

  .aesthetic-case-figure figcaption {
    padding: 14px 18px;
    background: #fff;
    color: #657479;
    font-size: 0.92rem;
    font-weight: 800;
    line-height: 1.35;
  }

  :global(.aesthetic-content-body > ul:last-child) {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
    margin: 24px 0 0;
    padding: 0;
    list-style: none;
  }

  :global(.aesthetic-content-body > ul:last-child li) {
    margin: 0;
  }

  :global(.aesthetic-content-body > ul:last-child a) {
    min-height: 82px;
    display: flex;
    align-items: center;
    border-left: 6px solid var(--blue-dark);
    border-radius: 8px;
    padding: 18px;
    background: #f5f7f8;
    color: var(--blue-dark);
    font-weight: 900;
    line-height: 1.25;
    text-decoration: none;
    transition: background-color 160ms ease, color 160ms ease, transform 160ms ease;
  }

  :global(.aesthetic-content-body > ul:last-child a:hover) {
    background: #e9f8f7;
    color: var(--blue);
    transform: translateY(-2px);
  }

  .conventions-hero {
    min-height: clamp(560px, 70vh, 800px);
    display: grid;
    place-items: center;
    padding: clamp(88px, 9vw, 154px) 0 clamp(76px, 8vw, 132px);
    background: #10283d;
    color: #fff;
    text-align: center;
  }

  .conventions-hero-inner {
    width: min(1680px, calc(100% - 48px));
    margin: 0 auto;
  }

  .conventions-hero h1 {
    margin: 0;
    color: #fff;
    font-family: "Inter", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: clamp(4.2rem, 11vw, 12.4rem);
    font-weight: 400;
    letter-spacing: 0;
    line-height: 0.9;
    text-transform: uppercase;
  }

  .conventions-hero p {
    max-width: 940px;
    margin: clamp(30px, 3.4vw, 52px) auto 0;
    color: #d6eef3;
    font-size: clamp(1.35rem, 2vw, 2.05rem);
    font-weight: 700;
    line-height: 1.18;
  }

  .conventions-media {
    height: clamp(390px, 50vw, 780px);
    margin: 0;
    overflow: hidden;
    background: #e9eef1;
  }

  .conventions-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 50%;
  }

  .conventions-intro {
    padding: clamp(84px, 9vw, 150px) 0;
    background: #fff;
  }

  .conventions-intro-wrap,
  .conventions-process-wrap,
  .conventions-final-cta-inner {
    width: min(1320px, calc(100% - 48px));
    margin: 0 auto;
  }

  .conventions-lead {
    max-width: 1210px;
    margin: 0;
    color: var(--blue-dark);
    font-family: "Inter", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: clamp(2.15rem, 4.3vw, 5.35rem);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .conventions-copy-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(28px, 5vw, 80px);
    margin-top: clamp(42px, 6vw, 86px);
  }

  .conventions-copy-grid p {
    margin: 0;
    color: #3d4f56;
    font-size: clamp(1.05rem, 1.35vw, 1.34rem);
    line-height: 1.55;
  }

  .conventions-process {
    padding: clamp(76px, 8vw, 132px) 0;
    background: var(--soft);
  }

  .conventions-process-head {
    max-width: 840px;
    margin-bottom: clamp(34px, 4vw, 58px);
  }

  .conventions-process-head h2 {
    margin: 0;
    color: var(--blue-dark);
    font-size: clamp(2.35rem, 4.8vw, 5rem);
    line-height: 0.98;
  }

  .conventions-step-grid {
