const clinicalShowcaseKeepsParagraphs = new Set([
  '/protesi/',
  '/parodontologia/',
  '/implantologia/',
  '/ortodonzia/',
  '/conservativa/',
  '/endodonzia/',
]).has(page.path);
const clinicalShowcaseBodyBlocks = bodyBlocks.filter((block) => {
  if (!clinicalShowcase) return true;
  if (block.type === 'heading' && cleanHeading(block.text) === 'Casi Clinici') return false;
  if (block.type === 'paragraph' && !clinicalShowcaseKeepsParagraphs) return false;

  const isClinicalLinkList =
    block.type === 'list' &&
    block.html.includes('/protesi/') &&
    block.html.includes('/implantologia/') &&
    block.html.includes('/video/');

  return !isClinicalLinkList;
});
type ClinicalMediaGroup = {
  label: string;
  notes: SiteParagraphBlock[];
  images: Extract<SiteBlock, { type: 'image' }>[];
};

type ClinicalRenderItem =
  | { type: 'block'; block: SiteBlock }
  | { type: 'mediaGrid'; groups: ClinicalMediaGroup[] };

const buildClinicalRenderItems = (blocks: SiteBlock[]): ClinicalRenderItem[] => {
  const items: ClinicalRenderItem[] = [];
  let index = 0;

  while (index < blocks.length) {
    const block = blocks[index];

    if (block.type === 'heading' && block.level >= 4) {
      const groups: ClinicalMediaGroup[] = [];

      const flushGroups = () => {
        if (groups.length === 0) return;
        items.push({ type: 'mediaGrid', groups: [...groups] });
        groups.length = 0;
      };

      while (index < blocks.length) {
        const labelBlock = blocks[index];
        if (labelBlock.type !== 'heading' || labelBlock.level < 4) break;

        const label = cleanHeading(labelBlock.text);
        const notes: SiteParagraphBlock[] = [];
        const images: Extract<SiteBlock, { type: 'image' }>[] = [];
        index += 1;

        while (index < blocks.length && blocks[index].type !== 'heading') {
          if (blocks[index].type === 'paragraph') {
            notes.push(blocks[index] as SiteParagraphBlock);
          }
          if (blocks[index].type === 'image') {
            images.push(blocks[index] as Extract<SiteBlock, { type: 'image' }>);
          }
          index += 1;
        }

        if (notes.length > 0 || images.length > 0) {
          groups.push({ label, notes, images });
        } else {
          flushGroups();
          items.push({ type: 'block', block: labelBlock });
        }
      }

      flushGroups();
      continue;
    }

    items.push({ type: 'block', block });
    index += 1;
  }

  return items;
};

const clinicalShowcaseRenderItems = buildClinicalRenderItems(clinicalShowcaseBodyBlocks);

