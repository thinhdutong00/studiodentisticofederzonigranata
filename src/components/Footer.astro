---
import { site } from '../data/site';
---

<footer class="site-footer">
  <div class="container footer-inner">
    <section>
      <h2>{site.name}</h2>
      <p>{site.description}</p>
      <p>{site.footerNote}</p>
      <p><a href="/privacy-policy/">Privacy Policy</a> · <a href="/cookie-privacy/">Cookie Policy</a></p>
    </section>
    {site.offices.map((office) => (
      <section>
        <h3>{office.title}</h3>
        <p>{office.address}</p>
        <p><a href={office.phoneHref}>{office.phone}</a></p>
        <p><a href={office.emailHref}>{office.email}</a></p>
        <p>{office.hours}</p>
      </section>
    ))}
  </div>
  <div class="footer-bottom">
    <div class="container">© {new Date().getFullYear()} {site.name}</div>
  </div>
</footer>
