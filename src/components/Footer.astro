---
import { site } from '../data/site';

const footerColumns = [
  {
    title: 'Prenota',
    links: [
      { label: 'Prima visita', href: '/prima-visita/' },
      { label: 'Trattamenti', href: '/trattamenti/' },
      { label: 'Urgenze', href: '/urgenze/' },
      { label: 'Prenota visita', href: '/richiesta/' },
    ],
  },
  {
    title: 'Trattamenti',
    links: [
      { label: 'Igiene e prevenzione', href: '/igiene-orale-prevenzione/' },
      { label: 'Ortodonzia', href: '/ortodonzia-allineatori-invisibili/' },
      { label: 'Implantologia', href: '/implantologia-tradizionale-computer-guidata/' },
      { label: 'Parodontologia', href: '/parodontologia-cure-gengivali/' },
    ],
  },
  {
    title: 'Convenzioni e casi',
    links: [
      { label: 'Convenzioni', href: '/convenzioni/' },
      { label: 'Convenzioni dirette', href: '/convenzioni-dirette/' },
      { label: 'Casi clinici', href: '/casi-clinici/' },
      { label: 'Video', href: '/video/' },
    ],
  },
  {
    title: 'Informazioni',
    links: [
      { label: 'Informazioni', href: '/informazioni/' },
      { label: 'Chi siamo', href: '/chi-siamo/' },
      { label: 'Qualità e Tecnologia', href: '/strumentazioni-attrezzature-tecniche/' },
      { label: 'FAQ', href: '/faq/' },
    ],
  },
];
---

<footer class="site-footer">
  <div class="container footer-shell">
    <nav class="footer-menu-grid" aria-label="Navigazione footer">
      {footerColumns.map((column) => (
        <section class="footer-links" aria-labelledby={`footer-${column.title.toLowerCase().replaceAll(' ', '-')}`}>
          <h2 id={`footer-${column.title.toLowerCase().replaceAll(' ', '-')}`}>{column.title}</h2>
          <ul>
            {column.links.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
          </ul>
        </section>
      ))}
    </nav>

    <div class="footer-social-row">
      <section class="footer-social-block" aria-labelledby="footer-social-title">
        <h2 id="footer-social-title">Seguici sui nostri social:</h2>
        <div class="footer-social" aria-label="Canali social">
          {site.social.map((item) => <a href={item.url} target="_blank" rel="noopener noreferrer">{item.label}</a>)}
        </div>
      </section>
      <section class="footer-social-block footer-article-block" aria-labelledby="footer-articles-title">
        <h2 id="footer-articles-title">Scopri i nostri contenuti:</h2>
        <a href="/video/">Video dello studio</a>
      </section>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <span>© {new Date().getFullYear()} {site.name}</span>
      <span>{site.footerNote}</span>
      <span><a href="/privacy-policy/">Privacy Policy</a> · <a href="/cookie-privacy/">Cookie Policy</a></span>
    </div>
  </div>
</footer>
