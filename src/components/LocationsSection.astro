---
import { site } from '../data/site';

const locationOffices = site.offices.map((office) => {
  const query = encodeURIComponent(office.address);
  const slug = office.city
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/\s+/g, '-');

  return {
    ...office,
    slug,
    mapEmbed: `https://www.google.com/maps?q=${query}&output=embed`,
    mapHref: `https://www.google.com/maps/search/?api=1&query=${query}`,
    hoursRows: office.hours.split(';').map((row) => {
      const [label, ...value] = row.split(':');

      return {
        label: label.trim(),
        value: value.join(':').trim(),
        closed: /chiuso/i.test(row),
      };
    }),
  };
});
---

<section class="locations-section" aria-labelledby="locations-title" data-locations-map-section>
  <div class="locations-layout">
    <div class="locations-copy">
      <p class="locations-eyebrow">Sedi e accessibilità</p>
      <h1 id="locations-title">Dove trovarci</h1>

      <div class="location-list">
        {locationOffices.map((office, index) => (
          <article
            class:list={['location-card', index === 0 && 'location-card-open']}
            id={office.slug}
            data-location-card
            data-map-src={office.mapEmbed}
            data-map-title={`Mappa dello studio dentistico di ${office.city}`}
            data-map-city={office.city}
            data-map-address={office.address}
            data-map-href={office.mapHref}>
            <button
              class="location-card-trigger"
              type="button"
              aria-expanded={index === 0 ? 'true' : 'false'}
              aria-controls={`sede-${office.slug}-panel`}>
              <span class="location-card-title">
                <small>Studio dentistico di</small>
                <strong>{office.city}</strong>
              </span>
              <i aria-hidden="true"></i>
            </button>

            <div class="location-card-panel" id={`sede-${office.slug}-panel`} hidden={index !== 0}>
              <div class="location-detail">
                <span>Indirizzo</span>
                <strong>{office.address}</strong>
              </div>

              <div class="location-detail">
                <span>Telefono</span>
                <a href={office.phoneHref}>{office.phone}</a>
              </div>

              <div class="location-detail">
                <span>Email</span>
                <a href={office.emailHref}>{office.email}</a>
              </div>

              <div class="location-hours" aria-label={`Orari ${office.city}`}>
                <p>Orari</p>
                {office.hoursRows.map((row) => (
                  <div class:list={['location-hours-row', row.closed && 'location-hours-row-closed']}>
                    <span>{row.label}</span>
                    <strong>{row.value}</strong>
                  </div>
                ))}
              </div>

              <a class="location-route" href={office.mapHref} target="_blank" rel="noreferrer">
                Apri percorso
                <span aria-hidden="true">↗</span>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="locations-map-stack" aria-label="Mappa dello studio selezionato">
      {locationOffices[0] && (
        <article class="location-map-card" aria-label={`Mappa ${locationOffices[0].city}`}>
          <iframe
            src={locationOffices[0].mapEmbed}
            title={`Mappa dello studio dentistico di ${locationOffices[0].city}`}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            data-location-map></iframe>
          <div class="location-map-caption">
            <strong data-location-map-city>{locationOffices[0].city}</strong>
            <span data-location-map-address>{locationOffices[0].address}</span>
            <a href={locationOffices[0].mapHref} target="_blank" rel="noreferrer" data-location-map-link>Apri su Google Maps</a>
          </div>
        </article>
      )}
    </div>
  </div>
</section>

<script>
  const locationSections = document.querySelectorAll('[data-locations-map-section]');

  locationSections.forEach((section) => {
    const cards = Array.from(section.querySelectorAll('[data-location-card]'));
    const map = section.querySelector('[data-location-map]');
    const mapCity = section.querySelector('[data-location-map-city]');
    const mapAddress = section.querySelector('[data-location-map-address]');
    const mapLink = section.querySelector('[data-location-map-link]');

    const activateCard = (card) => {
      cards.forEach((item) => {
        const isOpen = item === card;
        const button = item.querySelector('.location-card-trigger');
        const panel = item.querySelector('.location-card-panel');

        item.classList.toggle('location-card-open', isOpen);
        button?.setAttribute('aria-expanded', String(isOpen));

        if (panel) {
          panel.hidden = !isOpen;
        }
      });

      if (map instanceof HTMLIFrameElement && card.dataset.mapSrc && map.src !== card.dataset.mapSrc) {
        map.src = card.dataset.mapSrc;
      }

      if (card.dataset.mapTitle) {
        map?.setAttribute('title', card.dataset.mapTitle);
      }

      if (mapCity && card.dataset.mapCity) {
        mapCity.textContent = card.dataset.mapCity;
      }

      if (mapAddress && card.dataset.mapAddress) {
        mapAddress.textContent = card.dataset.mapAddress;
      }

      if (mapLink instanceof HTMLAnchorElement && card.dataset.mapHref) {
        mapLink.href = card.dataset.mapHref;
      }
    };

    cards.forEach((card) => {
      const button = card.querySelector('.location-card-trigger');
      button?.addEventListener('click', () => activateCard(card));
    });
  });
</script>

<style>
  .locations-section {
    background: #f7fbfc;
    color: var(--ink);
    font-family: inherit;
  }

  .locations-layout {
    min-height: 780px;
    display: grid;
    grid-template-columns: minmax(430px, 0.78fr) minmax(0, 1.22fr);
  }

  .locations-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(58px, 5vw, 84px) clamp(34px, 6vw, 104px);
    background: linear-gradient(180deg, #ffffff 0%, #f7fbfc 100%);
  }

  .locations-eyebrow {
    margin: 0 0 18px;
    color: var(--blue);
    font-size: clamp(1rem, 1.1vw, 1.125rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.25;
    text-transform: uppercase;
  }

  .locations-copy h1 {
    max-width: 12ch;
    margin: 0;
    color: var(--blue-dark);
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(2rem, 4.8vw, 4.75rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.05;
  }

  .location-list {
    display: grid;
    gap: 16px;
    margin-top: clamp(34px, 4vw, 52px);
  }

  .location-card {
    position: relative;
    border: 1px solid rgba(52, 124, 194, 0.22);
    border-radius: 8px;
    background: linear-gradient(180deg, #fff 0%, #f7fbff 100%);
    box-shadow: 0 16px 42px rgba(12, 77, 162, 0.08);
    overflow: hidden;
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      box-shadow 180ms ease;
  }

  .location-card::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 5px;
    background: rgba(52, 124, 194, 0.28);
    transition:
      background-color 180ms ease,
      width 180ms ease;
  }

  .location-card-open {
    border-color: rgba(52, 124, 194, 0.52);
    background: #fff;
    box-shadow: 0 24px 58px rgba(12, 77, 162, 0.13);
  }

  .location-card-open::before {
    width: 6px;
    background: var(--blue-dark);
  }

  .location-card-trigger {
    width: 100%;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 38px;
    gap: 18px;
    align-items: center;
    border: 0;
    padding: clamp(22px, 2.4vw, 30px) clamp(22px, 2.4vw, 30px) clamp(22px, 2.4vw, 30px) clamp(26px, 2.7vw, 36px);
    background: transparent;
    color: var(--blue-dark);
    cursor: pointer;
    font: inherit;
    text-align: left;
  }

  .location-card-title {
    min-width: 0;
  }

  .location-card-trigger strong {
    display: block;
    margin-top: 5px;
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(1.25rem, 1.55vw, 1.75rem);
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1.08;
  }

  .location-card-trigger small {
    display: block;
    color: #347cc2;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.13em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .location-card-trigger i {
    position: relative;
    width: 38px;
    height: 38px;
    justify-self: end;
    border: 1px solid rgba(52, 124, 194, 0.3);
    border-radius: 999px;
    background: #fff;
    color: #347cc2;
    transition:
      background-color 180ms ease,
      border-color 180ms ease,
      color 180ms ease;
  }

  .location-card-trigger i::after {
    content: "";
    position: absolute;
    inset: 50% auto auto 50%;
    width: 9px;
    height: 9px;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: translate(-50%, -62%) rotate(45deg);
    transition: transform 180ms ease;
  }

  .location-card-open .location-card-trigger {
    border-bottom: 1px solid rgba(52, 124, 194, 0.18);
    background: linear-gradient(90deg, rgba(237, 247, 255, 0.95), rgba(255, 255, 255, 0));
    color: var(--blue-dark);
  }

  .location-card-open .location-card-trigger small {
    color: #347cc2;
  }

  .location-card-open .location-card-trigger i {
    border-color: #347cc2;
    background: #347cc2;
    color: #fff;
  }

  .location-card-open .location-card-trigger i::after {
    transform: translate(-50%, -35%) rotate(225deg);
  }

  .location-card-panel {
    display: grid;
    gap: 18px;
    padding: clamp(18px, 1.8vw, 24px) clamp(22px, 2.4vw, 30px) clamp(22px, 2.4vw, 30px) clamp(26px, 2.7vw, 36px);
  }

  .location-card-panel[hidden] {
    display: none;
  }

  .location-detail {
    display: grid;
    gap: 5px;
  }

  .location-detail span,
  .location-hours p {
    margin: 0;
    color: #347cc2;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .location-detail strong,
  .location-detail a {
    color: #24313a;
    font-size: 1rem;
    font-weight: 800;
    line-height: 1.45;
  }

  .location-detail a {
    width: fit-content;
    text-decoration: none;
  }

  .location-detail a:hover {
    color: var(--blue);
  }

  .location-hours {
    display: grid;
    gap: 10px;
    border-top: 1px solid rgba(52, 124, 194, 0.16);
    padding-top: 18px;
  }

  .location-hours-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 22px;
    color: #24313a;
    font-size: 0.96rem;
    line-height: 1.3;
  }

  .location-hours-row span {
    color: var(--muted);
    font-weight: 800;
  }

  .location-hours-row strong {
    color: var(--blue-dark);
    font-weight: 900;
    text-align: right;
  }

  .location-hours-row-closed strong {
    color: #c54a4a;
  }

  .location-route {
    width: fit-content;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    border: 1px solid rgba(52, 124, 194, 0.28);
    border-radius: 999px;
    padding: 10px 15px;
    color: var(--blue-dark);
    font-weight: 900;
    text-decoration: none;
  }

  .location-route:hover {
    border-color: #347cc2;
    background: rgba(52, 124, 194, 0.09);
    color: #347cc2;
  }

  .locations-map-stack {
    min-height: 780px;
    display: block;
    background: var(--blue-dark);
  }

  .location-map-card {
    position: relative;
    min-height: 780px;
    height: 100%;
    margin: 0;
    overflow: hidden;
    border-left: 1px solid rgba(21, 90, 148, 0.12);
    isolation: isolate;
  }

  .location-map-card iframe {
    position: absolute;
    top: -120px;
    right: 0;
    bottom: 0;
    left: 0;
    width: 100%;
    height: calc(100% + 120px);
    border: 0;
    filter: saturate(0.9) contrast(0.98);
  }

  .location-map-caption {
    position: absolute;
    top: clamp(18px, 2.5vw, 34px);
    right: clamp(18px, 2.5vw, 34px);
    z-index: 1;
    max-width: min(420px, calc(100% - 36px));
    display: grid;
    gap: 4px;
    border-radius: 8px;
    padding: 16px 18px;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 14px 36px rgba(32, 54, 72, 0.16);
  }

  .location-map-caption strong {
    color: var(--blue-dark);
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: 0;
  }

  .location-map-caption span {
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.35;
  }

  .location-map-caption a {
    width: fit-content;
    margin-top: 6px;
    color: var(--blue-dark);
    font-size: 0.9rem;
    font-weight: 900;
    text-decoration: none;
  }

  @media (max-width: 1160px) {
    .locations-layout {
      grid-template-columns: 1fr;
    }

    .locations-layout,
    .locations-map-stack {
      min-height: auto;
    }

    .location-map-card {
      min-height: 420px;
      border-left: 0;
    }
  }

  @media (max-width: 720px) {
    .locations-copy {
      padding: 58px 24px;
    }

    .locations-copy h1 {
      font-size: clamp(2.8rem, 13vw, 4.4rem);
    }

    .location-card-trigger {
      grid-template-columns: minmax(0, 1fr) 34px;
      gap: 14px;
      padding: 22px 20px 22px 26px;
    }

    .location-card-trigger i {
      width: 34px;
      height: 34px;
    }

    .location-card-panel {
      padding: 18px 20px 22px 26px;
    }

    .location-hours-row {
      display: grid;
      gap: 4px;
    }

    .location-hours-row strong {
      text-align: left;
    }

    .location-map-card {
      min-height: 360px;
    }
  }
</style>
