---
import { site } from '../data/site';

interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;

const beforeTreatment = [
  { label: 'prima visita', href: '/prima-visita/' },
];

const afterTreatment = [
  { label: 'urgenze', href: '/urgenze/' },
];

const slugFromHref = (href: string) => href.replaceAll('/', '') || 'pagina';

const treatmentOrder = [
  'Igiene orale e Prevenzione',
  'Sbiancamento',
  'Conservativa (otturazioni)',
  'Endodonzia (devitalizzazioni)',
  'Pedodonzia (odontoiatria infantile)',
  'Ortodonzia e Allineatori invisibili (adulti e bimbi)',
  'Estetica diretta (faccette in composito)',
  'Parodontologia (cure gengivali)',
  'Protesi fissa e mobile',
  'Estetica Indiretta (faccette in porcellana)',
  'Chirurgia Stomatologica',
  'Implantologia tradizionale e computer guidata',
  'Gnatologia (disturbi articolazione temporo-mandibolare)',
  'Dispositivi contro il russamento e le apnee notturne',
];

const treatmentMenuLabels: Record<string, string> = {
  'Estetica diretta (faccette in composito)': 'Faccette in composito',
  'Estetica Indiretta (faccette in porcellana)': 'Faccette in ceramica',
};

const treatmentCategoryLabels: Record<string, string> = {
  'Prevenzione ed estetica': 'Estetica e prevenzione',
};

const treatmentMenu = site.treatmentMenu;
const treatmentGroups = treatmentMenu.map((category) => ({
  ...category,
  label: treatmentCategoryLabels[category.label] || category.label,
  items: [...category.items]
    .sort((a, b) => treatmentOrder.indexOf(a.label) - treatmentOrder.indexOf(b.label))
    .map((item) => ({
      ...item,
      menuLabel: treatmentMenuLabels[item.label] || item.label,
    })),
}));
const treatmentGroupColumns = [
  treatmentGroups.filter((_, index) => index % 2 === 0),
  treatmentGroups.filter((_, index) => index % 2 === 1),
];
const menuImages = [
  '/assets/placeholders/trattamenti-prevenzione.svg',
  '/assets/placeholders/trattamenti-cure.svg',
  '/assets/placeholders/trattamenti-ortodonzia.svg',
  '/assets/placeholders/trattamenti-chirurgia.svg',
];

const menuImageOverrides: Record<string, { image: string; imageAlt: string; imagePosition?: string; imageVariant?: 'square' }> = {
  Estetica: {
    image: '/assets/menu/casi-clinici-estetica.jpg',
    imageAlt: 'Donna che sorride allo specchio durante una visita estetica',
    imagePosition: '45% 52%',
  },
  Protesi: {
    image: '/assets/menu/casi-clinici-protesi.png',
    imageAlt: 'Progettazione digitale di una protesi dentale al computer',
    imagePosition: '54% 50%',
  },
  Parodontologia: {
    image: '/assets/menu/casi-clinici-parodontologia.png',
    imageAlt: 'Controllo parodontale su gengive e denti',
    imagePosition: '54% 48%',
  },
  Implantologia: {
    image: '/assets/menu/casi-clinici-implantologia.png',
    imageAlt: 'Impianto dentale con corona e gengiva',
    imagePosition: '50% 52%',
  },
  Ortodonzia: {
    image: '/assets/menu/casi-clinici-ortodonzia.png',
    imageAlt: 'Allineatore trasparente applicato sul sorriso',
    imagePosition: '52% 50%',
  },
  Conservativa: {
    image: '/assets/menu/casi-clinici-conservativa.png',
    imageAlt: 'Restauro conservativo su molare',
    imagePosition: '52% 48%',
  },
  Endodonzia: {
    image: '/assets/menu/casi-clinici-endodonzia.png',
    imageAlt: 'Trattamento endodontico su sezione di dente',
    imagePosition: '50% 48%',
  },
  Video: {
    image: '/assets/menu/casi-clinici-video.jpg',
    imageAlt: 'Equipe odontoiatrica durante una procedura clinica',
    imagePosition: '48% 45%',
  },
  'Chi siamo': {
    image: '/assets/original/2021/02/HOME.jpg',
    imageAlt: 'Studio Dentistico Federzoni Granata',
    imagePosition: '50% 50%',
  },
  'Qualità e Tecnologia': {
    image: '/assets/menu/qualita-tecnologia.jpg',
    imageAlt: 'Paziente durante una scansione radiografica digitale',
    imagePosition: '50% 18%',
    imageVariant: 'square',
  },
  'Orari e sedi': {
    image: '/assets/original/2022/05/dentista-reggio-emilia-modena-3.jpg',
    imageAlt: 'Studi dentistici di Modena e Reggio Emilia',
    imagePosition: '50% 50%',
  },
  Convenzioni: {
    image: '/assets/menu/convenzioni-studio.jpg',
    imageAlt: 'Sala operativa dello Studio Dentistico Federzoni Granata',
    imagePosition: '50% 50%',
  },
  FAQ: {
    image: '/assets/menu/faq.jpg',
    imageAlt: 'Dentista che spiega l’igiene orale a una bambina',
    imagePosition: '50% 46%',
  },
};

const detailDescriptions: Record<string, string> = {
  Convenzioni: 'Informazioni sulle convenzioni e sulla documentazione utile per richiedere eventuali rimborsi al proprio fondo, ente o assicurazione.',
  Estetica: 'Raccolta di casi dedicati all’armonia del sorriso, al colore, alla forma e alla naturalezza del risultato finale.',
  Protesi: 'Esempi di riabilitazioni protesiche fisse e mobili, pensate per recuperare funzione masticatoria, stabilità ed estetica.',
  Parodontologia: 'Casi legati alla salute delle gengive e dei tessuti di sostegno, con percorsi per stabilizzare e proteggere il sorriso.',
  Implantologia: 'Percorsi clinici con impianti dentali, dalla progettazione alla riabilitazione, anche con approccio digitale guidato.',
  Ortodonzia: 'Casi di allineamento dentale e correzione funzionale per adulti e bambini, con apparecchi tradizionali o allineatori.',
  Conservativa: 'Interventi dedicati al recupero dei denti naturali tramite restauri, otturazioni e ricostruzioni conservative.',
  Endodonzia: 'Casi di cura canalare e salvataggio del dente, quando la polpa dentale è compromessa da carie profonde o traumi.',
  Video: 'Contenuti video e materiali visuali per osservare più da vicino percorsi, risultati e dettagli dei trattamenti eseguiti.',
  'Chi siamo': 'Una panoramica sullo studio, sul metodo di lavoro e sull’approccio con cui accompagniamo adulti e bambini nei percorsi odontoiatrici.',
  'Qualità e Tecnologia': 'Approfondimento sulle tecnologie, sulle attrezzature e sugli strumenti digitali utilizzati per diagnosi, cura e pianificazione.',
  'Orari e sedi': 'Dettagli pratici su sedi, recapiti, orari di apertura e modalità per raggiungere lo studio di Modena e quello di Reggio Emilia.',
  FAQ: 'Risposte alle domande più frequenti su visite, trattamenti, appuntamenti, urgenze e organizzazione dello studio.',
};

const itemCategory = (item: { label: string; href: string }, index: number, imageAltPrefix: string) => {
  const imageOverride = menuImageOverrides[item.label];

  return {
    id: slugFromHref(item.href),
    label: item.label,
    description: detailDescriptions[item.label] || 'Pagina dedicata',
    image: imageOverride?.image || menuImages[index % menuImages.length],
    imageAlt: imageOverride?.imageAlt || `${imageAltPrefix} ${item.label}`,
    imagePosition: imageOverride?.imagePosition,
    imageVariant: imageOverride?.imageVariant,
    items: [{ ...item, description: 'Pagina dedicata' }],
  };
};

const secondaryMenus = [
  {
    id: 'clinical',
    title: 'Casi clinici',
    triggerLabel: 'casi clinici',
    href: '/casi-clinici/',
    panelId: 'clinical-sub-menu',
    tabLabel: 'Categorie casi clinici',
    kicker: 'Casi clinici',
    categories: site.clinicalLinks.map((item, index) => itemCategory(item, index, 'Segnaposto casi clinici')),
  },
  {
    id: 'information',
    title: 'Informazioni',
    triggerLabel: 'informazioni',
    href: '/informazioni/',
    panelId: 'information-sub-menu',
    tabLabel: 'Categorie informazioni',
    kicker: 'Informazioni',
    categories: [
      { label: 'Chi siamo', href: '/chi-siamo/' },
      { label: 'Qualità e Tecnologia', href: '/strumentazioni-attrezzature-tecniche/' },
      { label: 'Orari e sedi', href: '/orari-e-sedi/' },
      { label: 'Convenzioni', href: '/convenzioni/' },
      { label: 'FAQ', href: '/faq/' },
    ].map((item, index) => itemCategory(item, index, 'Segnaposto informazioni')),
  },
];

const callOptions = site.offices.map((office) => ({
  city: office.city,
  phone: office.phone,
  phoneHref: office.phoneHref,
}));

const siteMenuTreatments = treatmentGroups.flatMap((category) => category.items.map((item) => ({
  label: item.menuLabel,
  href: item.href,
})));

const siteMenuInformation = [
  { label: 'Chi siamo', href: '/chi-siamo/' },
  { label: 'Qualità e Tecnologia', href: '/strumentazioni-attrezzature-tecniche/' },
  { label: 'Orari e sedi', href: '/orari-e-sedi/' },
  { label: 'Convenzioni', href: '/convenzioni/' },
  { label: 'FAQ', href: '/faq/' },
];
---

<header class:list={['site-header', transparent && 'site-header-overlay', transparent && 'is-over-hero']} data-overlay-header={transparent ? 'true' : undefined} data-site-menu-root>
  <div class="container header-inner">
    <a class="brand" href="/" aria-label={site.name}>
      <img src={site.logo} alt="Studio dentistico Federzoni Granata" width="400" height="52" />
    </a>
    <nav id="primary-navigation" class="primary-nav" aria-label="Navigazione principale">
      {beforeTreatment.map((item) => <a class="primary-nav-link" href={item.href}>{item.label}</a>)}
      {secondaryMenus.slice(0, 1).map((navMenu) => (
        <div class="nav-mega" data-mega-menu data-menu-title={navMenu.title}>
          <a
            class="primary-nav-link primary-nav-trigger"
            href={navMenu.href}
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls={navMenu.panelId}
            data-mega-trigger
          >
            {navMenu.triggerLabel}
            <span class="nav-caret" aria-hidden="true"></span>
          </a>
          <div class="mobile-drilldown-bar">
            <button class="mobile-menu-back" type="button" data-mobile-menu-back>
              <span aria-hidden="true">‹</span>
              Menu principale
            </button>
            <h2 class="mobile-drilldown-title" data-mobile-drilldown-title>{navMenu.title}</h2>
          </div>
          <div id={navMenu.panelId} class="mega-menu" data-mega-panel>
            <div class="mega-menu-tabs" role="tablist" aria-label={navMenu.tabLabel}>
              {navMenu.categories.map((category, index) => (
                <a
                  id={`${navMenu.id}-tab-${category.id}`}
                  class:list={['mega-tab', 'mega-tab-link', index === 0 && 'is-active']}
                  href={category.items[0].href}
                  role="tab"
                  aria-selected={index === 0 ? 'true' : 'false'}
                  aria-controls={`${navMenu.id}-panel-${category.id}`}
                  tabindex={index === 0 ? '0' : '-1'}
                  data-treatment-tab
                  data-target={`${navMenu.id}-panel-${category.id}`}
                >
                  <span class="mega-tab-label">{category.label}</span>
                  <span class="mega-tab-count">Vai alla pagina <span aria-hidden="true">↗</span></span>
                </a>
              ))}
            </div>
            <div class="mega-menu-content">
              {navMenu.categories.map((category, index) => (
                <section
                  id={`${navMenu.id}-panel-${category.id}`}
                  class:list={['mega-menu-panel', 'mega-menu-panel-detail', index === 0 && 'is-active']}
                  role="tabpanel"
                  aria-labelledby={`${navMenu.id}-tab-${category.id}`}
                  hidden={index !== 0}
                  data-treatment-panel
                >
                  <div class="detail-menu-copy">
                    <p class="detail-menu-kicker">{navMenu.kicker}</p>
                    <h3>{category.label}</h3>
                    <p>{category.description}</p>
                    <a class="detail-menu-cta" href={category.items[0].href}>Vai alla pagina <span aria-hidden="true">↗</span></a>
                  </div>
                  <aside
                    class:list={[
                      'mega-feature',
                      'mega-feature-image-only',
                      category.imageVariant === 'square' && 'mega-feature-image-square',
                    ]}
                    aria-label={`Immagine ${category.label}`}
                  >
                    <img
                      src={category.image}
                      alt={category.imageAlt}
                      loading="lazy"
                      style={category.imagePosition ? `object-position: ${category.imagePosition};` : undefined}
                    />
                  </aside>
                </section>
              ))}
            </div>
          </div>
        </div>
      ))}
      {afterTreatment.map((item) => <a class="primary-nav-link" href={item.href}>{item.label}</a>)}
    </nav>
    <div class="header-actions">
      <details class="call-dropdown header-call-dropdown" data-call-dropdown>
        <summary class="button button-small call-dropdown-trigger header-call-trigger">
          Chiama lo studio
          <span class="call-dropdown-caret" aria-hidden="true"></span>
        </summary>
        <div class="call-dropdown-menu" role="list">
          {callOptions.map((office) => (
            <a class="call-dropdown-link" href={office.phoneHref}>
              <span>Studio {office.city}</span>
              <strong>{office.phone}</strong>
            </a>
          ))}
        </div>
      </details>
      <a class="button button-small header-cta" href="/richiesta/">Prenota visita <span aria-hidden="true">↗</span></a>
    </div>
    <button
      class="site-menu-trigger"
      type="button"
      aria-label="Apri menu"
      aria-expanded="false"
      aria-controls="site-menu-panel"
      data-site-menu-trigger
    >
      <span class="site-menu-icon" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
      <span class="site-menu-trigger-label">Menu</span>
    </button>
  </div>
  <div class="site-menu-backdrop" data-site-menu-close></div>
  <aside id="site-menu-panel" class="site-menu-panel" aria-label="Menu principale" aria-hidden="true" data-site-menu-panel>
    <button class="site-menu-close" type="button" data-site-menu-close>
      <span aria-hidden="true">×</span>
      Chiudi
    </button>
    <div class="site-menu-scroll">
      <section class="site-menu-section" aria-labelledby="site-menu-treatments">
        <h2 id="site-menu-treatments">Trattamenti</h2>
        <div class="site-menu-links">
          {siteMenuTreatments.map((item) => (
                <a href={item.href}>{item.label} <span class="site-menu-link-arrow" aria-hidden="true">→</span></a>
          ))}
        </div>
        <a class="site-menu-all-link" href="/trattamenti/">Tutti i trattamenti <span aria-hidden="true">↗</span></a>
      </section>
      <section class="site-menu-section" aria-labelledby="site-menu-information">
        <h2 id="site-menu-information">Informazioni</h2>
        <div class="site-menu-links">
          {siteMenuInformation.map((item) => (
                <a href={item.href}>{item.label} <span class="site-menu-link-arrow" aria-hidden="true">→</span></a>
          ))}
        </div>
      </section>
    </div>
  </aside>
</header>

<script>
  const setupMegaMenus = () => {
    const header = document.querySelector('.site-header');
    const mobileTrigger = document.querySelector('[data-mobile-menu-trigger]');
    const mobilePanel = document.querySelector('[data-mobile-menu-panel]');
    const menus = document.querySelectorAll('[data-mega-menu]');
    const mobileQuery = window.matchMedia('(max-width: 900px)');

    const syncMobilePanelState = () => {
      if (!mobileQuery.matches || !mobilePanel) return;

      const menuList = Array.from(menus);
      mobilePanel.classList.toggle('has-drilldown', menuList.some((menu) => menu.classList.contains('is-open')));
      mobilePanel.classList.toggle('has-detail', menuList.some((menu) => menu.classList.contains('is-detail-open')));
    };

    const setMobileOpen = (isOpen) => {
      header?.classList.toggle('mobile-menu-open', isOpen);
      if (isOpen) header?.classList.remove('is-hidden');
      mobileTrigger?.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      mobileTrigger?.setAttribute('aria-label', isOpen ? 'Chiudi menu' : 'Apri menu');

      if (!isOpen) {
        mobilePanel?.classList.remove('has-drilldown', 'has-detail');
        menus.forEach((menu) => {
          menu.classList.remove('is-open', 'is-detail-open');
          menu.querySelector('[data-mega-trigger]')?.setAttribute('aria-expanded', 'false');
          const mobileTitle = menu.querySelector('[data-mobile-drilldown-title]');
          if (mobileTitle) mobileTitle.textContent = menu.dataset.menuTitle || 'Menu';
        });
      }
    };

    if (mobileTrigger && mobilePanel && mobileTrigger.dataset.ready !== 'true') {
      mobileTrigger.dataset.ready = 'true';

      mobileTrigger.addEventListener('click', (event) => {
        event.preventDefault();
        setMobileOpen(!header?.classList.contains('mobile-menu-open'));
      });

      mobilePanel.addEventListener('click', (event) => {
        const target = event.target;
        if (
          target instanceof Element &&
          target.closest('a') &&
          !target.closest('[data-mega-trigger]') &&
          !target.closest('[data-treatment-tab]')
        ) {
          setMobileOpen(false);
        }
      });

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (target instanceof Node && header && !header.contains(target)) {
          setMobileOpen(false);
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') setMobileOpen(false);
      });

      mobileQuery.addEventListener('change', () => setMobileOpen(false));
    }

    menus.forEach((menu) => {
      if (menu.dataset.ready === 'true') return;
      menu.dataset.ready = 'true';

      const trigger = menu.querySelector('[data-mega-trigger]');
      const mobileBack = menu.querySelector('[data-mobile-menu-back]');
      const mobileTitle = menu.querySelector('[data-mobile-drilldown-title]');
      const defaultMobileTitle = menu.dataset.menuTitle || 'Menu';
      const tabButtons = Array.from(menu.querySelectorAll('[data-treatment-tab]'));
      const tabPanels = Array.from(menu.querySelectorAll('[data-treatment-panel]'));
      let closeMenuTimeout;

      const clearCloseDelay = () => {
        if (!closeMenuTimeout) return;
        window.clearTimeout(closeMenuTimeout);
        closeMenuTimeout = undefined;
      };

      const setOpen = (isOpen) => {
        if (isOpen) clearCloseDelay();

        if (isOpen) {
          menus.forEach((otherMenu) => {
            if (otherMenu === menu) return;
            otherMenu.classList.remove('is-open', 'is-detail-open');
            otherMenu.querySelector('[data-mega-trigger]')?.setAttribute('aria-expanded', 'false');
            const otherTitle = otherMenu.querySelector('[data-mobile-drilldown-title]');
            if (otherTitle) otherTitle.textContent = otherMenu.dataset.menuTitle || 'Menu';
          });
        }

        menu.classList.toggle('is-open', isOpen);
        trigger?.setAttribute('aria-expanded', isOpen ? 'true' : 'false');

        if (mobileQuery.matches) {
          if (!isOpen) {
            menu.classList.remove('is-detail-open');
            if (mobileTitle) mobileTitle.textContent = defaultMobileTitle;
          }

          syncMobilePanelState();
        }
      };

      const closeDesktopMenu = () => {
        setOpen(false);

        const activeElement = document.activeElement;
        if (activeElement instanceof HTMLElement && menu.contains(activeElement)) {
          activeElement.blur();
        }
      };

      const scheduleDesktopClose = () => {
        clearCloseDelay();
        closeMenuTimeout = window.setTimeout(closeDesktopMenu, 180);
      };

      const activateTab = (activeTab) => {
        const targetId = activeTab.dataset.target;

        tabButtons.forEach((tab) => {
          const isActive = tab === activeTab;
          tab.classList.toggle('is-active', isActive);
          tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
          tab.setAttribute('tabindex', isActive ? '0' : '-1');
        });

        tabPanels.forEach((panel) => {
          const isActive = panel.id === targetId;
          panel.classList.toggle('is-active', isActive);
          panel.hidden = !isActive;
        });
      };

      const setMobileDetail = (activeTab) => {
        const label = activeTab.querySelector('.mega-tab-label')?.textContent?.trim() || activeTab.textContent?.trim() || 'Trattamenti';
        menu.classList.add('is-detail-open');
        syncMobilePanelState();
        if (mobileTitle) mobileTitle.textContent = label;
      };

      trigger?.addEventListener('click', (event) => {
        if (mobileQuery.matches) {
          event.preventDefault();
          const shouldOpen = !menu.classList.contains('is-open');
          if (shouldOpen) mobilePanel?.classList.remove('has-detail');
          setOpen(shouldOpen);
        }
      });

      mobileBack?.addEventListener('click', () => {
        if (mobileQuery.matches) setOpen(false);
      });

      menu.addEventListener('mouseenter', () => {
        if (!mobileQuery.matches) {
          clearCloseDelay();
          setOpen(true);
        }
      });

      menu.addEventListener('mouseleave', () => {
        if (!mobileQuery.matches) scheduleDesktopClose();
      });

      menu.addEventListener('focusin', () => {
        clearCloseDelay();
        setOpen(true);
      });

      menu.addEventListener('focusout', () => {
        window.setTimeout(() => {
          if (!mobileQuery.matches && !menu.contains(document.activeElement)) {
            setOpen(false);
          }
        }, 0);
      });

      tabButtons.forEach((tab) => {
        tab.addEventListener('click', (event) => {
          activateTab(tab);
          const isDirectLink = tab instanceof HTMLAnchorElement && tab.dataset.directLink === 'true';
          if (mobileQuery.matches && !isDirectLink) {
            event.preventDefault();
            setMobileDetail(tab);
          }
        });
        tab.addEventListener('mouseenter', () => {
          if (!mobileQuery.matches) activateTab(tab);
        });
      });

      document.addEventListener('click', (event) => {
        clearCloseDelay();
        if (!menu.contains(event.target)) setOpen(false);
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          clearCloseDelay();
          setOpen(false);
          trigger?.focus();
        }
      });

      mobileQuery.addEventListener('change', () => {
        clearCloseDelay();
        setOpen(false);
      });
    });
  };

  const setupOverlayHeader = () => {
    const header = document.querySelector('[data-overlay-header="true"]');
    if (!(header instanceof HTMLElement)) return;

    const boundary = document.querySelector('[data-transparent-header-region]') || document.querySelector('main > *:first-child');
    if (!(boundary instanceof HTMLElement)) return;

    const syncHeaderTheme = () => {
      const headerHeight = header.offsetHeight || 0;
      const isOverColor = boundary.getBoundingClientRect().bottom > headerHeight + 1;
      const menuIsOpen = header.classList.contains('mobile-menu-open') || header.classList.contains('site-menu-open');
      header.classList.toggle('is-over-hero', isOverColor && !menuIsOpen);
    };

    syncHeaderTheme();
    window.addEventListener('scroll', syncHeaderTheme, { passive: true });
    window.addEventListener('resize', syncHeaderTheme);
  };

  const setupSiteMenu = () => {
    const header = document.querySelector('[data-site-menu-root]');
    const trigger = document.querySelector('[data-site-menu-trigger]');
    const panel = document.querySelector('[data-site-menu-panel]');
    const closeTargets = document.querySelectorAll('[data-site-menu-close]');

    if (!(header instanceof HTMLElement) || !(trigger instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) {
      return;
    }

    const setOpen = (isOpen) => {
      header.classList.toggle('site-menu-open', isOpen);
      document.documentElement.classList.toggle('site-menu-lock', isOpen);
      document.body.classList.toggle('site-menu-lock', isOpen);
      trigger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      trigger.setAttribute('aria-label', isOpen ? 'Chiudi menu' : 'Apri menu');
      panel.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
      if (isOpen) header.classList.remove('is-hidden');
    };

    trigger.addEventListener('click', () => {
      setOpen(!header.classList.contains('site-menu-open'));
    });

    closeTargets.forEach((target) => {
      target.addEventListener('click', () => setOpen(false));
    });

    panel.addEventListener('click', (event) => {
      const target = event.target;
      if (target instanceof Element && target.closest('a')) setOpen(false);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') setOpen(false);
    });
  };

  const setupCallDropdowns = () => {
    const dropdowns = Array.from(document.querySelectorAll('[data-call-dropdown]'));

    dropdowns.forEach((dropdown) => {
      if (!(dropdown instanceof HTMLDetailsElement) || dropdown.dataset.ready === 'true') return;
      dropdown.dataset.ready = 'true';

      dropdown.addEventListener('toggle', () => {
        if (!dropdown.open) return;
        dropdowns.forEach((otherDropdown) => {
          if (otherDropdown instanceof HTMLDetailsElement && otherDropdown !== dropdown) {
            otherDropdown.open = false;
          }
        });
      });
    });

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Node)) return;

      dropdowns.forEach((dropdown) => {
        if (dropdown instanceof HTMLDetailsElement && !dropdown.contains(target)) {
          dropdown.open = false;
        }
      });
    });

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;

      dropdowns.forEach((dropdown) => {
        if (dropdown instanceof HTMLDetailsElement) dropdown.open = false;
      });
    });
  };

  const setupHeaderVisibility = () => {
    const header = document.querySelector('.site-header');
    if (!(header instanceof HTMLElement)) return;

    let lastScrollY = window.scrollY;
    let ticking = false;

    const shouldKeepVisible = () =>
      header.classList.contains('mobile-menu-open') ||
      header.classList.contains('site-menu-open') ||
      header.matches(':focus-within') ||
      Boolean(header.querySelector('.nav-mega.is-open'));

    const syncHeaderVisibility = () => {
      const currentScrollY = Math.max(0, window.scrollY);
      const delta = currentScrollY - lastScrollY;
      const hideAfter = (header.offsetHeight || 0) + 32;

      if (currentScrollY <= 4 || shouldKeepVisible()) {
        header.classList.remove('is-hidden');
        lastScrollY = currentScrollY;
        ticking = false;
        return;
      }

      if (Math.abs(delta) > 6) {
        header.classList.toggle('is-hidden', delta > 0 && currentScrollY > hideAfter);
        lastScrollY = currentScrollY;
      }

      ticking = false;
    };

    const requestSync = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(syncHeaderVisibility);
    };

    syncHeaderVisibility();
    window.addEventListener('scroll', requestSync, { passive: true });
    window.addEventListener('resize', () => {
      header.classList.remove('is-hidden');
      lastScrollY = Math.max(0, window.scrollY);
      requestSync();
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      setupMegaMenus();
      setupOverlayHeader();
      setupSiteMenu();
      setupCallDropdowns();
      setupHeaderVisibility();
    }, { once: true });
  } else {
    setupMegaMenus();
    setupOverlayHeader();
    setupSiteMenu();
    setupCallDropdowns();
    setupHeaderVisibility();
  }
</script>
