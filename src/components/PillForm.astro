---
interface Props {
  variant?: 'compact' | 'full';
  title?: string;
  note?: string;
}

const {
  variant = 'compact',
  title = variant === 'compact' ? undefined : 'Compila il modulo contatti per ulteriori informazioni!',
  note = variant === 'compact' ? '' : 'Modulo statico: l’invio email verrà collegato successivamente con Resend.',
} = Astro.props;
---

<form class:list={['pill-form', `pill-form-${variant}`]} data-static-form>
  {title && <h2>{title}</h2>}

  {variant === 'compact' ? (
    <div class="pill-form-row">
      <label>
        <span>Nome e cognome</span>
        <input type="text" name="your-name" placeholder="Nome e cognome" autocomplete="name" />
      </label>
      <label>
        <span>Telefono</span>
        <input type="tel" name="your-phone" placeholder="Telefono" autocomplete="tel" />
      </label>
      <button class="button button-primary" type="submit">Richiedi Info <span aria-hidden="true">↗</span></button>
    </div>
  ) : (
    <>
      <div class="form-grid">
        <label>Nome
          <input type="text" name="your-name" placeholder="Nome" autocomplete="given-name" />
        </label>
        <label>Cognome
          <input type="text" name="your-lastname" placeholder="Cognome" autocomplete="family-name" />
        </label>
        <label>Telefono
          <input type="tel" name="your-phone" placeholder="Telefono" autocomplete="tel" />
        </label>
        <label>Email
          <input type="email" name="your-email" placeholder="Email" autocomplete="email" />
        </label>
        <label class="full-span">Messaggio
          <textarea name="your-message" placeholder="Messaggio"></textarea>
        </label>
      </div>
      <label class="checkbox-row">
        <input type="checkbox" name="acceptance-459" value="1" />
        <span>Accetto l’informativa sulla privacy policy</span>
      </label>
      <button class="button button-primary" type="submit">Richiedi Info <span aria-hidden="true">↗</span></button>
    </>
  )}
  {note && <p class="form-note">{note}</p>}
</form>

<script>
  document.querySelectorAll('[data-static-form]').forEach((form) => {
    form.addEventListener('submit', (event) => {
      event.preventDefault();
    });
  });
</script>
