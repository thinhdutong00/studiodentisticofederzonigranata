  /* MioDottore-inspired treatment mega menu */
  :root {
    --nav-height: 80px;
    --mega-radius: 24px;
  }

  .site-header {
    z-index: 1000;
    background: rgba(255, 255, 255, 0.98);
    border-bottom: 1px solid rgba(12, 77, 162, 0.12);
    box-shadow: none;
  }

  .header-inner {
    min-height: var(--nav-height);
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 28px;
    padding: 0;
  }

  .brand {
    padding: 0;
  }

  .brand img {
    width: 286px;
    max-width: 26vw;
  }

  .primary-nav {
    flex-wrap: nowrap;
    justify-content: center;
    gap: 4px;
    overflow: visible;
    font-size: 0.82rem;
    text-transform: none;
  }

  .primary-nav > a.primary-nav-link,
  .primary-nav-trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    border: 0;
    border-radius: 8px;
    padding: 10px 12px;
    background: transparent;
    color: var(--blue-dark);
    font-family: "Montserrat", "Century Gothic", CenturyGothic, AppleGothic, sans-serif;
    font-size: 0.82rem;
    font-weight: 800;
    line-height: 1;
    text-decoration: none;
    text-transform: none;
    white-space: nowrap;
    cursor: pointer;
  }

  .primary-nav > a.primary-nav-link:hover,
  .primary-nav > a.primary-nav-link:focus-visible,
  .primary-nav-trigger:hover,
  .primary-nav-trigger:focus-visible,
  .nav-mega.is-open .primary-nav-trigger,
  .nav-mega:hover .primary-nav-trigger,
  .nav-mega:focus-within .primary-nav-trigger {
    background: var(--signal-soft);
    color: var(--blue);
    outline: 0;
  }

  .primary-nav-trigger {
    gap: 7px;
  }

  .mobile-drilldown-bar,
  .mega-tab-count,
  .treatment-card-icon {
    display: none;
  }

  .nav-caret {
    width: 7px;
    height: 7px;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: translateY(-2px) rotate(45deg);
    transition: transform 160ms ease;
  }

  .nav-mega.is-open .nav-caret,
  .nav-mega:hover .nav-caret,
  .nav-mega:focus-within .nav-caret {
    transform: translateY(2px) rotate(225deg);
  }

  .nav-mega {
    display: inline-flex;
    align-items: center;
    min-height: var(--nav-height);
  }

  .mobile-menu-trigger,
  .mobile-menu-cta {
    display: none;
  }

  .mega-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    width: min(1180px, calc(100vw - 64px));
    max-height: calc(100vh - var(--nav-height) - 24px);
    overflow: auto;
    border: 0;
    border-radius: 0 0 var(--mega-radius) var(--mega-radius);
    background: #fff;
    box-shadow: 0 18px 48px rgba(36, 39, 39, 0.12);
    color: var(--ink);
    opacity: 0;
    pointer-events: none;
    text-transform: none;
    transform: translate(-50%, 10px);
    transition:
      opacity 160ms ease,
      transform 160ms ease,
      visibility 160ms ease;
    visibility: hidden;
  }

  .nav-mega:hover .mega-menu,
  .nav-mega:focus-within .mega-menu,
  .nav-mega.is-open .mega-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translate(-50%, 0);
    visibility: visible;
  }

  .mega-menu {
    display: grid;
    grid-template-columns: 300px minmax(0, 1fr);
  }

  .mega-menu-tabs {
    display: grid;
    align-content: start;
    gap: 8px;
    padding: 28px 18px 28px 28px;
    background: var(--blue-dark);
    border-radius: 0 0 0 var(--mega-radius);
  }

  .mega-tab {
    display: block;
    min-height: 44px;
    border: 0;
    border-radius: 8px;
    padding: 11px 13px;
    background: transparent;
    color: #fff;
    font: inherit;
    font-weight: 900;
    line-height: 1.25;
    text-align: left;
    text-decoration: none;
    cursor: pointer;
  }

  .primary-nav .mega-tab {
    display: block;
    min-height: 44px;
    border-radius: 8px;
    padding: 11px 13px;
    background: transparent;
    color: #fff;
    font-family: "Montserrat", "Century Gothic", CenturyGothic, AppleGothic, sans-serif;
    font-size: 0.82rem;
    font-weight: 900;
    line-height: 1.25;
    text-align: left;
    text-decoration: none;
    white-space: normal;
  }

  .mega-tab:hover,
  .mega-tab:focus-visible,
  .mega-tab.is-active,
  .primary-nav .mega-tab:hover,
  .primary-nav .mega-tab:focus-visible,
  .primary-nav .mega-tab.is-active {
    background: #fff;
    color: var(--blue);
    outline: 0;
  }

  .mega-menu-content {
    display: grid;
    min-width: 0;
    padding: 28px;
    background: linear-gradient(90deg, #fff 0%, #fff 62%, var(--signal-soft) 62%, var(--signal-soft) 100%);
    border-radius: 0 0 var(--mega-radius) 0;
    overflow: hidden;
  }

  .mega-menu-panel[hidden] {
    display: none;
  }

  .mega-menu-panel.is-active {
    height: 100%;
    min-height: 100%;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: 28px;
    align-items: stretch;
  }

  .mega-menu-panel-detail.is-active {
    grid-template-columns: minmax(0, 1fr) 300px;
  }

  .mega-treatment-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    align-content: start;
  }

  .mega-treatment-grid-single {
    grid-template-columns: minmax(0, 1fr);
  }

  .primary-nav .treatment-card {
    position: relative;
    min-height: 78px;
    display: grid;
    align-content: center;
    gap: 4px;
    border: 1px solid rgba(12, 77, 162, 0.1);
    border-radius: 8px;
    padding: 14px 42px 14px 15px;
    background: #fff;
    color: var(--ink);
    font-family: "Lato", ui-sans-serif, system-ui, sans-serif;
    line-height: 1.25;
    text-decoration: none;
    text-transform: none;
    white-space: normal;
    box-shadow: 0 8px 20px rgba(36, 48, 51, 0.06);
    transition:
      border-color 150ms ease,
      box-shadow 150ms ease,
      transform 150ms ease;
  }

  .primary-nav .treatment-card::after {
    content: "→";
    position: absolute;
    right: 15px;
    top: 50%;
    color: var(--signal);
    font-weight: 900;
    transform: translateY(-50%);
  }

  .primary-nav .treatment-card:hover,
  .primary-nav .treatment-card:focus-visible {
    border-color: rgba(12, 77, 162, 0.28);
    color: var(--blue);
    box-shadow: 0 12px 26px rgba(36, 48, 51, 0.1);
    transform: translateY(-1px);
    outline: 0;
  }

  .primary-nav .treatment-card:hover::after,
  .primary-nav .treatment-card:focus-visible::after,
  .primary-nav .treatment-card:hover .treatment-card-copy > span,
  .primary-nav .treatment-card:focus-visible .treatment-card-copy > span {
    color: var(--blue);
  }

  .treatment-card-copy {
    display: grid;
    gap: 4px;
    min-width: 0;
  }

  .treatment-card-copy > span {
    color: var(--blue-dark);
    font-size: 0.96rem;
    font-weight: 900;
  }

  .treatment-card small {
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .mega-feature {
    min-width: 0;
    display: grid;
    grid-template-rows: minmax(168px, 1fr) auto;
    gap: 14px;
    border-radius: 14px;
    padding: 14px;
    background: rgba(255, 255, 255, 0.72);
  }

  .mega-feature img {
    width: 100%;
    height: 100%;
    min-height: 168px;
    border-radius: 10px;
    object-fit: cover;
    background: var(--soft-blue);
  }

  .mega-feature div {
    display: grid;
    gap: 3px;
  }

  .mega-feature-kicker {
    margin: 0;
    color: var(--signal);
    font-size: 0.74rem;
    font-weight: 900;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .mega-feature strong {
    color: var(--blue-dark);
    font-size: 1.08rem;
    line-height: 1.2;
  }

  .detail-menu-copy {
    min-width: 0;
    min-height: 220px;
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    gap: 10px;
    border: 0;
    border-radius: 0;
    padding: 10px 8px 4px 0;
    background: transparent;
    box-shadow: none;
  }

  .detail-menu-kicker {
    margin: 0;
    color: var(--signal);
    font-size: 0.74rem;
    font-weight: 900;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .detail-menu-copy h3 {
    margin: 0;
    color: var(--blue-dark);
    font-size: 1.28rem;
    line-height: 1.15;
  }

  .detail-menu-copy p:not(.detail-menu-kicker) {
    margin: 0;
    color: var(--muted);
    font-size: 0.96rem;
    font-weight: 700;
    line-height: 1.55;
  }

  .primary-nav .detail-menu-cta {
    justify-self: end;
    align-self: end;
    min-height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    padding: 10px 16px;
    background: var(--signal);
    color: #fff;
    font-family: "Montserrat", "Century Gothic", CenturyGothic, AppleGothic, sans-serif;
    font-size: 0.82rem;
    font-weight: 900;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    box-shadow: 0 10px 18px rgba(12, 77, 162, 0.14);
  }

  .primary-nav .detail-menu-cta:hover,
  .primary-nav .detail-menu-cta:focus-visible {
    background: var(--blue);
    color: #fff;
    outline: 0;
  }

  .mega-feature-image-only {
    width: auto;
    height: calc(100% + 56px);
    min-height: 0;
    align-self: stretch;
    grid-template-rows: minmax(0, 1fr);
    gap: 0;
    overflow: hidden;
    margin: -28px -28px -28px 0;
    padding: 0;
    background: var(--signal-soft);
    border-radius: 0 0 var(--mega-radius) 0;
  }

  .mega-feature-image-only img {
    display: block;
    min-height: 0;
    height: 100%;
    border-radius: 0;
  }

  .mega-feature-image-square {
    width: calc(100% + 28px);
    height: auto;
    aspect-ratio: 1;
    align-self: start;
    margin: -28px -28px -28px 0;
    border-radius: 0;
  }

  .mega-feature-image-square img {
    width: 100%;
    height: 100%;
    border-radius: 0;
    object-fit: cover;
  }

  @media (max-width: 1180px) {
    .header-inner {
      grid-template-columns: auto minmax(0, 1fr) auto;
    }

    .brand img {
      width: 248px;
      max-width: 24vw;
    }

    .primary-nav {
      grid-column: auto;
      justify-content: center;
      overflow: visible;
      font-size: 0.76rem;
    }

    .primary-nav > a.primary-nav-link,
    .primary-nav-trigger {
      padding: 9px 8px;
      font-size: 0.76rem;
    }

    .mega-menu {
      width: min(960px, calc(100vw - 36px));
      grid-template-columns: 250px minmax(0, 1fr);
    }

    .mega-menu-panel.is-active {
      grid-template-columns: minmax(0, 1fr) 220px;
    }
  }

  @media (max-width: 900px) {
